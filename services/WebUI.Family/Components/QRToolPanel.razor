@using Microsoft.JSInterop
@using TaskRunner.Contracts.Pairing
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<div class="qr-tool-container">
    <!-- 服务器配对二维码 (紧凑横排) -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">🏠 服务器配对码</h5>
            <button class="btn btn-sm btn-outline-primary" @onclick="LoadServerQRCode" disabled="@_isLoadingServerQR">
                @if (_isLoadingServerQR)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>加载中...</span>
                }
                else
                {
                    <span>🔄 刷新</span>
                }
            </button>
        </div>
        <div class="card-body">
            @if (_serverQRCode != null)
            {
                @if (_isEditingName)
                {
                    <div class="name-edit-section">
                        <div class="name-edit-row">
                            <span class="info-label">名称</span>
                            <input class="name-edit-input" @bind="_editingName" @bind:event="oninput" @onkeydown="OnNameKeydown" placeholder="输入服务器名称" autofocus />
                            <button class="name-edit-btn name-save" @onclick="SaveDisplayNameAsync" disabled="@_isSavingName" title="保存">
                                @if (_isSavingName) { <span class="spinner-border spinner-border-sm"></span> } else { <span>✓</span> }
                            </button>
                            <button class="name-edit-btn name-cancel" @onclick="CancelEditName" disabled="@_isSavingName" title="取消">✗</button>
                        </div>
                        @if (!string.IsNullOrEmpty(_nameSaveMessage))
                        {
                            <div class="name-save-msg @(_nameSaveSuccess ? "success" : "error")">@_nameSaveMessage</div>
                        }
                    </div>
                }
                else
                {
                    <div class="server-qr-compact">
                        <div class="qr-code-wrapper qr-compact" @ref="_serverQrContainer"></div>
                        <div class="server-info-compact">
                            <div class="info-row info-row-editable">
                                <span class="info-label">名称</span>
                                <span class="info-value">@_serverQRCode.HostName</span>
                                <button class="name-edit-trigger" @onclick="StartEditName" title="修改名称">✏️</button>
                            </div>
                            @if (!string.IsNullOrEmpty(_nameSaveMessage))
                            {
                                <div class="name-save-msg @(_nameSaveSuccess ? "success" : "error")">@_nameSaveMessage</div>
                            }
                            <div class="info-row">
                                <span class="info-label">ServerId</span>
                                <span class="info-value text-truncate" title="@_serverQRCode.ServerId">@_serverQRCode.ServerId</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">地址</span>
                                <span class="info-value text-truncate" title="@_serverQRCode.Url">@_serverQRCode.Url</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(_serverQRError))
            {
                <div class="alert alert-warning mb-0">@_serverQRError</div>
            }
            else
            {
                <p class="text-muted mb-0">点击「刷新」加载服务器配对二维码</p>
            }
        </div>
    </div>

    <!-- 主 AI API Key 二维码 -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" @onclick="ToggleAiKey" role="button" tabindex="0">
            <h5 class="mb-0">🤖 主 AI API Key</h5>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-primary" @onclick="LoadMainAiApiKey" disabled="@_isLoadingAiKey" @onclick:stopPropagation>
                    @if (_isLoadingAiKey)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>加载中...</span>
                    }
                    else
                    {
                        <span>🔄 刷新</span>
                    }
                </button>
                <span class="collapse-indicator">@(_showAiKey ? "▲" : "▼")</span>
            </div>
        </div>
        <div class="card-body collapse @(_showAiKey ? "show" : "")">
            @if (_aiKeyQRCode != null)
            {
                <div class="server-qr-compact">
                    <div class="qr-code-wrapper qr-compact" @ref="_aiKeyQrContainer"></div>
                    <div class="server-info-compact">
                        <div class="info-row">
                            <span class="info-label">提供商</span>
                            <span class="info-value">@_aiKeyQRCode.ProviderName</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">ProviderId</span>
                            <span class="info-value text-truncate" title="@_aiKeyQRCode.ProviderId">@_aiKeyQRCode.ProviderId</span>
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(_aiKeyQRError))
            {
                <div class="alert alert-warning mb-0">@_aiKeyQRError</div>
            }
            else
            {
                <p class="text-muted mb-0">点击「刷新」加载主 AI API Key 二维码</p>
            }
        </div>
    </div>

    <!-- 通用二维码生成 -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center" @onclick="ToggleGeneralQR" role="button" tabindex="0">
            <h5 class="mb-0">📝 通用二维码</h5>
            <span class="collapse-indicator">@(_showGeneralQR ? "▲" : "▼")</span>
        </div>
        <div class="card-body collapse @(_showGeneralQR ? "show" : "")">
            <div class="server-qr-compact">
                <div class="qr-form-left">
                    <textarea class="form-control" @bind="_inputText" rows="2" placeholder="粘贴要转成二维码的内容..."></textarea>
                    <div class="form-actions mt-2">
                        <button class="btn btn-primary btn-sm" @onclick="GenerateQR">生成二维码</button>
                        <button class="btn btn-secondary btn-sm" @onclick="ClearAll">清空</button>
                    </div>
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-error mt-2 mb-0">@_errorMessage</div>
                    }
                </div>
                <div class="qr-result-compact @(_showQR ? "" : "d-none")">
                    <div class="qr-code-wrapper qr-compact" @ref="_qrContainer"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // 服务器配对二维码
    private ElementReference _serverQrContainer;
    private ServerQRResponse? _serverQRCode;
    private bool _isLoadingServerQR = false;
    private string _serverQRError = "";

    // 主 AI API Key 二维码
    private ElementReference _aiKeyQrContainer;
    private AiKeyQRResponse? _aiKeyQRCode;
    private bool _isLoadingAiKey = false;
    private string _aiKeyQRError = "";

    // 名称内联编辑
    private bool _isEditingName = false;
    private string _editingName = "";
    private bool _isSavingName = false;
    private string _nameSaveMessage = "";
    private bool _nameSaveSuccess = false;

    // 折叠状态
    private bool _showAiKey = false;
    private bool _showGeneralQR = false;

    private void ToggleAiKey() => _showAiKey = !_showAiKey;
    private void ToggleGeneralQR() => _showGeneralQR = !_showGeneralQR;

    // 通用二维码
    private string _inputText = "";
    private bool _showQR = false;
    private string _errorMessage = "";
    private ElementReference _qrContainer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadServerQRCode();
            await LoadMainAiApiKey();
        }
    }

    private async Task LoadMainAiApiKey()
    {
        _isLoadingAiKey = true;
        _aiKeyQRError = "";
        try
        {
            var aiClient = HttpClientFactory.CreateClient("TaskRunnerAiApi");
            _aiKeyQRCode = await aiClient.GetFromJsonAsync<AiKeyQRResponse>("api/ai/config/main-apikey");
            if (_aiKeyQRCode != null && !string.IsNullOrEmpty(_aiKeyQRCode.ApiKey))
            {
                await Task.Yield();
                await JS.InvokeVoidAsync("generateCompactQRCode", _aiKeyQrContainer, _aiKeyQRCode.ApiKey);
            }
        }
        catch (Exception ex)
        {
            _aiKeyQRError = $"加载失败: {ex.Message}";
        }
        finally
        {
            _isLoadingAiKey = false;
        }
    }

    private async Task LoadServerQRCode()
    {
        _isLoadingServerQR = true;
        _serverQRError = "";
        try
        {
            var apiClient = HttpClientFactory.CreateClient("TaskRunnerApi");
            _serverQRCode = await apiClient.GetFromJsonAsync<ServerQRResponse>("api/pairing/qrcode");
            await RenderServerQRCodeAsync();
        }
        catch (Exception ex)
        {
            _serverQRError = $"加载失败: {ex.Message}";
        }
        finally
        {
            _isLoadingServerQR = false;
        }
    }

    private async Task GenerateQR()
    {
        _errorMessage = "";
        if (string.IsNullOrWhiteSpace(_inputText))
        {
            _errorMessage = "请输入内容";
            _showQR = false;
            return;
        }
        _showQR = true;
        await Task.Yield();
        await JS.InvokeVoidAsync("generateCompactQRCode", _qrContainer, _inputText.Trim());
    }

    private void ClearAll()
    {
        _inputText = "";
        _showQR = false;
        _errorMessage = "";
    }

    private async Task RenderServerQRCodeAsync()
    {
        if (_serverQRCode != null && !string.IsNullOrEmpty(_serverQRCode.QrCodeData))
        {
            await Task.Yield();
            await JS.InvokeVoidAsync("generateCompactQRCode", _serverQrContainer, _serverQRCode.QrCodeData);
        }
    }

    private void StartEditName()
    {
        _editingName = _serverQRCode?.HostName ?? "";
        _isEditingName = true;
        _nameSaveMessage = "";
    }

    private async Task CancelEditName()
    {
        _isEditingName = false;
        _nameSaveMessage = "";
        await RenderServerQRCodeAsync();
    }

    private async Task OnNameKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveDisplayNameAsync();
        else if (e.Key == "Escape") CancelEditName();
    }

    private async Task SaveDisplayNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingName))
        {
            _nameSaveSuccess = false;
            _nameSaveMessage = "名称不能为空";
            return;
        }

        _isSavingName = true;
        _nameSaveMessage = "";
        try
        {
            var apiClient = HttpClientFactory.CreateClient("TaskRunnerApi");
            var response = await apiClient.PostAsJsonAsync("api/server-address", new { displayName = _editingName.Trim() });
            if (response.IsSuccessStatusCode)
            {
                _isEditingName = false;
                _nameSaveSuccess = true;
                _nameSaveMessage = "名称已更新";
                await LoadServerQRCode();
            }
            else
            {
                _nameSaveSuccess = false;
                _nameSaveMessage = "保存失败";
            }
        }
        catch (Exception ex)
        {
            _nameSaveSuccess = false;
            _nameSaveMessage = $"保存失败: {ex.Message}";
        }
        finally
        {
            _isSavingName = false;
        }
    }
}

<style>
    .qr-tool-container {
        max-width: 600px;
        margin-top: 1.5rem;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        margin-bottom: 0.35rem;
        font-weight: 500;
    }
    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #c8d4dc;
        border-radius: 4px;
        font-size: 0.95rem;
        font-family: monospace;
    }
    .form-actions {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .btn-primary {
        background: #2e8baf;
        color: white;
    }
    .btn-secondary {
        background: #5a6a72;
        color: white;
    }
    .qr-result {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: #f5f8fa;
        border-radius: 8px;
        text-align: center;
    }
    .qr-result.qr-hidden {
        display: none;
    }
    .qr-code-wrapper {
        display: inline-block;
        padding: 1rem;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        min-height: 200px;
        min-width: 200px;
    }
    .qr-hint {
        margin-top: 1rem;
        color: #666;
        font-size: 0.9rem;
    }
    .alert-error {
        background: #e0ecf4;
        border: 1px solid #c8dde8;
        color: #4a2a30;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 1rem;
    }
    .server-info {
        background: #f5f8fa;
        padding: 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
    }
    .collapse-indicator {
        font-size: 0.75rem;
        color: #888;
        transition: transform 0.2s;
    }
    .card-header[role="button"] {
        cursor: pointer;
        user-select: none;
    }
    .card-header[role="button"]:hover {
        background-color: rgba(0,0,0,0.02);
    }

    /* 紧凑横排布局：二维码左 + 信息右 */
    .server-qr-compact {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .qr-code-wrapper.qr-compact {
        flex-shrink: 0;
        min-height: auto;
        min-width: auto;
        padding: 0.5rem;
    }
    .qr-code-wrapper.qr-compact canvas,
    .qr-code-wrapper.qr-compact img {
        display: block;
        width: 180px;
        height: 180px;
    }
    .server-info-compact {
        flex: 1;
        min-width: 0;
        font-size: 0.85rem;
    }
    .info-row {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 0.2rem 0;
    }
    .info-row + .info-row {
        border-top: 1px solid #eee;
    }
    .info-label {
        flex-shrink: 0;
        color: #888;
        min-width: 4.5em;
    }
    .info-value {
        font-weight: 500;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* 通用二维码紧凑横排：输入区左 + 二维码右 */
    .qr-form-left {
        flex: 1;
        min-width: 0;
    }
    .qr-result-compact {
        flex-shrink: 0;
    }
    .qr-result-compact.d-none {
        display: none;
    }

    /* 名称内联编辑 */
    .name-edit-section {
        max-width: 320px;
    }
    .name-edit-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .name-edit-input {
        flex: 1;
        padding: 0.2rem 0.4rem;
        border: 1px solid #c8d4dc;
        border-radius: 3px;
        font-size: 0.85rem;
        font-weight: 500;
        min-width: 0;
    }
    .name-edit-input:focus {
        outline: none;
        border-color: #80bdff;
        box-shadow: 0 0 0 0.15rem rgba(0,123,255,.2);
    }
    .name-edit-btn {
        border: none;
        border-radius: 3px;
        cursor: pointer;
        font-size: 0.85rem;
        padding: 0.15rem 0.5rem;
        line-height: 1.3;
    }
    .name-save {
        background: #6b9e75;
        color: white;
    }
    .name-save:disabled { opacity: 0.6; cursor: not-allowed; }
    .name-cancel {
        background: #e8eef2;
        color: #5a6a72;
    }
    .name-edit-trigger {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.8rem;
        opacity: 0.4;
        padding: 0 0.2rem;
        transition: opacity 0.2s;
    }
    .name-edit-trigger:hover { opacity: 1; }
    .name-save-msg {
        font-size: 0.75rem;
        padding: 0.15rem 0.4rem;
        margin-top: 0.15rem;
        border-radius: 3px;
    }
    .name-save-msg.success { color: #3d6b45; background: #e0f0e5; }
    .name-save-msg.error { color: #4a2a30; background: #e0ecf4; }
</style>
