@using WebUI.Services

<!-- E2E 性能摘要 -->
@if (Summary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.TotalOperations</div>
                    <small>总操作数</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.AvgTotalTimeMs ms</div>
                    <small>平均总耗时</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.AvgNetworkTimeMs ms</div>
                    <small>平均网络耗时</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.AvgRenderingTimeMs ms</div>
                    <small>平均渲染耗时</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card @(Summary.SlowOperationCount > 0 ? "bg-danger" : "bg-success") text-white">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.SlowOperationCount</div>
                    <small>慢操作(&gt;1s)</small>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-secondary text-white">
                <div class="card-body text-center">
                    <div class="h3 mb-0">@Summary.MaxTotalTimeMs ms</div>
                    <small>最大耗时</small>
                </div>
            </div>
        </div>
    </div>
}

<!-- 最慢的操作 -->
@if (SlowestOperations?.Any() == true)
{
    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">🐌 最慢的操作 Top @(SlowestOperations.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>时间</th>
                            <th>页面</th>
                            <th>操作</th>
                            <th class="text-end">总耗时</th>
                            <th class="text-end">网络</th>
                            <th class="text-end">渲染</th>
                            <th class="text-end">API次数</th>
                            <th>最慢组件</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var op in SlowestOperations)
                        {
                            <tr class="@(op.TotalElapsedMs > 2000 ? "table-danger" : op.TotalElapsedMs > 1000 ? "table-warning" : "")">
                                <td class="small">@op.StartTime.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td><span class="badge bg-secondary">@op.PageName</span></td>
                                <td>@op.OperationName</td>
                                <td class="text-end font-monospace">
                                    <span class="badge @GetTimeBadgeClass(op.TotalElapsedMs)">
                                        @op.TotalElapsedMs ms
                                    </span>
                                </td>
                                <td class="text-end font-monospace text-info">@op.NetworkTimeMs ms</td>
                                <td class="text-end font-monospace text-warning">@op.RenderingTimeMs ms</td>
                                <td class="text-center">@op.ApiCallCount</td>
                                <td><code class="small">@(op.SlowestComponent.Length > 20 ? op.SlowestComponent[..20] + "..." : op.SlowestComponent)</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- 操作详情（可展开） -->
@if (Records?.Any() == true)
{
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">📊 最近操作记录 (@Records.Count 条)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>时间</th>
                            <th>页面</th>
                            <th>操作</th>
                            <th class="text-end">总耗时</th>
                            <th class="text-end">网络</th>
                            <th class="text-end">渲染</th>
                            <th>详情</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Records.Take(50))
                        {
                            <tr>
                                <td class="small text-nowrap">@record.StartTime.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td><span class="badge bg-secondary">@record.PageName</span></td>
                                <td>@record.OperationName</td>
                                <td class="text-end font-monospace">
                                    <span class="badge @GetTimeBadgeClass(record.TotalElapsedMs)">
                                        @record.TotalElapsedMs ms
                                    </span>
                                </td>
                                <td class="text-end font-monospace">@record.NetworkTimeMs ms</td>
                                <td class="text-end font-monospace">@record.RenderingTimeMs ms</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary py-0" @onclick="() => ToggleDetails(record.TraceId)">
                                        @(ExpandedRows.Contains(record.TraceId) ? "收起" : "展开")
                                    </button>
                                </td>
                            </tr>
                            @if (ExpandedRows.Contains(record.TraceId))
                            {
                                <tr>
                                    <td colspan="7" class="p-0">
                                        <div class="p-3 bg-light">
                                            <h6>API 调用 (@record.ApiCalls.Count)</h6>
                                            @if (record.ApiCalls.Any())
                                            {
                                                <table class="table table-sm table-bordered mb-3">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>端点</th>
                                                            <th>方法</th>
                                                            <th class="text-end">耗时</th>
                                                            <th>状态</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var api in record.ApiCalls.OrderByDescending(a => a.ElapsedMilliseconds))
                                                        {
                                                            <tr>
                                                                <td class="small"><code>@api.Endpoint</code></td>
                                                                <td><span class="badge bg-secondary">@api.Method</span></td>
                                                                <td class="text-end font-monospace">@api.ElapsedMilliseconds ms</td>
                                                                <td>
                                                                    @if (api.Success)
                                                                    {
                                                                        <span class="badge bg-success">✓</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-danger">✗</span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                            
                                            <h6>组件渲染 (@record.ComponentRenders.Count)</h6>
                                            @if (record.ComponentRenders.Any())
                                            {
                                                <div class="row g-2">
                                                    @foreach (var comp in record.ComponentRenders.OrderByDescending(c => c.RenderTimeMs).Take(10))
                                                    {
                                                        <div class="col-auto">
                                                            <span class="badge @(comp.RenderTimeMs > 100 ? "bg-warning" : "bg-info")">
                                                                @comp.ComponentName: @comp.RenderTimeMs ms
                                                            </span>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <div class="mb-3">📭</div>
            <p>暂无端到端性能数据</p>
            <p class="small">需要在页面中使用 E2E 追踪 API 来收集数据</p>
        </div>
    </div>
}

<!-- 使用说明 -->
<div class="alert alert-info mt-4">
    <h6>💡 端到端性能监控说明</h6>
    <p class="small mb-2">追踪从用户操作 → API 调用 → 页面渲染的完整链路：</p>
    <ul class="mb-0 small">
        <li><strong>总耗时</strong> = 从操作开始到页面渲染完成</li>
        <li><strong>网络耗时</strong> = 所有 API 调用耗时之和</li>
        <li><strong>渲染耗时</strong> = 所有组件渲染耗时之和（可能有并行）</li>
        <li><strong>瓶颈识别</strong>：总耗时高但网络低 → 渲染问题；网络高 → API 问题</li>
    </ul>
</div>

@code {
    [Parameter] public E2EPerformanceSummary? Summary { get; set; }
    [Parameter] public List<E2EPerformanceRecord>? Records { get; set; }
    [Parameter] public List<E2EPerformanceRecord>? SlowestOperations { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }
    
    private HashSet<string> ExpandedRows { get; set; } = new();

    private void ToggleDetails(string traceId)
    {
        if (ExpandedRows.Contains(traceId))
            ExpandedRows.Remove(traceId);
        else
            ExpandedRows.Add(traceId);
    }

    private string GetTimeBadgeClass(long ms)
    {
        if (ms > 2000) return "bg-danger";
        if (ms > 1000) return "bg-warning text-dark";
        if (ms > 500) return "bg-info";
        return "bg-success";
    }
}
