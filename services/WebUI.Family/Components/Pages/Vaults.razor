    // Git操作方法
    private async Task DoCommit()
    {
        if (activeVault == null)
        {
            message = "请先选择知识库";
            success = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(commitMessage)) return;
        
        isLoading = true;
        action = "commit";
        message = null;
        
        try
        {
            var client = HttpClientFactory.CreateClient("TaskRunnerApi");
            var url = $"api/git/commit?vaultId={Uri.EscapeDataString(activeVault.Id)}";
            var resp = await client.PostAsJsonAsync(url, new { message = commitMessage });
            var result = await resp.Content.ReadFromJsonAsync<GitResultResponse>();
            message = result?.Message;
            success = result?.Success ?? false;
            if (success) commitMessage = "";
            await LoadGitData();
        }
        catch (Exception ex)
        {
            message = $"提交失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isLoading = false;
            action = "";
        }
    }

