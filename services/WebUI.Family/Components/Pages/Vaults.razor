    // Vault操作方法
    private async Task AddNewVault()
    {
        if (string.IsNullOrWhiteSpace(newVaultName))
        {
            message = "请输入知识库名称";
            success = false;
            return;
        }
        if (string.IsNullOrEmpty(vaultRootPathPreference))
        {
            message = "请先设置知识库根路径";
            success = false;
            return;
        }

        isLoading = true;
        message = null;

        try
        {
            var vaultName = newVaultName.Trim();
            var industry = newVaultIndustry.Trim();
            var vaultPath = System.IO.Path.Combine(vaultRootPathPreference, "local", industry, vaultName);
            var (success, vault, error) = await VaultsService.AddVaultAsync(vaultName, vaultPath, industry);

            if (success && vault != null)
            {
                message = $"知识库 \"{vaultName}\" 添加成功";
                this.success = true;
                newVaultName = "";
                await LoadVaultsData();
                await StatusUpdateService.NotifyVaultStatusChangedAsync();
                VaultStatusService.NotifyStateChanged();
            }
            else
            {
                message = $"添加失败: {error}";
                this.success = false;
            }
        }
        catch (Exception ex)
        {
            message = $"添加失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SyncVaults()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "同步知识库将检测并移除已不存在的知识库。确定要继续吗？"))
            return;
        isLoading = true;
        message = null;

        try
        {
            var (success, added, removed, error) = await VaultsService.SyncVaultsAsync();

            if (success)
            {
                var parts = new List<string>();
                if (added > 0) parts.Add($"新增 {added} 个");
                if (removed > 0) parts.Add($"移除 {removed} 个");
                message = parts.Count > 0 ? $"同步完成：{string.Join("，", parts)}" : "知识库已是最新状态";
                this.success = true;
                await LoadVaultsData();
                await StatusUpdateService.NotifyVaultStatusChangedAsync();
                VaultStatusService.NotifyStateChanged();
            }
            else
            {
                message = $"同步失败: {error}";
                this.success = false;
            }
        }
        catch (Exception ex)
        {
            message = $"同步失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isLoading = false;
        }
    }

