@page "/vaults"
@rendermode InteractiveServer
@inherits WebUI.Components.PerformanceComponentBase
@using System.IO
@inject VaultsService VaultsService
@inject VaultStatusService VaultStatusService
@inject WebUI.Hubs.StatusUpdateService StatusUpdateService
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IApiService ApiService
@inject ILogger<Vaults> Logger
@inject BackupService BackupService

<PageTitle>知识库管理</PageTitle>

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="mb-0">📚 知识库管理</h2>
            <div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshCurrentTab" disabled="@isLoading">🔄 刷新</button>
            </div>
        </div>
        <div class="card-body">
            <!-- Tab导航 -->
            <ul class="nav nav-tabs mb-4">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "vaults" ? "active" : "")" @onclick='() => SwitchTab("vaults")'>
                        📁 知识库路径配置
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "git" ? "active" : "")" @onclick='() => SwitchTab("git")'>
                        🌿 根路径 Git
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "backup" ? "active" : "")" @onclick='() => SwitchTab("backup")'>
                        💾 备份恢复
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "trash" ? "active" : "")" @onclick='() => SwitchTab("trash")'>
                        🗑️ 回收站
                        @if (trashVaults.Count > 0)
                        {
                            <span class="badge bg-danger ms-1">@trashVaults.Count</span>
                        }
                    </button>
                </li>
            </ul>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert alert-@(success ? "success" : "danger") alert-dismissible fade show">
                    @message
                    @if (success && !string.IsNullOrEmpty(lastCreatedTaskId))
                    {
                        <a href="tasks" class="alert-link ms-2">→ 查看任务</a>
                    }
                    <button type="button" class="btn-close" @onclick="() => { message = null; lastCreatedTaskId = null; }"></button>
                </div>
            }

            @if (activeTab == "vaults")
            {
                <!-- 知识库路径配置 Tab -->

                <!-- 加载中状态 -->
                @if (isInitializing)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">加载中...</span>
                        </div>
                        <p class="mt-3 text-muted">正在加载知识库数据...</p>
                    </div>
                }
                else
                {
                    <!-- 知识库根路径（约定的固定路径） -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">📂 知识库根路径</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-2">新建知识库时，将在此路径下创建子目录。</p>
                            <div class="alert alert-info mb-2 py-2">
                                <small>🔒 使用约定的固定路径，不可修改</small>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <input type="text" class="form-control" value="@vaultRootPathPreference" readonly style="background-color: #f5f8fa;" />
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(vaultRootPathPreference))
                            {
                                <small class="text-muted mt-2 d-block">
                                    @if (Directory.Exists(vaultRootPathPreference))
                                    {
                                        <span class="text-success">✅ 路径存在</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning">⚠️ 路径不存在，新建知识库时会自动创建</span>
                                    }
                                </small>
                            }
                        </div>
                    </div>

                <!-- NotesMD CLI 推荐/状态 -->
                @if (notesMdStatus == null)
                {
                    <div class="alert alert-light border mb-3">
                        <h6 class="alert-heading">💡 推荐安装 NotesMD CLI</h6>
                        <p class="mb-1 small">
                            <a href="https://github.com/Yakitrak/notesmd-cli" target="_blank">notesmd-cli</a> 
                            是一个无需运行 Obsidian 即可管理 vault 的命令行工具，非常适合脚本化和自动化场景。
                            安装后可将本系统的知识库一键注册到 Obsidian，实现无缝衔接。
                        </p>
                        <p class="mb-0 small text-muted">
                            安装命令（Windows: <code>scoop install notesmd-cli</code> | macOS/Linux: <code>brew install yakitrak/yakitrak/notesmd-cli</code>）
                        </p>
                    </div>
                }
                else if (notesMdStatus.Available)
                {
                    <div class="card mb-3">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="small">
                                    <span class="badge bg-success">✅ notesmd-cli 已就绪</span>
                                    <span class="text-muted ms-2">
                                        已注册 @(notesMdStatus.RegisteredPaths.Count) 个 Obsidian 知识库
                                        @if (GetUnregisteredVaultCount() > 0)
                                        {
                                            <span class="text-warning">，尚有 @(GetUnregisteredVaultCount()) 个未注册</span>
                                        }
                                    </span>
                                </div>
                                @if (GetUnregisteredVaultCount() > 0)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="BatchAddVaultsToNotesMd" disabled="@isNotesMdLoading">
                                        @if (isNotesMdLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        📌 一键注册全部到 Obsidian
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border mb-3">
                        <h6 class="alert-heading">💡 推荐安装 NotesMD CLI</h6>
                        <p class="mb-1 small">
                            <a href="https://github.com/Yakitrak/notesmd-cli" target="_blank">notesmd-cli</a> 
                            是一个无需运行 Obsidian 即可管理 vault 的命令行工具，非常适合脚本化和自动化场景。
                            安装后可将本系统的知识库一键注册到 Obsidian，实现无缝衔接。
                        </p>
                        <p class="mb-0 small text-muted">
                            安装命令（Windows: <code>scoop install notesmd-cli</code> | macOS/Linux: <code>brew install yakitrak/yakitrak/notesmd-cli</code>）
                        </p>
                    </div>
                }

                <!-- 添加新知识库 -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">➕ 添加新知识库</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label small mb-1">行业</label>
                                <select class="form-select form-select-sm" @bind="newVaultIndustry">
                                    <option value="笔记">📝 笔记</option>
                                    <option value="计算机">💻 计算机</option>
                                    <option value="通用">📘 通用</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small mb-1">知识库名称</label>
                                <input type="text" class="form-control form-control-sm" @bind="newVaultName" placeholder="例如：脾胃病、Python入门..." />
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-sm btn-primary w-100" @onclick="AddNewVault" disabled="@isLoading">
                                    @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    添加
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(vaultRootPathPreference) && !string.IsNullOrEmpty(newVaultIndustry) && !string.IsNullOrEmpty(newVaultName))
                        {
                            <small class="text-muted d-block mt-2">
                                将创建到：<code>@System.IO.Path.Combine(vaultRootPathPreference, "local", newVaultIndustry, newVaultName)</code>
                            </small>
                        }
                        else if (string.IsNullOrEmpty(vaultRootPathPreference))
                        {
                            <small class="text-warning d-block mt-2">⚠️ 请先设置知识库根路径</small>
                        }
                    </div>
                </div>

                <!-- 知识库列表 -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">📋 所有知识库 (@vaults.Count)</h5>
                        <button class="btn btn-sm btn-outline-primary" @onclick="SyncVaults" disabled="@isLoading">
                            @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            🔄 同步知识库
                        </button>
                    </div>
                    <div class="card-body p-0">
                        @if (vaults.Count == 0)
                        {
                            <div class="text-center py-4 text-muted">
                                暂无知识库，请添加一个
                            </div>
                        }
                        else
                        {
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>名称</th>
                                        <th>路径</th>
                                        <th>行业</th>
                                        <th>创建时间</th>
                                        <th>标签</th>
                                        <th>笔记</th>
                                        <th>记忆卡片</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vault in vaults)
                                    {
                                        <tr @key="vault.Id">
                                            <td>
                                                @if (editingVaultId == vault.Id)
                                                {
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" class="form-control" @bind="editingName" />
                                                        <button class="btn btn-success" @onclick="SaveEdit">✓</button>
                                                        <button class="btn btn-secondary" @onclick="CancelEdit">✕</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <strong>@vault.Name</strong>
                                                }
                                            </td>
                                            <td><code class="small">@vault.Path</code></td>
                                            <td>
                                                @if (editingIndustryVaultId == vault.Id)
                                                {
                                                    <div class="input-group input-group-sm">
                                                        <select class="form-select form-select-sm" @bind="editingIndustry">
                                                            <option value="笔记">📝 笔记</option>
                                                            <option value="计算机">💻 计算机</option>
                                                            <option value="通用">📘 通用</option>
                                                        </select>
                                                        <button class="btn btn-success" @onclick="SaveIndustryEdit">✓</button>
                                                        <button class="btn btn-secondary" @onclick="CancelIndustryEdit">✕</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary" style="cursor: pointer;" @onclick="() => StartIndustryEdit(vault)" title="点击编辑行业">
                                                        @(string.IsNullOrWhiteSpace(vault.Industry) ? "+ 设置行业" : vault.Industry)
                                                    </span>
                                                }
                                            </td>
                                            <td>@vault.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                            <td>
                                                @if (editingTagVaultId == vault.Id)
                                                {
                                                    <div class="input-group input-group-sm">
                                                        <input type="text" class="form-control" @bind="editingTags" placeholder="标签1, 标签2..." />
                                                        <button class="btn btn-success" @onclick="SaveTagEdit">✓</button>
                                                        <button class="btn btn-secondary" @onclick="CancelTagEdit">✕</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex flex-wrap gap-1 align-items-center" style="min-height: 31px; cursor: pointer;" @onclick="() => StartTagEdit(vault)" title="点击编辑标签">
                                                        @if (vault.Tags?.Any() == true)
                                                        {
                                                            @foreach (var tag in vault.Tags)
                                                            {
                                                                <span class="badge bg-info text-dark" @key="tag">@tag</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small">+ 添加标签</span>
                                                        }
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                @if (vaultNoteCounts.GetValueOrDefault(vault.Id, -1) < 0)
                                                {
                                                    <span class="spinner-border spinner-border-sm text-muted"></span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-primary">📝 @vaultNoteCounts[vault.Id] 篇</span>
                                                }
                                            </td>
                                            <td>
                                                @if (vaultCardCounts.GetValueOrDefault(vault.Id, -1) < 0)
                                                {
                                                    <span class="spinner-border spinner-border-sm text-muted"></span>
                                                }
                                                else if (vaultCardCounts.GetValueOrDefault(vault.Id, 0) == 0)
                                                {
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => GenerateCardsForVault(vault)" disabled="@isGeneratingCards">
                                                        @if (isGeneratingCards && generatingVaultId == vault.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm"></span>
                                                        }
                                                        else
                                                        {
                                                            <span>🃏 生成记忆卡片</span>
                                                        }
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">🃏 @vaultCardCounts[vault.Id] 张</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-dark" @onclick="() => OpenInObsidian(vault)" title="用 Obsidian 打开">
                                                        🔮
                                                    </button>
                                                    @if (notesMdStatus?.Available == true && !IsVaultRegisteredInNotesMd(vault.Path))
                                                    {
                                                        <button class="btn btn-outline-success" @onclick="() => AddVaultToNotesMd(vault)" disabled="@(notesMdAddingVaultId == vault.Id)" title="注册到 Obsidian (notesmd-cli)">
                                                            @if (notesMdAddingVaultId == vault.Id)
                                                            {
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            }
                                                            else
                                                            {
                                                                <span>📌</span>
                                                            }
                                                        </button>
                                                    }
                                                    else if (notesMdStatus?.Available == true && IsVaultRegisteredInNotesMd(vault.Path))
                                                    {
                                                        <button class="btn btn-outline-success" disabled title="已注册到 Obsidian">
                                                            ✓
                                                        </button>
                                                    }
                                                    <button class="btn btn-outline-secondary" @onclick="() => StartEdit(vault)" title="重命名">
                                                        重命名
                                                    </button>
                                                    <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(vault)" title="删除">
                                                        删除
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
                }
            }
            else if (activeTab == "git")
            {
                @if (isGitLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary"></div>
                        <p class="mt-2">正在加载...</p>
                    </div>
                }
                else if (activeVault == null && string.IsNullOrEmpty(vaultRootPathPreference))
                {
                    <div class="alert alert-info">
                        <h5>📋 根路径 Git</h5>
                        <p class="mb-0">此功能对<strong>知识库根路径</strong>进行 Git 版本管理。请先在"知识库路径配置"Tab 中设置知识库根路径。</p>
                    </div>
                }
                else if (gitStatus == null)
                {
                    <div class="alert alert-warning">
                        <h5>⚠️ 加载失败</h5>
                        <p class="mb-0">无法获取 Git 状态。请检查后端服务是否正常运行。</p>
                    </div>
                }
                else if (!gitStatus.IsGitRepo)
                {
                    <div class="alert alert-warning">
                        <h5>⚠️ @gitStatus.Message</h5>
                        <p class="mb-0">请在知识库目录中运行 <code>git init</code> 初始化仓库。</p>
                    </div>
                }
                else
                {
                    <!-- 状态概览 -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">📊 仓库状态</h5>
                                    <table class="table table-sm mb-0">
                                        <tr><td width="100"><strong>分支</strong></td><td><code class="bg-white px-2 rounded">@gitStatus.Branch</code></td></tr>
                                        <tr><td><strong>远程</strong></td><td>@(gitStatus.HasRemote ? "✅ 已配置" : "❌ 未配置")</td></tr>
                                        <tr><td><strong>变更</strong></td><td><span class="badge bg-@(gitStatus.Changes.Count > 0 ? "warning" : "success")">@gitStatus.Changes.Count 个文件</span></td></tr>
                                        @if (gitStatus.Ahead > 0 || gitStatus.Behind > 0)
                                        {
                                            <tr><td><strong>同步</strong></td><td>
                                                @if (gitStatus.Ahead > 0) { <span class="badge bg-primary me-1">↑ @gitStatus.Ahead 待推送</span> }
                                                @if (gitStatus.Behind > 0) { <span class="badge bg-secondary">↓ @gitStatus.Behind 待拉取</span> }
                                            </td></tr>
                                        }
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">⚡ 快捷操作</h5>
                                    <button class="btn btn-outline-primary w-100 mb-2" @onclick="DoPull" disabled="@isLoading">
                                        @if (isLoading && action == "pull") { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        ↓ 拉取远程变更
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 变更列表 -->
                    @if (gitStatus.Changes.Count > 0)
                    {
                        <div class="card mb-4">
                            <div class="card-header bg-warning bg-opacity-25">
                                <h5 class="mb-0">📝 待提交的变更 (@gitStatus.Changes.Count)</h5>
                            </div>
                            <div class="card-body" style="max-height: 250px; overflow-y: auto;">
                                <ul class="list-group list-group-flush">
                                    @foreach (var change in gitStatus.Changes)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                            <code>@change.File</code>
                                            <span class="badge @GetStatusBadgeClass(change.Status)">@change.Status</span>
                                        </li>
                                    }
                                </ul>
                            </div>
                            <div class="card-footer">
                                <div class="row g-2">
                                    <div class="col">
                                        <div class="input-group">
                                            <input type="text" class="form-control" placeholder="输入提交信息..." 
                                                   @bind="commitMessage" @bind:event="oninput" />
                                            <button class="btn btn-success" @onclick="DoCommit" 
                                                    disabled="@(isLoading || string.IsNullOrWhiteSpace(commitMessage))">
                                                @if (isLoading && action == "commit") { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                ✅ 提交
                                            </button>
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-outline-danger" @onclick="ConfirmDiscard" disabled="@isLoading">
                                            @if (isLoading && action == "discard") { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            🗑️ 撤销更改
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success mb-4">
                            ✅ @gitStatus.Message
                        </div>
                    }

                    <!-- 推送按钮 -->
                    @if (gitStatus.Ahead > 0)
                    {
                        <div class="card mb-4 border-primary">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">🚀 待推送的提交 (@gitStatus.Ahead)</h5>
                            </div>
                            <div class="card-body">
                                @if (unpushedCommits.Count > 0)
                                {
                                    <table class="table table-sm mb-3">
                                        <tbody>
                                            @foreach (var c in unpushedCommits)
                                            {
                                                <tr>
                                                    <td style="width: 70px;"><code class="small">@c.Hash.Substring(0, Math.Min(7, c.Hash.Length))</code></td>
                                                    <td>
                                                        <strong>@c.Message</strong>
                                                        <br />
                                                        <small class="text-muted">@c.Author · @c.Date</small>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                <div class="d-flex justify-content-end">
                                    <button class="btn btn-primary btn-lg" @onclick="DoPush" disabled="@isLoading">
                                        @if (isLoading && action == "push") { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        ↑ 推送到远程
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- 提交历史 -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">📜 最近提交</h5>
                        </div>
                        <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                            @if (commits.Count > 0)
                            {
                                <table class="table table-hover mb-0">
                                    <tbody>
                                        @foreach (var c in commits)
                                        {
                                            <tr>
                                                <td style="width: 80px;"><code class="small">@c.Hash.Substring(0, Math.Min(7, c.Hash.Length))</code></td>
                                                <td>
                                                    <strong>@c.Message</strong>
                                                    <br />
                                                    <small class="text-muted">@c.Author · @c.Date</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted text-center py-3 mb-0">暂无提交历史</p>
                            }
                        </div>
                    </div>
                }
            }
            else if (activeTab == "backup")
            {
                <!-- 备份恢复 Tab -->
                <div class="row">
                    <!-- 创建备份 -->
                    <div class="col-md-6">
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">💾 创建备份</h5>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small">全量备份包含：数据库、AI 配置、知识库文件、用户偏好。支持跨平台恢复。</p>

                                <div class="mb-3">
                                    <label class="form-label">备份保存目录</label>
                                    <input type="text" class="form-control form-control-sm" @bind="backupDir" placeholder="留空使用默认目录（文档/DoctorNotesBackups）" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">备份密码（可选，用于保护 API Key）</label>
                                    <input type="password" class="form-control form-control-sm" @bind="backupPassword" placeholder="不设密码则 API Key 明文存储" />
                                    <small class="text-muted">设置密码后，API Key 将用此密码加密，恢复时需输入相同密码。</small>
                                </div>

                                <button class="btn btn-primary btn-sm" @onclick="CreateBackup" disabled="@isBackupLoading">
                                    @if (isBackupLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    创建全量备份
                                </button>

                                @if (!string.IsNullOrEmpty(backupResultMessage))
                                {
                                    <div class="alert alert-@(backupResultSuccess ? "success" : "danger") mt-3 mb-0 small">
                                        @backupResultMessage
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- 恢复备份 -->
                    <div class="col-md-6">
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0">📂 恢复备份</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">备份文件路径</label>
                                    <input type="text" class="form-control form-control-sm" @bind="restoreBackupPath" placeholder="选择 .zip 备份文件" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">备份密码</label>
                                    <input type="password" class="form-control form-control-sm" @bind="restorePassword" placeholder="如果备份有密码保护则输入" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">知识库根路径覆盖（跨平台恢复时）</label>
                                    <input type="text" class="form-control form-control-sm" @bind="restoreVaultRootOverride" placeholder="留空使用当前系统根路径" />
                                    <small class="text-muted">从 Windows 恢复到 Linux 时，可在此指定新的知识库根路径。</small>
                                </div>

                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" @bind="restoreOverwrite" id="restoreOverwrite" />
                                    <label class="form-check-label" for="restoreOverwrite">覆盖现有数据</label>
                                </div>

                                @if (restoreValidation != null)
                                {
                                    <div class="alert alert-info small mb-3">
                                        <strong>备份信息：</strong><br />
                                        版本：@restoreValidation.Version<br />
                                        创建时间：@(restoreValidation.CreatedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "未知")<br />
                                        源平台：@restoreValidation.SourceOS<br />
                                        @if (restoreValidation.HasPassword)
                                        {
                                            <span class="text-warning">🔒 有密码保护</span><br />
                                        }
                                        知识库数量：@restoreValidation.VaultCount
                                    </div>
                                }

                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="ValidateBackup" disabled="@isRestoreLoading || string.IsNullOrEmpty(restoreBackupPath)">
                                        验证备份
                                    </button>
                                    <button class="btn btn-warning btn-sm" @onclick="RestoreBackup" disabled="@isRestoreLoading || string.IsNullOrEmpty(restoreBackupPath)">
                                        @if (isRestoreLoading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        恢复备份
                                    </button>
                                </div>

                                @if (!string.IsNullOrEmpty(restoreResultMessage))
                                {
                                    <div class="alert alert-@(restoreResultSuccess ? "success" : "danger") mt-3 mb-0 small">
                                        @restoreResultMessage
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 备份列表 -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📋 已有备份</h5>
                    </div>
                    <div class="card-body">
                        @if (backupList.Count == 0)
                        {
                            <p class="text-muted text-center py-3 mb-0">暂无备份文件</p>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>文件名</th>
                                        <th>大小</th>
                                        <th>创建时间</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var b in backupList)
                                    {
                                        <tr>
                                            <td><code>@b.FileName</code></td>
                                            <td>@FormatFileSize(b.Size)</td>
                                            <td>@b.CreationTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
            else if (activeTab == "trash")
            {
                <!-- 回收站 Tab -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">🗑️ 回收站 (@trashVaults.Count)</h5>
                    @if (trashVaults.Count > 0)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="ConfirmEmptyTrash" disabled="@isLoading">
                            🧹 清空回收站
                        </button>
                    }
                </div>

                @if (trashVaults.Count == 0)
                {
                    <div class="text-center py-5 text-muted">
                        <p class="mb-0">回收站为空</p>
                        <small>删除的知识库会暂存在这里</small>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>名称</th>
                                        <th>路径</th>
                                        <th>行业</th>
                                        <th>操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var vault in trashVaults)
                                    {
                                        <tr @key="vault.Id">
                                            <td><strong>@vault.Name</strong></td>
                                            <td><code class="small">@vault.Path</code></td>
                                            <td>@(string.IsNullOrWhiteSpace(vault.Industry) ? "-" : vault.Industry)</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => ConfirmRestore(vault)">
                                                    ↩️ 恢复
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- 删除确认对话框 -->
@if (showDeleteConfirm)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠️ 确认删除知识库</h5>
                </div>
                <div class="modal-body">
                    <p>确定要删除知识库 <strong>"@vaultToDelete?.Name"</strong> 吗？</p>
                    <p class="text-muted mb-0">知识库将移入回收站，可随时恢复。</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">取消</button>
                    <button type="button" class="btn btn-danger" @onclick="DoDelete">确认删除</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 恢复确认对话框 -->
@if (showRestoreConfirm)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">↩️ 确认恢复知识库</h5>
                </div>
                <div class="modal-body">
                    <p>确定要恢复知识库 <strong>"@vaultToRestore?.Name"</strong> 吗？</p>
                    <p class="text-muted mb-0">将移回原始路径：<code>@vaultToRestore?.Path</code></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelRestore">取消</button>
                    <button type="button" class="btn btn-success" @onclick="DoRestore">确认恢复</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 清空回收站确认对话框 -->
@if (showEmptyTrashConfirm)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠️ 确认清空回收站</h5>
                </div>
                <div class="modal-body">
                    <p>确定要清空回收站吗？</p>
                    <p class="text-muted mb-0"><strong>@trashVaults.Count</strong> 个知识库将被<strong>永久删除</strong>，无法恢复。</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelEmptyTrash">取消</button>
                    <button type="button" class="btn btn-danger" @onclick="DoEmptyTrash">确认清空</button>
