}

<!-- 撤销确认对话框 -->
@if (showDiscardConfirm)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠️ 确认撤销更改</h5>
                </div>
                <div class="modal-body">
                    <p class="mb-0">此操作将撤销所有未提交的工作区更改，<strong>无法恢复</strong>。</p>
                    <p class="text-muted mt-2 mb-0">包括：已修改的文件、新增的文件、删除的文件。</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDiscard">取消</button>
                    <button type="button" class="btn btn-danger" @onclick="DoDiscard">确认撤销</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    // Tab状态
    private string activeTab = "vaults";

    // Vault相关
    private List<VaultConfig> vaults = new();
    private VaultConfig? activeVault;
    private string? editingVaultId;
    private string editingName = "";
    private string? editingTagVaultId;
    private string editingTags = "";
    private string? editingIndustryVaultId;
    private string editingIndustry = "笔记";
    private bool showDeleteConfirm;
    private VaultConfig? vaultToDelete;

    // 回收站相关
    private List<VaultConfig> trashVaults = new();
    private bool showRestoreConfirm;
    private VaultConfig? vaultToRestore;
    private bool showEmptyTrashConfirm;

    // Git相关
    private GitStatusResponse? gitStatus;
    private bool isGitLoading = false;
    private List<CommitResponse> commits = new();
    private List<CommitResponse> unpushedCommits = new();
    private string commitMessage = "";
    private bool showDiscardConfirm = false;

    // 通用
    private string? message;
    private bool success;
    private bool isLoading;
    private bool isInitializing = true;  // 页面首次加载状态
    private string action = "";

    // 知识库根路径偏好
    private string vaultRootPathPreference = "";

    // 添加新知识库
    private string newVaultIndustry = "笔记";
    private string newVaultName = "";

    // 笔记数 / 记忆卡片
    private Dictionary<string, int> vaultNoteCounts = new();
    private Dictionary<string, int> vaultCardCounts = new();
    private bool isGeneratingCards = false;
    private string? generatingVaultId;

    // 备份恢复
    private bool isBackupLoading = false;
    private bool isRestoreLoading = false;
    private string backupDir = "";
    private string backupPassword = "";
    private string backupResultMessage = "";
    private bool backupResultSuccess = false;
    private string restoreBackupPath = "";
    private string restorePassword = "";
    private string restoreVaultRootOverride = "";
    private bool restoreOverwrite = true;
    private string restoreResultMessage = "";
    private bool restoreResultSuccess = false;
    private ValidateBackupResponse? restoreValidation = null;
    private List<BackupFileInfo> backupList = new();

    // 平台信息（用于路径示例）
    private PlatformInfoResponse? _platformInfo;

    // NotesMD CLI
    private NotesMdCliStatus? notesMdStatus;
    private bool isNotesMdLoading;
    private string? notesMdAddingVaultId;

    protected override void OnInitialized()
    {
        // 从URL查询参数读取tab设置
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var tabParam = query.Get("tab");
        if (!string.IsNullOrEmpty(tabParam) && (tabParam == "vaults" || tabParam == "git" || tabParam == "backup"))
        {
            activeTab = tabParam;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 异步加载数据，不阻塞初始渲染
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isInitializing = true;

            // 并行加载平台信息和当前 tab 数据
            var platformTask = LoadPlatformInfoAsync();
            var tabTask = activeTab == "vaults" ? LoadVaultsData() : LoadGitData();
            await Task.WhenAll(platformTask, tabTask);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "加载知识库数据失败");
            message = $"加载失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isInitializing = false;
        }

        // 数据加载完成后刷新UI
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPlatformInfoAsync()
    {
        try
        {
            _platformInfo = await ApiService.GetPlatformAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "加载平台信息失败");
        }
    }

    private async Task LoadVaultsData()
    {
        isLoading = true;
        try
        {
            // 并行加载知识库列表、根路径偏好、NotesMD CLI 状态
            var vaultsTask = VaultsService.GetVaultsAsync(forceRefresh: true);
            var rootPathTask = VaultsService.GetVaultRootPathPreferenceAsync();
            var notesMdTask = ApiService.GetNotesMdCliStatusAsync();

            await Task.WhenAll(vaultsTask, rootPathTask, notesMdTask);

            var response = vaultsTask.Result;
            vaults = response.Vaults;
            activeVault = vaults.FirstOrDefault();
            vaultRootPathPreference = rootPathTask.Result;
            notesMdStatus = notesMdTask.Result;

            // 并行加载各知识库的笔记数量和卡片数量
            _ = LoadVaultNoteCountsAsync();
            _ = LoadVaultCardCountsAsync();
        }
        catch (Exception ex)
        {
            message = $"加载失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsVaultRegisteredInNotesMd(string path)
    {
        if (notesMdStatus?.RegisteredPaths == null || notesMdStatus.RegisteredPaths.Count == 0)
            return false;
        var normalized = path.Trim().Replace("\\", "/").TrimEnd('/');
        return notesMdStatus.RegisteredPaths.Any(r =>
        {
            var regNormalized = r.Trim().Replace("\\", "/").TrimEnd('/');
            return string.Equals(regNormalized, normalized, StringComparison.OrdinalIgnoreCase);
        });
    }

    private async Task LoadVaultNoteCountsAsync()
    {
        if (vaults == null || vaults.Count == 0) return;
        foreach (var vault in vaults)
        {
            vaultNoteCounts[vault.Id] = -1;
        }
        try
        {
            var tasks = vaults.Select(async v =>
            {
                try
                {
                    var count = await ApiService.GetVaultNoteCountAsync(v.Id);
                    vaultNoteCounts[v.Id] = count;
                }
                catch
                {
                    vaultNoteCounts[v.Id] = 0;
                }
            });
            await Task.WhenAll(tasks);
        }
        catch { /* 非关键功能，失败不影响主流程 */ }
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadVaultCardCountsAsync()
    {
        if (vaults == null || vaults.Count == 0) return;
        foreach (var vault in vaults)
        {
            vaultCardCounts[vault.Id] = -1;
        }
        try
        {
            var tasks = vaults.Select(async v =>
            {
                try
                {
                    var count = await ApiService.GetVaultCardCountAsync(v.Id);
                    vaultCardCounts[v.Id] = count;
                }
                catch
                {
                    vaultCardCounts[v.Id] = 0;
                }
            });
            await Task.WhenAll(tasks);
        }
        catch { /* 非关键功能，失败不影响主流程 */ }
        StateHasChanged();
    }

    private string? lastCreatedTaskId = null;

    private async Task GenerateCardsForVault(VaultConfig vault)
    {
        isGeneratingCards = true;
        generatingVaultId = vault.Id;
        StateHasChanged();
        try
        {
            var result = await ApiService.GenerateAllCardsAsync(vault.Id);
            if (result != null && result.Success)
            {
                lastCreatedTaskId = result.TaskId;
                message = $"已创建卡片生成任务：{result.VaultName}，可前往任务页查看进度";
                success = true;
            }
            else
            {
                message = $"创建任务失败: {result?.Message ?? "未知错误"}";
                success = false;
            }
        }
        catch (Exception ex)
        {
            message = $"生成失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isGeneratingCards = false;
            generatingVaultId = null;
            StateHasChanged();
        }
    }

    private int GetUnregisteredVaultCount()
    {
        if (notesMdStatus?.Available != true)
            return 0;
        return vaults.Count(v => !IsVaultRegisteredInNotesMd(v.Path));
    }

    private async Task AddVaultToNotesMd(VaultConfig vault)
    {
        if (notesMdStatus?.Available != true) return;
        notesMdAddingVaultId = vault.Id;
        try
        {
            var result = await ApiService.AddVaultToNotesMdCliAsync(vault.Path);
            if (result)
            {
                notesMdStatus = await ApiService.GetNotesMdCliStatusAsync();
                message = $"知识库 \"{vault.Name}\" 已注册到 Obsidian";
                success = true;
            }
            else
            {
                message = $"注册失败，请检查 notesmd-cli 是否正常工作";
                success = false;
            }
        }
        catch (Exception ex)
        {
            message = $"注册失败: {ex.Message}";
            success = false;
        }
        finally
        {
            notesMdAddingVaultId = null;
        }
    }

    private async Task BatchAddVaultsToNotesMd()
    {
        if (notesMdStatus?.Available != true) return;
        var unregistered = vaults.Where(v => !IsVaultRegisteredInNotesMd(v.Path)).ToList();
        if (unregistered.Count == 0) return;

        isNotesMdLoading = true;
        try
        {
            var paths = unregistered.Select(v => v.Path).ToList();
            var result = await ApiService.BatchAddVaultsToNotesMdCliAsync(paths);
            if (result != null)
            {
                notesMdStatus = await ApiService.GetNotesMdCliStatusAsync();
                if (result.Success)
                {
                    message = $"成功注册 {result.SucceededCount} 个知识库到 Obsidian";
                    success = true;
                }
                else
                {
                    message = $"注册完成：成功 {result.SucceededCount} 个，失败 {result.FailedCount} 个";
                    success = result.FailedCount == 0;
                }
            }
            else
            {
                message = "批量注册失败，请检查 notesmd-cli 是否正常工作";
                success = false;
            }
        }
        catch (Exception ex)
        {
            message = $"批量注册失败: {ex.Message}";
            success = false;
        }
        finally
        {
            isNotesMdLoading = false;
        }
    }

    private async Task LoadGitData()
    {
        if (activeVault == null && string.IsNullOrEmpty(vaultRootPathPreference))
        {
            // 没有活跃知识库也没有根路径，不需要加载
            isGitLoading = false;
            return;
        }

        isGitLoading = true;
        isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("TaskRunnerApi");
            var vaultIdParam = activeVault != null
                ? $"?vaultId={Uri.EscapeDataString(activeVault.Id)}"
                : "";
            gitStatus = await client.GetFromJsonAsync<GitStatusResponse>($"api/git/status{vaultIdParam}");
            commits = await client.GetFromJsonAsync<List<CommitResponse>>($"api/git/log{vaultIdParam}") ?? new();
            unpushedCommits = await client.GetFromJsonAsync<List<CommitResponse>>($"api/git/unpushed{vaultIdParam}") ?? new();
        }
        catch (Exception ex)
        {
            message = $"加载失败: {ex.Message}";
            success = false;
            gitStatus = null; // 确保加载失败时 gitStatus 为 null，触发"加载失败"提示
        }
        finally
        {
            isLoading = false;
            isGitLoading = false;
        }
    }

    // ---- 备份恢复方法 ----

    private async Task CreateBackup()
    {
        isBackupLoading = true;
        backupResultMessage = "";
        try
        {
            var result = await BackupService.CreateFullBackupAsync(
                string.IsNullOrWhiteSpace(backupDir) ? null : backupDir.Trim(),
                string.IsNullOrWhiteSpace(backupPassword) ? null : backupPassword);

            backupResultSuccess = result.Success;
            backupResultMessage = result.Success
                ? $"备份创建成功！文件：{result.BackupPath}，大小：{FormatFileSize(result.FileSize ?? 0)}"
                : result.Message;

            // 刷新备份列表
            await LoadBackupList();
        }
        catch (Exception ex)
        {
            backupResultSuccess = false;
            backupResultMessage = $"创建备份失败：{ex.Message}";
        }
        finally
        {
            isBackupLoading = false;
        }
    }

    private async Task ValidateBackup()
    {
        isRestoreLoading = true;
        try
        {
            restoreValidation = await BackupService.ValidateBackupAsync(
                restoreBackupPath,
                string.IsNullOrWhiteSpace(restorePassword) ? null : restorePassword);
        }
        catch (Exception ex)
        {
            restoreValidation = new ValidateBackupResponse { IsValid = false, Message = ex.Message };
        }
        finally
        {
            isRestoreLoading = false;
        }
    }

    private async Task RestoreBackup()
    {
        var warnMsg = restoreOverwrite
            ? "⚠️ 将覆盖现有数据，此操作不可撤销！确定要继续恢复备份吗？"
            : "确定要从此备份恢复吗？";
        if (!await JS.InvokeAsync<bool>("confirm", warnMsg))
            return;
        isRestoreLoading = true;
        restoreResultMessage = "";
        try
        {
            var result = await BackupService.RestoreFullBackupAsync(
                restoreBackupPath,
                string.IsNullOrWhiteSpace(restorePassword) ? null : restorePassword,
                string.IsNullOrWhiteSpace(restoreVaultRootOverride) ? null : restoreVaultRootOverride.Trim(),
                restoreOverwrite);

            restoreResultSuccess = result.Success;
            if (result.Success)
            {
                restoreResultMessage = $"恢复成功！源平台：{result.SourcePlatform}，源系统：{result.SourceOS}";
                // 刷新知识库列表
                await LoadVaultsData();
            }
            else
            {
                restoreResultMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            restoreResultSuccess = false;
            restoreResultMessage = $"恢复失败：{ex.Message}";
        }
        finally
        {
            isRestoreLoading = false;
        }
    }

