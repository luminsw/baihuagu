@page "/component-performance"
@rendermode InteractiveServer
@inject ComponentPerformanceService PerformanceService
@inject IJSRuntime JSRuntime

<PageTitle>组件性能监控</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>🔍 组件性能监控</h2>
            <p class="text-muted">实时监控各 Blazor 组件渲染性能，找出慢组件</p>
        </div>
        <div class="col-auto">
            <div class="btn-group">
                <button class="btn btn-outline-primary" @onclick="RefreshData">
                    🔄 刷新
                </button>
                <button class="btn btn-outline-danger" @onclick="ClearData">
                    🗑️ 清空数据
                </button>
                <button class="btn btn-outline-secondary" @onclick="ExportData">
                    📥 导出
                </button>
            </div>
        </div>
    </div>

    <!-- 摘要卡片 -->
    @if (summary != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-2">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.TotalComponents</div>
                        <small>组件总数</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.TotalRenders</div>
                        <small>总渲染次数</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.AverageRenderTimeMs.ToString("F1")</div>
                        <small>平均耗时(ms)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card bg-warning text-dark">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.MaxRenderTimeMs.ToString("F0")</div>
                        <small>最大耗时(ms)</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card @(summary.SlowComponentCount > 0 ? "bg-danger text-white" : "bg-success text-white")">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.SlowComponentCount</div>
                        <small>慢组件数</small>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="card @(summary.SlowRenders > 0 ? "bg-danger text-white" : "bg-success text-white")">
                    <div class="card-body text-center">
                        <div class="h3 mb-0">@summary.SlowRenders</div>
                        <small>慢渲染次数</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- 阈值设置 -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">⚙️ 设置</h5>
        </div>
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <label class="form-label">慢组件阈值 (ms)</label>
                    <div class="input-group">
                        <input type="number" class="form-control" @bind="slowThreshold" min="10" max="5000" />
                        <button class="btn btn-outline-primary" @onclick="UpdateThreshold">应用</button>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="form-text mt-2">
                        超过此时间的渲染将被标记为"慢渲染"。当前阈值: <strong>@PerformanceService.SlowThresholdMs ms</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 慢组件列表 -->
    @if (slowComponents?.Any() == true)
    {
        <div class="card border-danger mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">🐌 慢组件 Top @(slowComponents.Count)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>组件名</th>
                                <th class="text-end">渲染次数</th>
                                <th class="text-end">平均耗时</th>
                                <th class="text-end">最大耗时</th>
                                <th class="text-end">慢渲染次数</th>
                                <th>最后渲染</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var comp in slowComponents)
                            {
                                <tr class="@(comp.AverageRenderTimeMs > PerformanceService.SlowThresholdMs * 2 ? "table-danger" : "table-warning")">
                                    <td><code>@comp.ComponentName</code></td>
                                    <td class="text-end">@comp.RenderCount</td>
                                    <td class="text-end font-monospace">@comp.AverageRenderTimeMs.ToString("F1") ms</td>
                                    <td class="text-end font-monospace">@comp.MaxRenderTimeMs.ToString("F1") ms</td>
                                    <td class="text-end">
                                        <span class="badge bg-danger">@comp.SlowRenderCount</span>
                                    </td>
                                    <td class="text-muted small">@comp.LastRenderTime.ToString("HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- 所有组件详情 -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">📊 所有组件详情</h5>
        </div>
        <div class="card-body p-0">
            @if (allMetrics?.Any() != true)
            {
                <div class="text-center py-5 text-muted">
                    <div class="mb-3">📭</div>
                    <p>暂无数据，请刷新页面或访问其他页面以收集性能数据</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>组件名</th>
                                <th class="text-end">渲染次数</th>
                                <th class="text-end">平均耗时</th>
                                <th class="text-end">最小耗时</th>
                                <th class="text-end">最大耗时</th>
                                <th class="text-end">总耗时</th>
                                <th class="text-end">慢渲染</th>
                                <th>最后渲染</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var comp in allMetrics)
                            {
                                <tr class="@(comp.AverageRenderTimeMs > PerformanceService.SlowThresholdMs ? "table-warning" : "")">
                                    <td><code>@comp.ComponentName</code></td>
                                    <td class="text-end">@comp.RenderCount</td>
                                    <td class="text-end font-monospace">
                                        <span class="badge @(GetBadgeClass(comp.AverageRenderTimeMs))">
                                            @comp.AverageRenderTimeMs.ToString("F1") ms
                                        </span>
                                    </td>
                                    <td class="text-end font-monospace text-muted">@comp.MinRenderTimeMs.ToString("F1") ms</td>
                                    <td class="text-end font-monospace">@comp.MaxRenderTimeMs.ToString("F1") ms</td>
                                    <td class="text-end font-monospace">@comp.TotalRenderTimeMs.ToString("F0") ms</td>
                                    <td class="text-end">
                                        @if (comp.SlowRenderCount > 0)
                                        {
                                            <span class="badge bg-danger">@comp.SlowRenderCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@comp.LastRenderTime.ToString("HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- 最近渲染事件 -->
    @if (recentEvents?.Any() == true)
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">🕐 最近渲染事件</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>时间</th>
                                <th>组件名</th>
                                <th>耗时</th>
                                <th>类型</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var evt in recentEvents.Take(50))
                            {
                                <tr class="@(evt.IsSlow ? "table-danger" : "")">
                                    <td class="small text-nowrap">@evt.Timestamp.ToString("HH:mm:ss.fff")</td>
                                    <td><code class="small">@evt.ComponentName</code></td>
                                    <td class="font-monospace">
                                        <span class="badge @(GetBadgeClass(evt.ElapsedMilliseconds))">
                                            @evt.ElapsedMilliseconds.ToString("F1") ms
                                        </span>
                                    </td>
                                    <td>
                                        @if (evt.IsFirstRender)
                                        {
                                            <span class="badge bg-info">首次渲染</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private PerformanceSummary? summary;
    private List<ComponentMetrics>? allMetrics;
    private List<ComponentMetrics>? slowComponents;
    private List<RenderEvent>? recentEvents;
    private int slowThreshold = 100;

    protected override void OnInitialized()
    {
        RefreshData();
    }

    private void RefreshData()
    {
        summary = PerformanceService.GetSummary();
        allMetrics = PerformanceService.GetAllMetrics();
        slowComponents = PerformanceService.GetSlowComponents();
        recentEvents = PerformanceService.GetRecentEvents(100);
    }

    private void ClearData()
    {
        PerformanceService.Clear();
        RefreshData();
    }

    private void UpdateThreshold()
    {
        PerformanceService.SlowThresholdMs = slowThreshold;
        RefreshData();
    }

    private string GetBadgeClass(double elapsedMs)
    {
        var threshold = PerformanceService.SlowThresholdMs;
        if (elapsedMs > threshold * 2) return "bg-danger";
        if (elapsedMs > threshold) return "bg-warning text-dark";
        if (elapsedMs > threshold / 2) return "bg-info";
        return "bg-success";
    }

    private async Task ExportData()
    {
        var csv = GenerateCsv();
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", csv);
        // 可以添加 toast 提示
    }

    private string GenerateCsv()
    {
        var lines = new List<string>
        {
            "ComponentName,RenderCount,AverageRenderTimeMs,MinRenderTimeMs,MaxRenderTimeMs,TotalRenderTimeMs,SlowRenderCount,LastRenderTime"
        };
        
        foreach (var m in allMetrics ?? new List<ComponentMetrics>())
        {
            lines.Add($"{m.ComponentName},{m.RenderCount},{m.AverageRenderTimeMs:F2},{m.MinRenderTimeMs:F2},{m.MaxRenderTimeMs:F2},{m.TotalRenderTimeMs:F2},{m.SlowRenderCount},{m.LastRenderTime:yyyy-MM-dd HH:mm:ss}");
        }
        
        return string.Join("\n", lines);
    }
}
