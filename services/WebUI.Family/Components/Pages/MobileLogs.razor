@page "/mobile-logs"
@inject HttpClient Http
@inject ILogger<MobileLogs> Logger

<PageTitle>移动端日志 - 百花谷</PageTitle>

<div class="container-fluid mx-auto p-4">
    <h1 class="text-2xl font-bold mb-4">📱 移动端日志</h1>

    @if (loading)
    {
        <div class="flex justify-center items-center h-32">
            <span class="loading loading-spinner loading-lg"></span>
        </div>
    }
    else
    {
        <!-- 统计信息 -->
        <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="stat bg-base-200 rounded-box">
                <div class="stat-title">总日志数</div>
                <div class="stat-value text-primary">@stats.Total</div>
            </div>
            <div class="stat bg-base-200 rounded-box">
                <div class="stat-title">信息</div>
                <div class="stat-value text-info">@stats.Info</div>
            </div>
            <div class="stat bg-base-200 rounded-box">
                <div class="stat-title">警告</div>
                <div class="stat-value text-warning">@stats.Warn</div>
            </div>
            <div class="stat bg-base-200 rounded-box">
                <div class="stat-title">错误</div>
                <div class="stat-value text-error">@stats.Error</div>
            </div>
        </div>

        <!-- 过滤器 -->
        <div class="flex gap-4 mb-4">
            <select class="select select-bordered" @bind="selectedDevice">
                <option value="">所有设备</option>
                @foreach (var device in devices)
                {
                    <option value="@device.DeviceId">@device.DeviceName (@device.LogCount 条日志)</option>
                }
            </select>

            <div class="btn-group btn-group-sm" role="group">
                <button type="button" class="btn @(selectedLevel == "" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => selectedLevel = "")">全部</button>
                <button type="button" class="btn @(selectedLevel == "info" ? "btn-info" : "btn-outline-info")" @onclick="@(() => selectedLevel = "info")">信息</button>
                <button type="button" class="btn @(selectedLevel == "warn" ? "btn-warning" : "btn-outline-warning")" @onclick="@(() => selectedLevel = "warn")">警告</button>
                <button type="button" class="btn @(selectedLevel == "error" ? "btn-danger" : "btn-outline-danger")" @onclick="@(() => selectedLevel = "error")">错误</button>
            </div>

            <button class="btn btn-primary" @onclick="LoadLogs">刷新</button>
            <button class="btn btn-error" @onclick="ClearLogs">清空日志</button>
        </div>

        <!-- 日志列表 -->
        @if (logs.Any())
        {
            <div class="overflow-x-auto">
                <table class="table table-zebra w-full">
                    <thead>
                        <tr>
                            <th>时间</th>
                            <th>设备</th>
                            <th>级别</th>
                            <th>上下文</th>
                            <th>消息</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            <tr class="@(log.Level == "error" ? "bg-error/10" : log.Level == "warn" ? "bg-warning/10" : "")">
                                <td class="text-sm">
                                    <div>@log.ServerTimestamp.ToString("MM-dd HH:mm:ss")</div>
                                    <div class="text-xs text-gray-500">@log.Timestamp.ToString("HH:mm:ss.fff")</div>
                                </td>
                                <td>
                                    <div class="font-medium">@log.DeviceName</div>
                                    <div class="text-xs text-gray-500">@log.DeviceId</div>
                                </td>
                                <td>
                                    <span class="badge @GetLevelBadgeClass(log.Level)">@log.Level</span>
                                </td>
                                <td>@log.Context</td>
                                <td>
                                    <div class="max-w-md truncate" title="@log.Message">@log.Message</div>
                                    @if (log.Extra != null && log.Extra.Any())
                                    {
                                        <div class="text-xs text-gray-500 mt-1">
                                            @string.Join(" | ", log.Extra.Select(kv => $"{kv.Key}: {kv.Value}"))
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 分页 -->
            <div class="flex justify-center mt-4 gap-2">
                @if (offset > 0)
                {
                    <button class="btn btn-sm" @onclick="PreviousPage">上一页</button>
                }
                <span class="btn btn-sm btn-disabled">第 @(offset / limit + 1) 页</span>
                @if (logs.Count == limit)
                {
                    <button class="btn btn-sm" @onclick="NextPage">下一页</button>
                }
            </div>
        }
        else
        {
            <div class="text-center text-gray-500 py-8">
                暂无日志记录
            </div>
        }
    }
</div>

@code {
    private List<MobileLogRecord> logs = new();
    private List<DeviceInfo> devices = new();
    private LogStats stats = new();

    private string selectedDevice = "";
    private string selectedLevel = "";
    private int offset = 0;
    private int limit = 50;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        try
        {
            await Task.WhenAll(
                LoadLogs(),
                LoadDevices(),
                LoadStats()
            );
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadLogs()
    {
        try
        {
            var url = $"/api/mobile-logs?limit={limit}&offset={offset}";
            if (!string.IsNullOrEmpty(selectedDevice))
                url += $"&deviceId={selectedDevice}";
            if (!string.IsNullOrEmpty(selectedLevel))
                url += $"&level={selectedLevel}";

            logs = await Http.GetFromJsonAsync<List<MobileLogRecord>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load logs");
        }
    }

    private async Task LoadDevices()
    {
        try
        {
            devices = await Http.GetFromJsonAsync<List<DeviceInfo>>("/api/mobile-logs/devices") ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load devices");
        }
    }

    private async Task LoadStats()
    {
        try
        {
            var url = "/api/mobile-logs/stats";
            if (!string.IsNullOrEmpty(selectedDevice))
                url += $"?deviceId={selectedDevice}";

            stats = await Http.GetFromJsonAsync<LogStats>(url) ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load stats");
        }
    }

    private async Task ClearLogs()
    {
        try
        {
            var url = "/api/mobile-logs";
            if (!string.IsNullOrEmpty(selectedDevice))
                url += $"?deviceId={selectedDevice}";

            var response = await Http.DeleteAsync(url);
            if (response.IsSuccessStatusCode)
            {
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to clear logs");
        }
    }

    private async Task PreviousPage()
    {
        offset = Math.Max(0, offset - limit);
        await LoadLogs();
    }

    private async Task NextPage()
    {
        offset += limit;
        await LoadLogs();
    }

    private string GetLevelBadgeClass(string level)
    {
        return level switch
        {
            "error" => "badge-error",
            "warn" => "badge-warning",
            "info" => "badge-info",
            _ => "badge-ghost"
        };
    }

    // 数据模型
    public class MobileLogRecord
    {
        public string Id { get; set; } = "";
        public string DeviceId { get; set; } = "";
        public string DeviceName { get; set; } = "";
        public string Level { get; set; } = "info";
        public string Message { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public string Context { get; set; } = "";
        public Dictionary<string, string>? Extra { get; set; }
        public DateTime ServerTimestamp { get; set; }
    }

    public class DeviceInfo
    {
        public string DeviceId { get; set; } = "";
        public string DeviceName { get; set; } = "";
        public int LogCount { get; set; }
        public DateTime LastLogTime { get; set; }
        public int ErrorCount { get; set; }
        public int WarnCount { get; set; }
    }

    public class LogStats
    {
        public int Total { get; set; }
        public int Info { get; set; }
        public int Warn { get; set; }
        public int Error { get; set; }
        public int Devices { get; set; }
    }
}
