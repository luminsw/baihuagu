@code {
    private bool _canShowLocalModelSettings = true;
    
    private List<AiConfigProvider> aiProviders = new();

    // 视图状态
    private bool isEditing = false;
    private bool isSaving = false;
    private bool isFetchingModels = false;
    private bool isRemovingMissingModels = false;
    private CancellationTokenSource? _fetchCts;
    private CancellationTokenSource? _removeCts;
    private string editErrorMessage = "";
    private string fetchModelsError = "";
    private EditProviderModel editingProvider = new();
    private List<MissingModelInfo> missingModels = new();

    // 预设提供商列表
    private List<AiProviderPreset> providerPresets = new();

    // 服务连接状态


    protected override void OnInitialized()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // 后台并行加载
        _ = Task.Run(async () =>
        {
            try
            {
                _canShowLocalModelSettings = await CapabilityService.CanShowAsync("SettingsLocalModelDownload");
                await Task.WhenAll(
                    LoadAiProviders(),
                    LoadLocalModelConfigAsync(),
                    LoadEmbeddingConfigAsync()
                );
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "后台加载失败");
            }
        });
    }

    private async Task LoadAiProviders()
    {
        try
        {
            aiProviders = await ApiService.GetAiConfigProvidersAsync();
            await CheckMissingLocalModelsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载 AI 提供商失败");
            aiProviders = new List<AiConfigProvider>();
        }
        finally
        {
            await InvokeAsync(() =>
            {
                StateHasChanged();
            });
        }
    }

    private async Task CheckMissingLocalModelsAsync()
    {
        missingModels.Clear();
        foreach (var provider in aiProviders)
        {
            var toolId = GetToolIdFromProviderUrl(provider.BaseUrl);
            if (toolId == null) continue;

            try
            {
                var availableModels = await ApiService.GetAvailableModelsAsync(toolId);
                var availableSet = availableModels.ToHashSet(StringComparer.OrdinalIgnoreCase);
                foreach (var model in provider.Models)
                {
                    if (!availableSet.Contains(model.Name))
                    {
                        missingModels.Add(new MissingModelInfo
                        {
                            ProviderId = provider.Id,
                            ProviderName = provider.Name,
                            ModelName = model.Name,
                            ToolId = toolId
                        });
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "检查 {ProviderName} 模型列表失败", provider.Name);
            }
        }
    }

    private static string? GetToolIdFromProviderUrl(string baseUrl)
    {
        var lower = baseUrl.ToLowerInvariant();
        if (lower.Contains("11434")) return "ollama";
        if (lower.Contains("1234")) return "lmstudio";
        return null;
    }

    private async Task RemoveMissingModelsAsync()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"确定要从配置中删除 {missingModels.Count} 个缺失的模型吗？"))
            return;
        isRemovingMissingModels = true;
        _removeCts = new CancellationTokenSource();
        try
        {
            var providerGroups = missingModels.GroupBy(m => m.ProviderId);
            foreach (var group in providerGroups)
            {
                _removeCts.Token.ThrowIfCancellationRequested();
                var provider = aiProviders.FirstOrDefault(p => p.Id == group.Key);
                if (provider == null) continue;

                var toRemove = group.Select(m => m.ModelName).ToHashSet(StringComparer.OrdinalIgnoreCase);
                var remainingModels = provider.Models
                    .Where(m => !toRemove.Contains(m.Name))
                    .Select(m => new AiModelRequest
                    {
                        Name = m.Name,
                        IsPaid = m.IsPaid,
                        IsMain = m.IsMain
                    })
                    .ToList();

                // 确保至少有一个默认模型
                if (remainingModels.Count > 0 && !remainingModels.Any(m => m.IsMain))
                {
                    remainingModels[0].IsMain = true;
                }

                var request = new SaveAiProviderRequest
                {
                    Id = provider.Id,
                    Name = provider.Name,
                    BaseUrl = provider.BaseUrl,
                    AnthropicBaseUrl = provider.AnthropicBaseUrl,
                    IsMain = provider.IsMain,
                    Models = remainingModels,
                    ApiKey = null // 保留现有密钥
                };

                var result = await ApiService.SaveAiConfigProviderAsync(request);
                if (!result.Success)
                {
                    Logger.LogWarning("删除 {ProviderName} 缺失模型失败: {Message}", provider.Name, result.Message);
                }
            }

            missingModels.Clear();
            await LoadAiProviders();
            await StatusUpdateService.NotifyAIStatusChangedAsync();
            AIStatusService.NotifyStateChanged();
        }
        catch (OperationCanceledException)
        {
            // 用户取消，不处理
        }
        finally
        {
            isRemovingMissingModels = false;
            _removeCts?.Dispose();
            _removeCts = null;
        }
    }

    private void StopRemoveMissingModels()
    {
        _removeCts?.Cancel();
    }

    private void GoToLocalModels()
    {
        Navigation.NavigateTo("local-models");
    }

    private void DismissMissingModelsWarning()
    {
        missingModels.Clear();
    }

    private async Task AddNewProvider()
    {
        // 加载预设列表
        providerPresets = await ApiService.GetAiProviderPresetsAsync();
        
        editingProvider = new EditProviderModel
        {
            Id = "",
            Name = "",
            BaseUrl = "https://api.example.com/v1",
            IsMain = aiProviders.Count == 0, // 第一个默认设为主提供商
            Tier = AiModelTier.Tier3_Cloud, // 默认云端
            Models = new List<EditModel>(),
            ApiKey = ""
        };
        isEditing = true;
        editErrorMessage = "";
    }

    private void OnPresetSelected(ChangeEventArgs e)
    {
        var presetId = e.Value?.ToString();
        if (string.IsNullOrEmpty(presetId))
        {
            // 用户选择手动输入，清空所有字段
            editingProvider.Id = "";
            editingProvider.Name = "";
            editingProvider.BaseUrl = "https://api.example.com/v1";
            editingProvider.Models = new List<EditModel>();
            return;
        }

        var preset = providerPresets.FirstOrDefault(p => p.Id == presetId);
        if (preset != null)
        {
            editingProvider.Id = preset.Id;
            editingProvider.Name = preset.Name;
            editingProvider.BaseUrl = preset.BaseUrl;
            editingProvider.Tier = preset.Tier;
            editingProvider.Models = preset.Models.Select(m => new EditModel
            {
                Name = m.Name,
                IsPaid = m.IsPaid,
                IsMain = m.IsMain
            }).ToList();
        }
    }

    private void EditProvider(AiConfigProvider provider)
    {
        editingProvider = new EditProviderModel
        {
            Id = provider.Id,
            Name = provider.Name,
            BaseUrl = provider.BaseUrl,
            AnthropicBaseUrl = provider.AnthropicBaseUrl,
            IsMain = provider.IsMain,
            Tier = provider.Tier,
            Models = provider.Models.Select(m => new EditModel
            {
                Name = m.Name,
                IsPaid = m.IsPaid,
                IsMain = m.IsMain
            }).ToList(),
            ApiKey = "", // 为了安全不填充 API Key
            ExistingKeyMask = provider.KeyMask
        };
        isEditing = true;
        editErrorMessage = "";
    }

    private async Task DeleteProvider(AiConfigProvider provider)
    {
        if (!await ConfirmDelete($"确定要删除 '{provider.Name}' 吗？"))
            return;

        if (await ApiService.DeleteAiConfigProviderAsync(provider.Id))
        {
            await LoadAiProviders();
            // 通过 SignalR 推送状态变更到所有客户端
            await StatusUpdateService.NotifyAIStatusChangedAsync();
            // 触发事件通知（用于同一页面内的组件更新）
            AIStatusService.NotifyStateChanged();
        }
        else
        {
        }
    }

    private async Task SaveProvider()
    {
        isSaving = true;
        editErrorMessage = "";

        try
        {
            // 验证
            if (string.IsNullOrWhiteSpace(editingProvider.Id))
            {
                editErrorMessage = "提供商 ID 不能为空";
                return;
            }

            if (string.IsNullOrWhiteSpace(editingProvider.Name))
            {
                editErrorMessage = "显示名称不能为空";
                return;
            }

            if (string.IsNullOrWhiteSpace(editingProvider.BaseUrl))
            {
                editErrorMessage = "API 基础地址不能为空";
                return;
            }

            var request = new SaveAiProviderRequest
            {
                Id = editingProvider.Id.Trim(),
                Name = editingProvider.Name.Trim(),
                BaseUrl = editingProvider.BaseUrl.Trim(),
                AnthropicBaseUrl = editingProvider.AnthropicBaseUrl,
                IsMain = editingProvider.IsMain,
                Models = editingProvider.Models.Select(m => new AiModelRequest
                {
                    Name = m.Name,
                    IsPaid = m.IsPaid,
                    IsMain = m.IsMain
                }).ToList(),
                ApiKey = string.IsNullOrWhiteSpace(editingProvider.ApiKey) ? null : editingProvider.ApiKey,
                Tier = editingProvider.Tier
            };

            var result = await ApiService.SaveAiConfigProviderAsync(request);
            if (result.Success)
            {
                isEditing = false;
                await LoadAiProviders();
                // 通过 SignalR 推送状态变更到所有客户端
                await StatusUpdateService.NotifyAIStatusChangedAsync();
                // 触发事件通知（用于同一页面内的组件更新）
                AIStatusService.NotifyStateChanged();
            }
            else
            {
                editErrorMessage = $"保存提供商失败: {result.Message}";
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelEdit()
    {
        isEditing = false;
        editingProvider = new EditProviderModel();
        editErrorMessage = "";
    }

    private void AddModel()
    {
        editingProvider.Models.Add(new EditModel
        {
            Name = "",
            IsPaid = false,
            IsMain = editingProvider.Models.Count == 0
        });
    }

    private void RemoveModel(EditModel model)
    {
        editingProvider.Models.Remove(model);
        // 确保至少有一个默认模型
        if (model.IsMain && editingProvider.Models.Count > 0)
        {
            editingProvider.Models[0].IsMain = true;
        }
    }

    private void SetMainModel(EditModel model)
    {
        foreach (var m in editingProvider.Models)
        {
            m.IsMain = (m == model);
        }
    }

    private static bool IsLocalProviderUrl(string baseUrl)
    {
        if (string.IsNullOrWhiteSpace(baseUrl)) return false;
        var lower = baseUrl.ToLowerInvariant();
        return lower.Contains("localhost:11434") || lower.Contains("127.0.0.1:11434") ||
               lower.Contains("localhost:1234") || lower.Contains("127.0.0.1:1234");
    }

    private class MissingModelInfo
    {
        public string ProviderId { get; set; } = "";
        public string ProviderName { get; set; } = "";
        public string ModelName { get; set; } = "";
        public string ToolId { get; set; } = "";
    }

    private async Task AutoFetchModelsAsync()
    {
        isFetchingModels = true;
        fetchModelsError = "";
        _fetchCts = new CancellationTokenSource();
        try
        {
            string? toolId = null;
            var lower = editingProvider.BaseUrl.ToLowerInvariant();
            if (lower.Contains("11434"))
                toolId = "ollama";
            else if (lower.Contains("1234"))
                toolId = "lmstudio";

            if (toolId == null)
            {
                fetchModelsError = "无法识别本地工具类型";
                return;
            }

            var models = await ApiService.GetAvailableModelsAsync(toolId, _fetchCts.Token);
            if (models.Count == 0)
            {
                fetchModelsError = "未获取到模型，请检查工具是否运行";
                return;
            }

            var existingNames = editingProvider.Models.Select(m => m.Name).ToHashSet();
            int added = 0;
            foreach (var name in models)
            {
                if (existingNames.Contains(name)) continue;
                editingProvider.Models.Add(new EditModel
                {
                    Name = name,
                    IsPaid = false,
                    IsMain = editingProvider.Models.Count == 0
                });
                existingNames.Add(name);
                added++;
            }

            if (added == 0)
            {
                fetchModelsError = $"模型列表已是最新（共 {models.Count} 个）";
            }
        }
        catch (OperationCanceledException)
        {
            fetchModelsError = "已取消获取";
        }
        catch (Exception ex)
        {
            fetchModelsError = $"获取失败: {ex.Message}";
        }
        finally
        {
            isFetchingModels = false;
            _fetchCts?.Dispose();
            _fetchCts = null;
        }
    }

    private void StopFetchModels()
    {
        _fetchCts?.Cancel();
    }

    private async Task ReloadProviders()
    {
        await LoadAiProviders();
    }

    private async Task<bool> ConfirmDelete(string message)
    {
        return await JSRuntime.InvokeAsync<bool>("confirm", message);
    }

    private class EditProviderModel
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string BaseUrl { get; set; } = "";
        public string? AnthropicBaseUrl { get; set; }
        public bool IsMain { get; set; }
        public List<EditModel> Models { get; set; } = new();
        public string ApiKey { get; set; } = "";
        public string? ExistingKeyMask { get; set; }
        public AiModelTier Tier { get; set; } = AiModelTier.Unset;
    }

    private class EditModel
    {
        public string Name { get; set; } = "";
        public bool IsPaid { get; set; }
        public bool IsMain { get; set; }
    }

    // Embedding 配置
    private EmbeddingConfigDto embeddingConfig = new();
    private bool isSavingEmbedding = false;
    private string embeddingConfigMessage = "";
    private bool embeddingConfigSuccess = false;

    private async Task LoadEmbeddingConfigAsync()
    {
        try
        {
            embeddingConfig = await ApiService.GetEmbeddingConfigAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载 Embedding 配置失败");
        }
    }

    private async Task SaveEmbeddingConfig()
    {
        isSavingEmbedding = true;
        embeddingConfigMessage = "";
        try
        {
            var request = new SaveEmbeddingConfigRequest
            {
                ProviderId = embeddingConfig.ProviderId,
                Model = embeddingConfig.Model,
                BaseUrl = embeddingConfig.BaseUrl,
                ApiKey = string.IsNullOrWhiteSpace(embeddingConfig.ApiKey) ? null : embeddingConfig.ApiKey,
                IsEnabled = embeddingConfig.IsEnabled,
                Dimensions = embeddingConfig.Dimensions
            };
            var result = await ApiService.SaveEmbeddingConfigAsync(request);
            embeddingConfigSuccess = result.Success;
            embeddingConfigMessage = result.Success ? "✅ Embedding 配置已保存" : $"❌ 保存失败: {result.Message}";
            if (result.Success)
            {
                // 重新加载以更新 KeyMask
                await LoadEmbeddingConfigAsync();
            }
        }
        catch (Exception ex)
        {
            embeddingConfigSuccess = false;
            embeddingConfigMessage = $"保存失败: {ex.Message}";
        }
        finally
        {
            isSavingEmbedding = false;
        }
    }

    // 本地模型配置
    private string localModelDownloadDir = "";
    private string platformDefaultDownloadDir = "";
    private string preferredDownloadSource = "auto";
    private bool useChinaMirror = true;
    private bool isSavingLocalConfig = false;
    private string localModelConfigMessage = "";
    private bool localModelConfigSuccess = false;

    private async Task LoadLocalModelConfigAsync()
    {
        try
        {
            var config = await ApiService.GetDownloadConfigAsync();
            if (config != null)
            {
                localModelDownloadDir = config.DownloadDirectory ?? "";
                platformDefaultDownloadDir = config.PlatformDefaultDirectory ?? "";
                preferredDownloadSource = config.PreferredSource ?? "auto";
                useChinaMirror = config.UseChinaMirror;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载本地模型配置失败");
        }
    }

    private async Task SaveLocalModelConfig()
    {
        isSavingLocalConfig = true;
        localModelConfigMessage = "";
        try
        {
            var config = new DownloadDirectoryConfigDto
            {
                DownloadDirectory = localModelDownloadDir,
                PreferredSource = preferredDownloadSource,
                UseChinaMirror = useChinaMirror
            };

            var success = await ApiService.SaveDownloadConfigAsync(config);
            localModelConfigSuccess = success;
            localModelConfigMessage = success ? "✅ 本地模型设置已保存" : "❌ 保存失败";
        }
        catch (Exception ex)
        {
            localModelConfigSuccess = false;
            localModelConfigMessage = $"保存失败: {ex.Message}";
        }
        finally
        {
            isSavingLocalConfig = false;
        }
    }
}
