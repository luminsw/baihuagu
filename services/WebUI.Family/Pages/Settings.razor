@page "/settings"
@rendermode InteractiveServer
@using TaskRunner.Contracts.LocalModels
@inject WebUI.Services.SettingsService SettingsService
@inject WebUI.Services.IApiService ApiService
@inject WebUI.Services.AIStatusService AIStatusService
@inject WebUI.Hubs.StatusUpdateService StatusUpdateService
@inject WebUI.Services.CapabilityService CapabilityService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Logging.ILogger<Settings> Logger

<PageTitle>AI配置</PageTitle>

<h1>🤖 AI配置</h1>

<div class="settings-form">
    
    @if (isEditing)
    {
        <!-- 编辑视图 -->
        <div class="ai-edit-form">
            <h4>@(string.IsNullOrEmpty(editingProvider.Id) ? "添加 AI 提供商" : "编辑 AI 提供商")</h4>
            
            @if (string.IsNullOrEmpty(editingProvider.Id))
            {
                <!-- 预设选择 - 仅新建时显示 -->
                <div class="form-group">
                    <label>选择预设提供商</label>
                    <select class="form-control" @onchange="OnPresetSelected">
                        <option value="">-- 手动输入（自定义）--</option>
                        @foreach (var preset in providerPresets)
                        {
                            <option value="@preset.Id">@preset.Name</option>
                        }
                    </select>
                    <small class="form-text">选择知名提供商可自动填充 API 地址和推荐模型</small>
                </div>
            }

            <div class="form-group">
                <label>提供商 ID</label>
                <input type="text" class="form-control" @bind="editingProvider.Id" 
                       disabled="@(!string.IsNullOrEmpty(editingProvider.Id))" 
                       placeholder="如：siliconflow, aliyun" />
                <small class="form-text">唯一标识，创建后不可修改</small>
            </div>

            <div class="form-group">
                <label>显示名称</label>
                <input type="text" class="form-control" @bind="editingProvider.Name" 
                       placeholder="如：硅基流动" />
            </div>

            <div class="form-group">
                <label>API 基础地址</label>
                <input type="text" class="form-control" @bind="editingProvider.BaseUrl" 
                       placeholder="https://api.example.com/v1" />
            </div>

            <div class="form-group">
                <label>Anthropic 协议地址（可选，用于 DeepSeek 返回为空时 fallback）</label>
                <input type="text" class="form-control" @bind="editingProvider.AnthropicBaseUrl" 
                       placeholder="https://api.anthropic.com" />
                <small class="form-text text-muted">
                    仅在当前提供商返回空响应时自动切换到 Anthropic 协议
                </small>
            </div>

            <div class="form-group">
                <label>模型层级</label>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn @(editingProvider.Tier == AiModelTier.Unset ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => editingProvider.Tier = AiModelTier.Unset)">未设置</button>
                    <button type="button" class="btn @(editingProvider.Tier == AiModelTier.Tier1_Embedding ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => editingProvider.Tier = AiModelTier.Tier1_Embedding)">固本</button>
                    <button type="button" class="btn @(editingProvider.Tier == AiModelTier.Tier2_Local ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => editingProvider.Tier = AiModelTier.Tier2_Local)">问道</button>
                    <button type="button" class="btn @(editingProvider.Tier == AiModelTier.Tier3_Cloud ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => editingProvider.Tier = AiModelTier.Tier3_Cloud)">通玄</button>
                </div>
                <small class="form-text">
                    固本 = Embedding 向量模型 / 问道 = 本地大模型 / 通玄 = 云端 API
                </small>
            </div>

            <div class="form-group">
                <label>API Key</label>
                <input type="password" class="form-control" @bind="editingProvider.ApiKey" 
                       placeholder="sk-..." />
                @if (!string.IsNullOrEmpty(editingProvider.ExistingKeyMask))
                {
                    <small class="form-text">留空保留现有密钥：@editingProvider.ExistingKeyMask</small>
                }
                
                <small class="form-text text-muted">
                    API Key 将加密后存储在本地
                </small>
            </div>

            <div class="form-group checkbox-group">
                <label class="checkbox-label">
                    <input type="checkbox" @bind="editingProvider.IsMain" />
                    <span>设为主提供商</span>
                </label>
            </div>

            <h5>模型列表</h5>
            @if (IsLocalProviderUrl(editingProvider.BaseUrl))
            {
                <div class="mb-2">
                    <button class="btn btn-outline-primary btn-sm" @onclick="AutoFetchModelsAsync" disabled="@isFetchingModels">
                        @if (isFetchingModels)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>获取中...</span>
                        }
                        else
                        {
                            <span>🔄 自动获取模型</span>
                        }
                    </button>
                    @if (isFetchingModels)
                    {
                        <button class="btn btn-outline-danger btn-sm ms-1" @onclick="StopFetchModels">取消</button>
                    }
                    @if (!string.IsNullOrEmpty(fetchModelsError))
                    {
                        <span class="text-danger ms-2 small">@fetchModelsError</span>
                    }
                </div>
            }
            <div class="models-editor">
                @foreach (var model in editingProvider.Models)
                {
                    <div class="model-edit-row">
                        <input type="text" class="form-control model-name" 
                               @bind="model.Name" placeholder="模型名称" />
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="model.IsPaid" />
                            <span>付费</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="model.IsMain" 
                                   @onclick="() => SetMainModel(model)" />
                            <span>默认</span>
                        </label>
                        <button class="btn btn-icon" @onclick="() => RemoveModel(model)">删除</button>
                    </div>
                }
                <button class="btn btn-secondary" @onclick="AddModel">+ 添加模型</button>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveProvider" disabled="@isSaving">
                    @(isSaving ? "保存中..." : "保存")
                </button>
                <button class="btn btn-secondary" @onclick="CancelEdit" disabled="@isSaving">取消</button>
            </div>

            @if (!string.IsNullOrEmpty(editErrorMessage))
            {
                <div class="alert alert-error">@editErrorMessage</div>
            }
        </div>
    }
    else
    {
        <!-- 本地模型缺失提示 -->
        @if (missingModels.Count > 0)
        {
            <div class="alert alert-warning" style="margin-bottom: 1.5rem;">
                <div style="font-weight: 600; margin-bottom: 0.5rem;">
                    ⚠️ 以下配置的模型在本地工具中未找到：
                </div>
                <div style="margin-bottom: 0.75rem;">
                    @foreach (var group in missingModels.GroupBy(m => m.ProviderName))
                    {
                        <div style="margin-bottom: 0.35rem;">
                            <strong>@group.Key</strong>：
                            <code>@string.Join("</code>, <code>", group.Select(m => m.ModelName))</code>
                        </div>
                    }
                </div>
                <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
                    <button class="btn btn-warning btn-sm" @onclick="RemoveMissingModelsAsync" disabled="@isRemovingMissingModels">
                        @if (isRemovingMissingModels)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>处理中...</span>
                        }
                        else
                        {
                            <span>🗑️ 从配置中删除缺失模型</span>
                        }
                    </button>
                    @if (isRemovingMissingModels)
                    {
                        <button class="btn btn-outline-danger btn-sm ms-1" @onclick="StopRemoveMissingModels">取消</button>
                    }
                    <button class="btn btn-primary btn-sm" @onclick="GoToLocalModels">
                        📦 前往下载模型
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="DismissMissingModelsWarning">
                        忽略
                    </button>
                </div>
            </div>
        }

        <!-- 列表视图 -->
        @if (aiProviders.Count == 0)
        {
            <div class="alert alert-warning">
                暂无 AI 提供商配置，点击"添加提供商"创建一个。
            </div>
        }
        else
        {
            <div class="ai-providers-list">
                @foreach (var provider in aiProviders)
                {
                    <div class="ai-provider-card">
                        <div class="provider-header">
                            <div class="provider-title">
                                <span class="provider-name">@provider.Name</span>
                                @if (provider.IsMain)
                                {
                                    <span class="badge badge-primary">主</span>
                                }
                                @switch (provider.Tier)
                                {
                                    case AiModelTier.Tier1_Embedding:
                                        <span class="badge" style="background:#e8d5f2;color:#6b2c91;">固本</span>
                                        break;
                                    case AiModelTier.Tier2_Local:
                                        <span class="badge" style="background:#e0f0e5;color:#3d6b45;">问道</span>
                                        break;
                                    case AiModelTier.Tier3_Cloud:
                                        <span class="badge" style="background:#e0ecf4;color:#4a2a30;">通玄</span>
                                        break;
                                }
                            </div>
                            <div class="provider-actions">
                                <button class="btn btn-icon" @onclick="() => EditProvider(provider)" title="编辑">
                                    编辑
                                </button>
                                <button class="btn btn-icon btn-danger" @onclick="() => DeleteProvider(provider)" title="删除">
                                    删除
                                </button>
                            </div>
                        </div>
                        
                        <div class="provider-info">
                            <code class="provider-id">@provider.Id</code>
                            <span class="provider-url">@provider.BaseUrl</span>
                        </div>

                        <div class="api-key-status">
                            @if (provider.HasApiKey)
                            {
                                <span class="badge badge-success" title="已加密存储">
                                    已配置：@(provider.KeyMask ?? "***")
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-warning">未配置 API Key</span>
                            }
                        </div>

                        <div class="provider-models">
                            @foreach (var model in provider.Models)
                            {
                                <div class="model-item">
                                    <span class="model-name">@(model.Name.Split('/').LastOrDefault() ?? model.Name)</span>
                                    @if (model.IsMain)
                                    {
                                        <span class="badge badge-secondary">默认</span>
                                    }
                                    @if (model.IsPaid)
                                    {
                                        <span class="badge badge-paid">付费</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-free">免费</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <div class="list-actions">
            <button class="btn btn-primary" @onclick="AddNewProvider">+ 添加AI提供商</button>
            <button class="btn btn-secondary" @onclick="ReloadProviders">刷新</button>
        </div>

        <p class="config-note">
            API Key 加密存储在本地。
        </p>
    }

    <!-- Embedding 配置（一级·固本模型） -->
    <div class="embedding-config-section" style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #e8eef2;">
        <h2>🔍 Embedding 配置（一级·固本）</h2>
        <p style="color:#666;font-size:0.9rem;margin-bottom:1rem;">
            配置 RAG 知识库检索所需的 Embedding 模型。纯 CPU 即可运行，推荐 nomic-embed-text 或 bge-small-zh-v1.5。
        </p>
        <div class="form-group">
            <label>提供商</label>
            <div class="btn-group btn-group-sm" role="group">
                <button type="button" class="btn @(embeddingConfig.ProviderId == "ollama" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => embeddingConfig.ProviderId = "ollama")">Ollama（本地）</button>
                <button type="button" class="btn @(embeddingConfig.ProviderId == "openai" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => embeddingConfig.ProviderId = "openai")">OpenAI API</button>
                <button type="button" class="btn @(embeddingConfig.ProviderId == "siliconflow" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => embeddingConfig.ProviderId = "siliconflow")">硅基流动</button>
                <button type="button" class="btn @(embeddingConfig.ProviderId == "custom" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => embeddingConfig.ProviderId = "custom")">自定义</button>
            </div>
        </div>
        <div class="form-group">
            <label>模型名称</label>
            <input type="text" class="form-control" @bind="embeddingConfig.Model" placeholder="nomic-embed-text" />
            <small class="form-text">推荐：nomic-embed-text, bge-small-zh-v1.5, text-embedding-3-small</small>
        </div>
        <div class="form-group">
            <label>API 基础地址</label>
            <input type="text" class="form-control" @bind="embeddingConfig.BaseUrl" placeholder="http://localhost:11434/v1" />
        </div>
        <div class="form-group">
            <label>API Key（本地 Ollama 可留空）</label>
            <input type="password" class="form-control" @bind="embeddingConfig.ApiKey" placeholder="sk-..." />
            @if (!string.IsNullOrEmpty(embeddingConfig.KeyMask))
            {
                <small class="form-text">已配置：@embeddingConfig.KeyMask</small>
            }
        </div>
        <div class="form-group checkbox-group">
            <label class="checkbox-label">
                <input type="checkbox" @bind="embeddingConfig.IsEnabled" />
                <span>启用 Embedding 检索</span>
            </label>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveEmbeddingConfig" disabled="@isSavingEmbedding">
                @(isSavingEmbedding ? "保存中..." : "保存 Embedding 配置")
            </button>
        </div>
        @if (!string.IsNullOrEmpty(embeddingConfigMessage))
        {
            <div class="alert @(embeddingConfigSuccess ? "alert-success" : "alert-error")" style="margin-top: 0.75rem;">
                @embeddingConfigMessage
            </div>
        }
    </div>

    @if (_canShowLocalModelSettings)
    {
    <!-- 本地模型设置 -->
    <div class="local-model-settings" style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #e8eef2;">
        <h2>🖥️ 本地模型设置</h2>
        <div class="form-group">
            <label>模型下载目录</label>
            <input type="text" class="form-control" @bind="localModelDownloadDir"
                   placeholder="留空使用平台默认值" />
            <small class="form-text">
                平台默认值: @platformDefaultDownloadDir
                @if (!string.IsNullOrEmpty(localModelDownloadDir))
                {
                    <span> | 当前: @localModelDownloadDir</span>
                }
            </small>
        </div>
        <div class="form-group">
            <label>下载源偏好</label>
            <div class="btn-group btn-group-sm flex-wrap" role="group">
                <button type="button" class="btn @(preferredDownloadSource == "auto" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "auto")">自动</button>
                <button type="button" class="btn @(preferredDownloadSource == "ollama" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "ollama")">Ollama</button>
                <button type="button" class="btn @(preferredDownloadSource == "lmstudio" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "lmstudio")">LM Studio</button>
                <button type="button" class="btn @(preferredDownloadSource == "huggingface" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "huggingface")">HuggingFace</button>
                <button type="button" class="btn @(preferredDownloadSource == "hf-mirror" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "hf-mirror")">HF 镜像</button>
                <button type="button" class="btn @(preferredDownloadSource == "modelscope" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => preferredDownloadSource = "modelscope")">魔搭</button>
            </div>
        </div>
        <div class="form-group checkbox-group">
            <label class="checkbox-label">
                <input type="checkbox" @bind="useChinaMirror" />
                <span>优先使用国内镜像加速下载</span>
            </label>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveLocalModelConfig" disabled="@isSavingLocalConfig">
                @(isSavingLocalConfig ? "保存中..." : "保存本地模型设置")
            </button>
        </div>
        @if (!string.IsNullOrEmpty(localModelConfigMessage))
        {
            <div class="alert @(localModelConfigSuccess ? "alert-success" : "alert-error")" style="margin-top: 0.75rem;">
                @localModelConfigMessage
            </div>
        }
    </div>
    }

</div>

<style>
    /* AI 提供商列表 */
    .ai-providers-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ai-provider-card {
        background: #f5f8fa;
        border: 1px solid #e8eef2;
        border-radius: 8px;
        padding: 1rem;
    }

    .provider-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .provider-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .provider-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
    }

    .provider-actions {
        display: flex;
        gap: 0.5rem;
    }

    .provider-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
    }

    .provider-id {
        color: #666;
        background: #e8eef2;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
    }

    .provider-url {
        color: #888;
    }

    .api-key-status {
        margin-bottom: 0.75rem;
    }

    .provider-models {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .model-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.5rem;
        background: white;
        border-radius: 4px;
        border: 1px solid #d8e2e8;
    }

    .model-name {
        flex: 1;
        font-family: monospace;
        font-size: 0.9rem;
        color: #555;
    }

    /* 编辑表单 */
    .ai-edit-form {
        background: #f5f8fa;
        border: 1px solid #e8eef2;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .ai-edit-form h4 {
        margin-top: 0;
        margin-bottom: 1rem;
    }

    .ai-edit-form h5 {
        margin: 1.5rem 0 0.75rem 0;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.35rem;
        font-weight: 500;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #c8d4dc;
        border-radius: 4px;
        font-size: 0.95rem;
    }

    .form-control:focus {
        outline: none;
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
    }

    .form-text {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.85rem;
        color: #5a6a72;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        cursor: pointer;
        font-weight: normal;
    }

    .models-editor {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .model-edit-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem;
        background: white;
        border: 1px solid #d8e2e8;
        border-radius: 4px;
    }

    .model-edit-row .model-name {
        flex: 1;
    }

    .form-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid #d8e2e8;
    }

    .list-actions {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    /* 按钮 */
    .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-primary {
        background: #2e8baf;
        color: white;
    }

    .btn-primary:hover:not(:disabled) {
        background: #0056b3;
    }

    .btn-secondary {
        background: #5a6a72;
        color: white;
    }

    .btn-secondary:hover:not(:disabled) {
        background: #545b62;
    }

    .btn-danger {
        background: #c94c4c;
        color: white;
    }

    .btn-danger:hover:not(:disabled) {
        background: #c82333;
    }

    .btn-icon {
        padding: 0.35rem 0.75rem;
        font-size: 0.85rem;
    }

    /* 标签 */
    .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .badge-primary {
        background: #2e8baf;
        color: white;
    }

    .badge-secondary {
        background: #5a6a72;
        color: white;
    }

    .badge-paid {
        background: #f5eee0;
        color: #6a5a3a;
        border: 1px solid #d4a574;
    }

    .badge-free {
        background: #e0f0e5;
        color: #3d6b45;
        border: 1px solid #6b9e75;
    }

    .badge-success {
        background: #6b9e75;
        color: white;
    }

    .badge-info {
        background: #5ab8c4;
        color: white;
    }

    .badge-warning {
        background: #d4a574;
        color: #1e3a4c;
    }

    /* 提示框 */
    .alert {
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 1rem;
    }

    .alert-warning {
        background: #f5eee0;
        border: 1px solid #d4a574;
        color: #6a5a3a;
    }

    .alert-error {
        background: #e0ecf4;
        border: 1px solid #c8dde8;
        color: #4a2a30;
        margin-top: 1rem;
    }

    .status-message {
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-top: 1rem;
