    private string GetGpuSummary()
    {
        if (hardwareInfo?.Gpus == null || hardwareInfo.Gpus.Count == 0)
            return "未检测到独立 GPU";
        var gpu = hardwareInfo.Gpus[0];
        var parts = new List<string> { gpu.Name };
        if (gpu.ComputeUnits.HasValue)
            parts.Add($"({gpu.ComputeUnits} {(gpu.Vendor == "NVIDIA" ? "CUDA" : gpu.Vendor == "AMD" ? "CU" : gpu.Vendor == "Intel" ? "Xe" : "核")})");
        if (gpu.EstimatedTokensPerSecond.HasValue)
            parts.Add($"~{gpu.EstimatedTokensPerSecond:F0} tok/s");
        return string.Join(" ", parts);
    }

    private string GetDiskGiB(long? bytes)
    {
        if (!bytes.HasValue || bytes.Value <= 0) return "-";
        return Math.Round(bytes.Value / (1024.0 * 1024 * 1024), 0).ToString("F0");
    }

    private string GetMachineTierClass()
    {
        var tier = GetHardwareTier();
        return tier switch
        {
            HardwareTier.CpuOnly => "tier-cpu-only",
            HardwareTier.LowEndGpu => "tier-low-end",
            HardwareTier.MidRangeGpu => "tier-mid-range",
            HardwareTier.HighEndGpu => "tier-high-end",
            HardwareTier.TopTierGpu => "tier-top-tier",
            _ => "tier-unknown"
        };
    }

    private string GetMachineTierLabel()
    {
        var tier = GetHardwareTier();
        return tier switch
        {
            HardwareTier.CpuOnly => "CPU 推理",
            HardwareTier.LowEndGpu => "入门 GPU",
            HardwareTier.MidRangeGpu => "中端 GPU",
            HardwareTier.HighEndGpu => "高端 GPU",
            HardwareTier.TopTierGpu => "顶级 GPU",
            _ => "未知"
        };
    }

    private HardwareTier GetHardwareTier()
    {
        if (hardwareInfo?.Gpus == null || hardwareInfo.Gpus.Count == 0)
            return HardwareTier.CpuOnly;

        // 优先看是否有独立显卡
        var dedicatedGpu = hardwareInfo.Gpus.FirstOrDefault(g => !g.IsIntegrated && !g.IsAppleSilicon);
        if (dedicatedGpu != null && dedicatedGpu.VramGiB.HasValue)
        {
            var vram = dedicatedGpu.VramGiB.Value;
            if (vram >= 16) return HardwareTier.TopTierGpu;
            if (vram >= 8) return HardwareTier.HighEndGpu;
            if (vram >= 4) return HardwareTier.MidRangeGpu;
            return HardwareTier.LowEndGpu;
        }

        // Apple Silicon
        var appleGpu = hardwareInfo.Gpus.FirstOrDefault(g => g.IsAppleSilicon);
        if (appleGpu != null && appleGpu.VramGiB.HasValue)
        {
            var vram = appleGpu.VramGiB.Value;
            if (vram >= 16) return HardwareTier.TopTierGpu;
            if (vram >= 8) return HardwareTier.HighEndGpu;
            if (vram >= 4) return HardwareTier.MidRangeGpu;
            return HardwareTier.LowEndGpu;
        }

        // 集成显卡
        var igpu = hardwareInfo.Gpus.FirstOrDefault(g => g.IsIntegrated);
        if (igpu != null)
        {
            if (hardwareInfo.Memory.TotalGiB >= 16) return HardwareTier.LowEndGpu;
            return HardwareTier.CpuOnly;
        }

        // 无任何 GPU 信息，按内存判断
        if (hardwareInfo.Memory.TotalGiB >= 32) return HardwareTier.LowEndGpu;
        return HardwareTier.CpuOnly;
    }

    private string GetSpeedClass(double? speed)
    {
        if (!speed.HasValue) return "";
        return speed.Value switch
        {
            >= 100 => "speed-excellent",
            >= 50 => "speed-good",
            >= 20 => "speed-mid",
            >= 5 => "speed-low",
            _ => "speed-poor",
        };
    }

    private void GenerateRecommendations()
    {
        recommendations = new List<RecommendationItem>();
        var tier = GetHardwareTier();
        var totalMem = hardwareInfo?.Memory.TotalGiB ?? 0;
        var currentSpeed = hardwareInfo?.Gpus?.FirstOrDefault()?.EstimatedTokensPerSecond
            ?? hardwareInfo?.EstimatedCpuTokensPerSecond ?? 0;

        // 本地模型推理
        if (tier == HardwareTier.CpuOnly)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🧠", Title = "本地模型推理",
                Description = $"CPU 推理约 {currentSpeed:F0} tok/s，仅支持 1B-3B 小模型。建议优先使用云端 API。",
                LevelClass = "level-bad", LevelText = "受限"
            });
        }
        else if (tier == HardwareTier.LowEndGpu)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🧠", Title = "本地模型推理",
                Description = $"估算约 {currentSpeed:F0} tok/s，可运行 7B Q4 量化模型。",
                LevelClass = "level-ok", LevelText = "可用"
            });
        }
        else if (tier == HardwareTier.MidRangeGpu)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🧠", Title = "本地模型推理",
                Description = $"估算约 {currentSpeed:F0} tok/s，流畅运行 7B-13B 模型，可尝试 70B Q4。",
                LevelClass = "level-good", LevelText = "良好"
            });
        }
        else if (tier == HardwareTier.HighEndGpu)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🧠", Title = "本地模型推理",
                Description = $"估算约 {currentSpeed:F0} tok/s，可本地运行 70B 模型，适合重度 AI 开发。",
                LevelClass = "level-good", LevelText = "优秀"
            });
        }
        else
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🧠", Title = "本地模型推理",
                Description = $"估算约 {currentSpeed:F0} tok/s，顶级性能，可运行大模型或多模型并行。",
                LevelClass = "level-excellent", LevelText = "顶级"
            });
        }

        // 多模态/图像生成
        if (tier == HardwareTier.CpuOnly)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🎨", Title = "图像生成 / 多模态",
                Description = "不支持 Stable Diffusion 等图像生成模型。",
                LevelClass = "level-bad", LevelText = "不支持"
            });
        }
        else if (tier <= HardwareTier.LowEndGpu)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🎨", Title = "图像生成 / 多模态",
                Description = "可尝试 SD 1.5 / SDXL 低分辨率生成，显存可能成为瓶颈。",
                LevelClass = "level-ok", LevelText = "受限"
            });
        }
        else
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "🎨", Title = "图像生成 / 多模态",
                Description = "可运行 SDXL、FLUX 等主流图像生成模型。",
                LevelClass = tier >= HardwareTier.HighEndGpu ? "level-good" : "level-ok",
                LevelText = tier >= HardwareTier.HighEndGpu ? "良好" : "可用"
            });
        }

        // 知识库构建
        if (totalMem < 8)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "📚", Title = "知识库嵌入构建",
                Description = "内存较低，大量文档处理时可能出现内存不足。",
                LevelClass = "level-ok", LevelText = "受限"
            });
        }
        else if (totalMem < 16)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "📚", Title = "知识库嵌入构建",
                Description = "内存充足，可流畅处理中等规模知识库构建。",
                LevelClass = "level-good", LevelText = "良好"
            });
        }
        else
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "📚", Title = "知识库嵌入构建",
                Description = "大内存优势明显，可高效处理大规模知识库构建。",
                LevelClass = "level-excellent", LevelText = "优秀"
            });
        }

        // RAG / 长上下文
        if (tier == HardwareTier.CpuOnly || totalMem < 16)
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "💬", Title = "RAG 长上下文对话",
                Description = "建议优先使用云端 API，本地模型上下文窗口和速度可能受限。",
                LevelClass = tier == HardwareTier.CpuOnly ? "level-bad" : "level-ok",
                LevelText = tier == HardwareTier.CpuOnly ? "受限" : "可用"
            });
        }
        else
        {
            recommendations.Add(new RecommendationItem
            {
                Icon = "💬", Title = "RAG 长上下文对话",
                Description = "可本地运行支持长上下文的模型，实现私有化 RAG。",
                LevelClass = tier >= HardwareTier.HighEndGpu ? "level-good" : "level-ok",
                LevelText = tier >= HardwareTier.HighEndGpu ? "优秀" : "良好"
            });
        }
    }

    public void Dispose()
    {
    }

    private class PlatformComparisonItem
    {
        public bool IsCurrentMachine { get; set; }
        public int Rank { get; set; }
        public string Vendor { get; set; } = "";
        public string VendorEmoji { get; set; } = "";
        public string BadgeClass { get; set; } = "";
        public string ModelName { get; set; } = "";
        public string GpuInfo { get; set; } = "";
        public string MemoryInfo { get; set; } = "";
        public string TflopsInt8Info { get; set; } = "";
        public string TflopsInt4Info { get; set; } = "";
        public string BandwidthInfo { get; set; } = "";
        public string SpeedInfo { get; set; } = "";
        public double EstimatedTokensPerSecond { get; set; }
        public string PowerInfo { get; set; } = "";
        public string PriceInfo { get; set; } = "";
    }

    private class RecommendationItem
    {
        public string Icon { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string LevelClass { get; set; } = "";
        public string LevelText { get; set; } = "";
    }
}

