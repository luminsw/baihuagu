@page "/hardware-benchmark"
@rendermode InteractiveServer
@using TaskRunner.Contracts.LocalModels
@inject WebUI.Services.IApiService ApiService
@inject Microsoft.Extensions.Logging.ILogger<HardwareBenchmark> Logger
@implements IDisposable

<PageTitle>硬件评测</PageTitle>

<h1>🖥️ 硬件评测</h1>

<p class="text-muted">
    评估当前机器的 AI 算力水平，与主流 AI 计算平台进行对比，帮助您了解硬件性能定位。
</p>

@if (isLoading)
{
    <div class="loading-spinner">正在检测硬件信息...</div>
}
else
{
    <!-- 当前机器概览 -->
    <div class="section current-machine">
        <h2>📋 本机配置</h2>
        <div class="machine-cards">
            <div class="machine-card @(GetMachineTierClass())">
                <div class="card-header">
                    <span class="platform-icon">💻</span>
                    <span class="platform-name">当前机器</span>
                    <span class="tier-badge">@GetMachineTierLabel()</span>
                </div>
                <div class="spec-grid">
                    <div class="spec-item">
                        <span class="spec-label">CPU</span>
                        <span class="spec-value">@(hardwareInfo?.Cpu.Name ?? "未知")</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">核心数</span>
                        <span class="spec-value">@(hardwareInfo?.Cpu.LogicalProcessorCount ?? 0) 核</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">内存</span>
                        <span class="spec-value">@(hardwareInfo?.Memory.TotalGiB.ToString("F1") ?? "-") GB</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">显卡</span>
                        <span class="spec-value">@(GetGpuSummary())</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">系统</span>
                        <span class="spec-value">@(hardwareInfo?.OsPlatform ?? "-") @(hardwareInfo?.IsWsl == true ? "(WSL)" : "")</span>
                    </div>
                    <div class="spec-item">
                        <span class="spec-label">磁盘可用</span>
                        <span class="spec-value">@GetDiskGiB(hardwareInfo?.AvailableDiskSpaceBytes) GB</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AI 算力对比表 -->
    <div class="section comparison-section">
        <h2>⚡ AI 算力对比表</h2>
        <p class="section-desc">按 Llama-3-8B Q4 估算推理速度排序。数据为理论/实测参考值，供性能定位参考。</p>

        <div class="table-wrapper">
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th class="col-rank">排名</th>
                        <th class="col-platform">平台</th>
                        <th class="col-gpu">GPU / NPU / 加速器</th>
                        <th class="col-memory">显存 / 统一内存</th>
                        <th class="col-tops">INT8 算力</th>
                        <th class="col-tops">INT4 算力</th>
                        <th class="col-bandwidth">显存带宽</th>
                        <th class="col-speed">Llama3-8B Q4 估速</th>
                        <th class="col-power">典型功耗</th>
                        <th class="col-price">参考价格</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in sortedPlatforms)
                    {
                        <tr class="@(item.IsCurrentMachine ? "current-row" : "")">
                            <td class="col-rank">
                                @if (item.Rank == 1)
                                {
                                    <span>🥇</span>
                                }
                                else if (item.Rank == 2)
                                {
                                    <span>🥈</span>
                                }
                                else if (item.Rank == 3)
                                {
                                    <span>🥉</span>
                                }
                                else
                                {
                                    <span>@item.Rank</span>
                                }
                            </td>
                            <td class="col-platform">
                                <div class="platform-cell">
                                    <span class="platform-badge @item.BadgeClass">@item.VendorEmoji @item.Vendor</span>
                                    <span class="platform-model">@item.ModelName</span>
                                </div>
                            </td>
                            <td class="col-gpu">@((MarkupString)item.GpuInfo)</td>
                            <td class="col-memory">@((MarkupString)item.MemoryInfo)</td>
                            <td class="col-tops">
                                @if (!string.IsNullOrEmpty(item.TflopsInt8Info))
                                {
                                    <span class="tops-value">@item.TflopsInt8Info</span>
                                }
                                else
                                {
                                    <span class="sub-text">-</span>
                                }
                            </td>
                            <td class="col-tops">
                                @if (!string.IsNullOrEmpty(item.TflopsInt4Info))
                                {
                                    <span class="tops-value">@item.TflopsInt4Info</span>
                                }
                                else
                                {
                                    <span class="sub-text">-</span>
                                }
                            </td>
                            <td class="col-bandwidth">@item.BandwidthInfo</td>
                            <td class="col-speed">
                                <span class="speed-value @(GetSpeedClass(item.EstimatedTokensPerSecond))">@item.SpeedInfo</span>
                            </td>
                            <td class="col-power">@item.PowerInfo</td>
                            <td class="col-price">@item.PriceInfo</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="data-source-note">
            <h5>📋 数据来源与估算说明</h5>
            <ul>
                <li><strong>GPU 规格</strong>：NVIDIA / AMD / Intel / Apple 官方产品页及 CES 发布会公开资料</li>
                <li><strong>带宽数据</strong>：显存带宽 = 位宽 × 等效频率 ÷ 8；集显/统一内存带宽来自官方 SoC 规格</li>
                <li><strong>推理速度估算</strong>：基于 <code>tokens/s ≈ 内存带宽 × 利用率系数</code>，其中
                    NVIDIA/AMD/Intel 独显取 <strong>0.13</strong>、Apple Silicon 取 <strong>0.16</strong>、集显取 <strong>0.08</strong>
                </li>
                <li><strong>基准模型</strong>：Llama-3-8B Q4_K_M（约 4.8GB），自回归 decode 阶段通常为 memory-bound</li>
                <li><strong>局限性</strong>：实际速度受量化格式、上下文长度、batch 大小、软件优化等影响，估算值仅供参考</li>
            </ul>
        </div>
    </div>

    <!-- 性能等级说明 -->
    <div class="section tier-explanation">
        <h2>📊 性能等级说明</h2>
        <div class="tier-cards">
            <div class="tier-card tier-cpu">
                <div class="tier-title">🐢 CPU 推理</div>
                <div class="tier-range">无独立 GPU 或显存 &lt; 4GB</div>
                <div class="tier-desc">适合运行 1B-3B 小模型，速度较慢（1-10 tok/s），可作为 fallback 方案。</div>
            </div>
            <div class="tier-card tier-entry">
                <div class="tier-title">🐇 入门 GPU</div>
                <div class="tier-range">显存 4-8GB (GTX 1660, RTX 3050 等)</div>
                <div class="tier-desc">可运行 7B Q4 量化模型，速度约 15-40 tok/s，适合个人日常使用。</div>
            </div>
            <div class="tier-card tier-mid">
                <div class="tier-title">🦌 中端 GPU</div>
                <div class="tier-range">显存 8-16GB (RTX 4060/4070, Arc A770 等)</div>
                <div class="tier-desc">流畅运行 7B-13B 模型，可尝试 70B Q4，速度 40-100 tok/s。</div>
            </div>
            <div class="tier-card tier-high">
                <div class="tier-title">🐆 高端 GPU</div>
                <div class="tier-range">显存 16-24GB (RTX 4080/4090/5070, Arc Pro 等)</div>
                <div class="tier-desc">本地运行 70B 模型无障碍，可运行多模型并行，速度 80-180 tok/s。</div>
            </div>
            <div class="tier-card tier-pro">
                <div class="tier-title">🚀 专业/工作站</div>
                <div class="tier-range">显存 48GB+ 或 大统一内存 (DGX, M3 Ultra, AI Max+)</div>
                <div class="tier-desc">可本地运行 405B 级别大模型，或同时加载多个 70B 模型，企业级生产力。</div>
            </div>
        </div>
    </div>

    <!-- 适用场景建议 -->
    <div class="section scenario-section">
        <h2>🎯 本机适用场景建议</h2>
        @if (recommendations.Count == 0)
        {
            <div class="alert alert-info">正在分析硬件配置...</div>
        }
        else
        {
            <div class="recommendation-list">
                @foreach (var rec in recommendations)
                {
                    <div class="recommendation-item @rec.LevelClass">
                        <div class="rec-icon">@rec.Icon</div>
                        <div class="rec-content">
                            <div class="rec-title">@rec.Title</div>
                            <div class="rec-desc">@rec.Description</div>
                        </div>
                        <div class="rec-badge @rec.LevelClass">@rec.LevelText</div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="section refresh-section">
        <button class="btn btn-secondary" @onclick="RefreshHardware" disabled="@isLoading">
            @(isLoading ? "🔄 刷新中..." : "🔄 刷新硬件信息")
        </button>
        <span class="text-muted" style="margin-left: 1rem; font-size: 0.85rem;">
            数据仅供参考，实际性能受驱动、散热、模型优化等因素影响。
        </span>
    </div>
}

@code {
    private bool isLoading = true;
    private HardwareInfoDto? hardwareInfo;
    private List<RecommendationItem> recommendations = new();
    private List<PlatformComparisonItem> sortedPlatforms = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadHardwareInfoAsync();
    }

    private async Task LoadHardwareInfoAsync()
    {
        isLoading = true;
        try
        {
            hardwareInfo = await ApiService.GetHardwareInfoAsync();
            BuildSortedPlatforms();
            GenerateRecommendations();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "获取硬件信息失败");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshHardware()
    {
        await LoadHardwareInfoAsync();
    }

    /// <summary>
    /// 构建本机 + 参考平台的合并列表，按估算速度排序
    /// </summary>
    private void BuildSortedPlatforms()
    {
        var platforms = new List<PlatformComparisonItem>();

        // ---- 本机 ----
        var currentGpu = hardwareInfo?.Gpus?.FirstOrDefault();
        double currentSpeed = 0;
        if (currentGpu?.EstimatedTokensPerSecond.HasValue == true)
            currentSpeed = currentGpu.EstimatedTokensPerSecond.Value;
        else if (hardwareInfo?.EstimatedCpuTokensPerSecond.HasValue == true)
            currentSpeed = hardwareInfo.EstimatedCpuTokensPerSecond.Value;

        var currentComputeUnits = currentGpu?.ComputeUnits.HasValue == true
            ? $"{currentGpu.ComputeUnits} {(currentGpu.Vendor == "NVIDIA" ? "CUDA" : currentGpu.Vendor == "AMD" ? "CU" : currentGpu.Vendor == "Intel" ? "Xe" : "核")}"
            : (currentGpu != null ? "未知" : "-");

        platforms.Add(new PlatformComparisonItem
        {
            IsCurrentMachine = true,
            Vendor = "本机",
            VendorEmoji = "💻",
            BadgeClass = "current",
            ModelName = "当前机器",
            GpuInfo = currentGpu != null
                ? $"{currentGpu.Name}<br><span class=\"sub-text\">{currentComputeUnits}</span>"
                : "无独立 GPU<br><span class=\"sub-text\">使用 CPU 推理</span>",
            MemoryInfo = currentGpu?.VramGiB.HasValue == true
                ? $"{currentGpu.VramGiB:F0} GB<br><span class=\"sub-text\">{(currentGpu.IsIntegrated ? "共享内存" : "专用显存")}</span>"
                : $"{hardwareInfo?.Memory.TotalGiB:F0} GB<br><span class=\"sub-text\">系统内存</span>",
            TflopsInt8Info = currentGpu?.EstimatedTflopsInt8.HasValue == true
                ? $"~{currentGpu.EstimatedTflopsInt8:F0} TFLOPS"
                : (currentGpu != null ? "未知" : "< 2"),
            TflopsInt4Info = currentGpu?.EstimatedTflopsInt4.HasValue == true
                ? $"~{currentGpu.EstimatedTflopsInt4:F0} TFLOPS"
                : (currentGpu != null ? "未知" : "< 4"),
            BandwidthInfo = currentGpu?.MemoryBandwidthGBps.HasValue == true
                ? $"~{currentGpu.MemoryBandwidthGBps:F0} GB/s"
                : (hardwareInfo?.EstimatedCpuTokensPerSecond.HasValue == true ? "~50 GB/s (DDR)" : "未知"),
            SpeedInfo = currentSpeed > 0 ? $"~{currentSpeed:F0} tok/s" : "未知",
            EstimatedTokensPerSecond = currentSpeed,
            PowerInfo = "-",
            PriceInfo = "-",
        });

        // ---- 参考平台 ----
        platforms.AddRange(GetReferencePlatforms());

        // 按速度降序排序并分配排名
        sortedPlatforms = platforms
            .OrderByDescending(p => p.EstimatedTokensPerSecond)
            .Select((p, idx) => { p.Rank = idx + 1; return p; })
            .ToList();
    }

