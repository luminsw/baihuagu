@page "/model-benchmark"
@rendermode InteractiveServer
@using TaskRunner.Contracts.Benchmark
@using TaskRunner.Contracts.LocalModels
@inject WebUI.Services.IApiService ApiService
@inject WebUI.Services.SettingsService SettingsService
@implements IDisposable

<PageTitle>模型 benchmark</PageTitle>

<h1>📊 模型 benchmark</h1>

<p class="text-muted">对笔记大模型与编程模型进行标准化测试，比较质量与速度。</p>

<!-- 分类切换 -->
<div class="benchmark-tabs">
    <button class="tab-btn @(activeCategory == "tcm" ? "active" : "")" @onclick='@(() => SwitchCategory("tcm"))'>
        📝 笔记大模型
    </button>
    <button class="tab-btn @(activeCategory == "coding" ? "active" : "")" @onclick='@(() => SwitchCategory("coding"))'>
        💻 编程大模型
    </button>
</div>

@if (isLoading)
{
    <div class="loading-spinner">加载中...</div>
}
else
{
    <!-- 测试配置 -->

    <div class="section test-config">
        <h3>测试配置</h3>
        <div class="config-row">
            <div class="form-group">
                <label>选择 Provider</label>
                <select class="form-control" @bind="selectedProviderId" @bind:after="LoadModelsAsync">
                    <option value="">-- 请选择 --</option>
                    @foreach (var p in aiProviders)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>选择模型</label>
                <select class="form-control" @bind="selectedModelId">
                    <option value="">-- 请选择 --</option>
                    @foreach (var m in availableModels)
                    {
                        <option value="@m">@m</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>&nbsp;</label>
                @if (isRunning)
                {
                    <button class="btn btn-danger" @onclick="StopBenchmarkAsync">
                        <span>⏹ 停止测试</span>
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="StartBenchmarkAsync" disabled="@(!CanStart)">
                        <span>▶️ 开始测试</span>
                    </button>
                }
            </div>
        </div>
        @if (!string.IsNullOrEmpty(runError))
        {
            <div class="alert alert-danger mt-2">@runError</div>
        }
    </div>

    <!-- 测试进度 -->
    @if (isRunning || status?.Status == "running")
    {
        <div class="section progress-section">
            <h3>测试进度</h3>
            <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width: @ProgressPercent%"></div>
            </div>
            <div class="progress-text">
                @status?.CompletedCount / @status?.TotalCount
                @if (!string.IsNullOrEmpty(status?.CurrentPromptTitle))
                {
                    <span> — 正在测：@status.CurrentPromptTitle</span>
                }
            </div>
        </div>
    }

    <!-- 最新结果 -->
    @if (latestResult != null)
    {
        <div class="section">
            <h3>最新结果：@latestResult.ModelName</h3>
            <div class="result-summary">
                <div class="summary-card">
                    <div class="summary-value">@latestResult.TotalScore</div>
                    <div class="summary-label">质量均分</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">@latestResult.AvgTokensPerSecond.ToString("F1")</div>
                    <div class="summary-label">平均 tok/s</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">@latestResult.AvgLatencyMs.ToString("F0")</div>
                    <div class="summary-label">平均延迟 ms</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">@(latestResult.CompletionRate.ToString("P0"))</div>
                    <div class="summary-label">完成率</div>
                </div>
            </div>
            <table class="table result-table">
                <thead>
                    <tr>
                        <th>题目</th>
                        <th>质量分</th>
                        <th>tok/s</th>
                        <th>耗时 ms</th>
                        <th>匹配关键词</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in latestResult.Results)
                    {
                        <tr>
                            <td>@r.PromptTitle</td>
                            <td>
                                @if (r.IsTimeout)
                                {
                                    <span class="score-badge" style="background:#fef3c7;color:#92400e;">超时</span>
                                }
                                else if (r.IsError)
                                {
                                    <span class="score-badge bad">失败</span>
                                }
                                else
                                {
                                    <span class="score-badge @(r.QualityScore >= 80 ? "good" : r.QualityScore >= 50 ? "medium" : "bad")">
                                        @r.QualityScore
                                    </span>
                                }
                            </td>
                            <td>@(r.IsTimeout || r.IsError ? "-" : r.TokensPerSecond.ToString("F1"))</td>
                            <td>@(r.IsTimeout ? "⏱ 超时" : r.IsError ? "失败" : r.LatencyMs.ToString())</td>
                            <td>
                                @if (r.MatchedKeywords.Length > 0)
                                {
                                    <span class="kw-match">✓ @string.Join(", ", r.MatchedKeywords)</span>
                                }
                                @if (r.MissingKeywords.Length > 0)
                                {
                                    <span class="kw-miss">✗ @string.Join(", ", r.MissingKeywords)</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- 排行榜 -->
    <div class="section">
        <h3>🏆 排行榜</h3>
        @if (leaderboard.Count == 0)
        {
            <div class="alert alert-info">暂无数据，请先运行测试。</div>
        }
        else
        {
            <table class="table leaderboard-table">
                <thead>
                    <tr>
                        <th>排名</th>
                        <th>模型</th>
                        <th>质量均分</th>
                        <th>tok/s</th>
                        <th>测试次数</th>
                        <th>最近测试</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < leaderboard.Count; i++)
                    {
                        var entry = leaderboard[i];
                        <tr>
                            <td>
                                @if (i == 0)
                                {
                                    <span>🥇</span>
                                }
                                else if (i == 1)
                                {
                                    <span>🥈</span>
                                }
                                else if (i == 2)
                                {
                                    <span>🥉</span>
                                }
                                else
                                {
                                    <span>@(i + 1)</span>
                                }
                            </td>
                            <td>@entry.ModelName</td>
                            <td>
                                <span class="score-badge @(entry.AvgQualityScore >= 80 ? "good" : entry.AvgQualityScore >= 50 ? "medium" : "bad")">
                                    @entry.AvgQualityScore.ToString("F0")
                                </span>
                            </td>
                            <td>@entry.AvgTokensPerSecond.ToString("F1")</td>
                            <td>@entry.TestCount</td>
                            <td>@(entry.LastTestedAt?.ToString("MM-dd HH:mm") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- 历史记录 -->
    <div class="section">
        <div class="section-header">
            <h3>📝 历史记录</h3>
            @if (history.Count > 0)
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="ClearHistoryAsync">清空</button>
            }
        </div>
        @if (history.Count == 0)
        {
            <div class="alert alert-info">暂无历史记录。</div>
        }
        else
        {
            <table class="table history-table">
                <thead>
                    <tr>
                        <th>时间</th>
                        <th>模型</th>
                        <th>质量均分</th>
                        <th>tok/s</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in history)
                    {
                        <tr>
                            <td>@h.TestedAt.ToString("MM-dd HH:mm")</td>
                            <td>@h.ModelName</td>
                            <td>
                                <span class="score-badge @(h.TotalScore >= 80 ? "good" : h.TotalScore >= 50 ? "medium" : "bad")">
                                    @h.TotalScore
                                </span>
                            </td>
                            <td>@h.AvgTokensPerSecond.ToString("F1")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ViewDetail(h)">详情</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSessionAsync(h.Id)">删除</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- 提示词预览 -->
    <div class="section">
        <h3>📋 测试题目预览</h3>
        <div class="prompt-list">
            @foreach (var p in prompts)
            {
                <details class="prompt-item">
                    <summary>@p.Title</summary>
                    <div class="prompt-text">@p.Prompt</div>
                    <div class="prompt-kws">
                        <strong>预期关键词：</strong>@string.Join("、", p.ExpectedKeywords)
                    </div>
                </details>
            }
        </div>
    </div>
}

@code {
    private string activeCategory = "tcm";
    private bool isLoading = true;
    private bool isRunning = false;
    private string? runError;

    private List<RecommendedBenchmarkModel> recommendedModels = new();
    private List<BenchmarkPrompt> prompts = new();
    private List<AiProviderInfo> aiProviders = new();
    private List<string> availableModels = new();

    private string selectedProviderId = "";
    private string selectedModelId = "";

    private BenchmarkStatusDto? status;
    private BenchmarkSession? latestResult;
    private List<BenchmarkLeaderboardEntry> leaderboard = new();
    private List<BenchmarkSession> history = new();

    private System.Timers.Timer? _pollTimer;

    private bool CanStart => !isRunning && !string.IsNullOrEmpty(selectedProviderId) && !string.IsNullOrEmpty(selectedModelId);
    private double ProgressPercent => status?.TotalCount > 0 ? (double)status.CompletedCount / status.TotalCount * 100 : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        isLoading = false;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _pollTimer = new System.Timers.Timer(2000);
            _pollTimer.Elapsed += async (_, _) => await PollStatusAsync();
            _pollTimer.AutoReset = true;
            _pollTimer.Start();
        }
    }

    private async Task LoadDataAsync()
    {
        recommendedModels = await ApiService.GetBenchmarkModelsAsync(activeCategory);
        prompts = await ApiService.GetBenchmarkPromptsAsync(activeCategory);
        aiProviders = await ApiService.GetAiProvidersAsync();
        leaderboard = await ApiService.GetBenchmarkLeaderboardAsync(activeCategory);
        history = await ApiService.GetBenchmarkHistoryAsync(activeCategory);

        // 自动选中 Ollama provider（如果存在）
        var ollama = aiProviders.FirstOrDefault(p => p.Id.Equals("ollama", StringComparison.OrdinalIgnoreCase));
        if (ollama != null)
        {
            selectedProviderId = ollama.Id;
            await LoadModelsAsync();
        }
    }

    private async Task SwitchCategory(string category)
    {
        activeCategory = category;
        isLoading = true;
        await InvokeAsync(StateHasChanged);
        await LoadDataAsync();
        isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadModelsAsync()
    {
        availableModels = new();
        selectedModelId = "";
        if (string.IsNullOrEmpty(selectedProviderId)) return;

        var provider = aiProviders.FirstOrDefault(p => p.Id == selectedProviderId);
        if (provider == null) return;

        availableModels = provider.Models.Select(m => m.Name).ToList();
        if (availableModels.Count > 0)
            selectedModelId = availableModels[0];
    }

    private async Task StartBenchmarkAsync()
    {
        runError = null;
        var config = new BenchmarkModelConfig
        {
            ProviderId = selectedProviderId,
            ModelId = selectedModelId,
            DisplayName = $"{selectedProviderId}/{selectedModelId}",
            Category = activeCategory
        };

        var ok = await ApiService.RunBenchmarkAsync(config);
        if (!ok)
        {
            runError = "启动测试失败，请检查后台服务状态。";
            return;
        }

        isRunning = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task StopBenchmarkAsync()
    {
        await ApiService.StopBenchmarkAsync();
        isRunning = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task PollStatusAsync()
    {
        try
        {
            status = await ApiService.GetBenchmarkStatusAsync();

            if (status?.Status == "completed" && isRunning)
            {
                isRunning = false;
                latestResult = status.Result;
                // 刷新排行榜和历史
                leaderboard = await ApiService.GetBenchmarkLeaderboardAsync(activeCategory);
                history = await ApiService.GetBenchmarkHistoryAsync(activeCategory);
            }
            else if (status?.Status == "failed" && isRunning)
            {
                isRunning = false;
                runError = status.Error ?? "测试失败";
            }

            await InvokeAsync(StateHasChanged);
        }
        catch { /* 忽略轮询错误 */ }
    }

    private async Task ClearHistoryAsync()
    {
        var ok = await ApiService.ClearBenchmarkHistoryAsync();
        if (ok)
        {
            history = new();
            leaderboard = new();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteSessionAsync(string sessionId)
    {
        var ok = await ApiService.DeleteBenchmarkSessionAsync(sessionId);
        if (ok)
        {
            history = await ApiService.GetBenchmarkHistoryAsync(activeCategory);
            leaderboard = await ApiService.GetBenchmarkLeaderboardAsync(activeCategory);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ViewDetail(BenchmarkSession session)
    {
        latestResult = session;
        StateHasChanged();
    }

    public void Dispose()
    {
        _pollTimer?.Stop();
        _pollTimer?.Dispose();
    }
}

