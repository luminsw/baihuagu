@page "/login"
@layout WebUI.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject WebUI.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Logging.ILogger<Login> Logger

<PageTitle>授权访问 - 百花谷</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-icon">🩺</span>
            <h1>百花谷</h1>
            <p class="subtitle">需要授权访问</p>
        </div>

        <div class="alert alert-info" role="alert">
            <span class="bi bi-info-circle-fill" aria-hidden="true"></span>
            本机命令行一键授权
        </div>

        <div class="login-form text-center">
            <p class="mb-3">请在服务器本机终端运行以下命令：</p>
            <div class="code-block">
                <code>./yj dashboard</code>
            </div>
            <p class="mt-3 text-muted small">
                命令会自动生成一次性授权链接并在浏览器中打开。
            </p>
        </div>

        <div class="login-footer">
            <p>💡 提示：授权基于操作系统用户权限</p>
            <p>只有能登录到本机的用户才能访问管理面板</p>
        </div>
    </div>
</div>

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #d65a6f 0%, #c44569 100%);
        padding: 1rem;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 2.5rem;
        width: 100%;
        max-width: 400px;
        animation: slideUp 0.3s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .logo-icon {
        font-size: 3rem;
        display: block;
        margin-bottom: 0.5rem;
    }

    .login-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 0.5rem;
    }

    .subtitle {
        color: #666;
        font-size: 1rem;
    }

    .login-form {
        margin-bottom: 1.5rem;
    }

    .code-block {
        background: #fdf6f8;
        border: 1px solid #f5e8ed;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-family: 'SF Mono', Monaco, Inconsolata, 'Fira Code', monospace;
        font-size: 0.95rem;
        color: #4a3540;
        word-break: break-all;
    }

    .login-footer {
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid #eee;
    }

    .login-footer p {
        color: #888;
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
    }

    .alert {
        margin-bottom: 1rem;
        border-radius: 8px;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        // 无需密码状态检查，始终显示授权提示
    }
}
