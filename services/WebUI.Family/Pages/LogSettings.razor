@page "/log-settings"
@rendermode InteractiveServer
@inject WebUI.Services.SettingsService SettingsService
@inject HttpClient Http

<PageTitle>日志配置</PageTitle>

<h1>📋 OpenObserve 日志配置</h1>

<div class="settings-form">
    <p class="form-description">
        OpenObserve 是高性能的可观测性平台，支持日志、指标、追踪。应用日志通过 REST API（/_multi）推送到 OpenObserve 进行集中查询和分析。
    </p>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <span class="spinner"></span> 加载中...
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert alert-error">@errorMessage</div>
    }
    else
    {
        <div class="sink-config-section">
            <h4>OpenObserve 配置</h4>
            <div class="form-group">
                <label>OpenObserve URL（已弃用）</label>
                <input type="text" class="form-control" @bind="otlpGrpcUrl"
                       placeholder="http://localhost:5081" disabled />
                <small class="form-text">当前使用 REST API 直接推送，此字段保留仅用于向后兼容</small>
            </div>
            <div class="form-group">
                <label>用户名</label>
                <input type="text" class="form-control" @bind="user"
                       placeholder="root@example.com" />
            </div>
            <div class="form-group">
                <label>密码</label>
                <input type="password" class="form-control" @bind="password"
                       placeholder="通过环境变量 OPENOBSERVE_ROOT_PASSWORD 配置" />
            </div>
            <div class="form-group">
                <label>Web UI 地址</label>
                <input type="text" class="form-control" @bind="webUrl"
                       placeholder="http://localhost:5080" />
                <small class="form-text">浏览器访问地址</small>
            </div>
        </div>

        <!-- 打开 Web UI 按钮 -->
        <div class="form-group" style="margin-top: 1rem;">
            <button class="btn btn-secondary" @onclick="OpenWebUI" @disabled="string.IsNullOrEmpty(webUrl)">
                🔗 打开 OpenObserve
            </button>
            @if (!string.IsNullOrEmpty(webUrl))
            {
                <small class="form-text" style="margin-left: 0.5rem;">@webUrl</small>
            }
        </div>

        <!-- 保存按钮 -->
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveConfig" @disabled="isSaving">
                @(isSaving ? "保存中..." : "💾 保存配置")
            </button>
            @if (saveMessage != null)
            {
                <span class="save-message @saveMessageClass">@saveMessage</span>
            }
        </div>

        <!-- Docker 部署提示 -->
        <details class="deploy-hint" style="margin-top: 2rem;">
            <summary>🐳 Docker 部署命令</summary>
            <div class="hint-content">
                <p>在项目目录运行以下命令启动 OpenObserve：</p>
                <pre><code>cd docker/logging
docker compose up -d</code></pre>
                <table class="port-table">
                    <thead>
                        <tr><th>服务</th><th>端口</th><th>说明</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>OpenObserve HTTP</td><td>5080</td><td>Web UI 和 REST API 日志推送</td></tr>
                        <tr><td>OpenObserve gRPC</td><td>5081</td><td>OTLP gRPC（内部查询用）</td></tr>
                    </tbody>
                </table>
            </div>
        </details>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? saveMessage;
    private string saveMessageClass = "";

    private string otlpGrpcUrl = "";
    private string user = "";
    private string password = "";
    private string webUrl = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var backendUrl = SettingsService.BackendUrl;
            var response = await Http.GetAsync($"{backendUrl}/api/log-sink");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var config = System.Text.Json.JsonSerializer.Deserialize<OpenObserveConfigDto>(json,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (config != null)
                {
                    otlpGrpcUrl = config.OtlpGrpcUrl ?? otlpGrpcUrl;
                    user = config.User ?? user;
                    password = config.Password ?? password;
                    webUrl = config.WebUrl ?? webUrl;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"加载配置失败：{ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveConfig()
    {
        isSaving = true;
        saveMessage = null;
        try
        {
            var config = new OpenObserveConfigDto
            {
                OtlpGrpcUrl = otlpGrpcUrl,
                User = user,
                Password = password,
                WebUrl = webUrl
            };

            var backendUrl = SettingsService.BackendUrl;
            var json = System.Text.Json.JsonSerializer.Serialize(config,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");

            var response = await Http.PutAsync($"{backendUrl}/api/log-sink", content);
            if (response.IsSuccessStatusCode)
            {
                saveMessage = "配置已保存（重启服务后生效）";
                saveMessageClass = "success";
            }
            else
            {
                saveMessage = $"保存失败：{response.StatusCode}";
                saveMessageClass = "error";
            }
        }
        catch (Exception ex)
        {
            saveMessage = $"保存失败：{ex.Message}";
            saveMessageClass = "error";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenWebUI()
    {
        // 在 Blazor Server 中通过 JS interop 打开新窗口
        // 这里仅作为占位符，实际需要 JS interop
    }

    private class OpenObserveConfigDto
    {
        public string? OtlpGrpcUrl { get; set; }
        public string? User { get; set; }
        public string? Password { get; set; }
        public string? WebUrl { get; set; }
    }
}

<style>
    .form-description {
        color: #555;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

    .sink-config-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin: 1rem 0;
    }

    .sink-config-section h4 {
        margin-bottom: 1rem;
        color: #2c3e50;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.3rem;
        font-size: 0.85rem;
        color: #444;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem 0.75rem;
        border: 1px solid #dcdde1;
        border-radius: 6px;
        background: #fff;
        color: #333;
        font-size: 0.9rem;
    }

    .form-control:focus {
        outline: none;
        border-color: #4a9eff;
        box-shadow: 0 0 0 2px rgba(74, 158, 255, 0.15);
    }

    .form-text {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.78rem;
        color: #888;
    }

    .form-actions {
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .btn {
        padding: 0.5rem 1.25rem;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #4a9eff;
        color: #fff;
    }

    .btn-primary:hover {
        background: #3a8eef;
    }

    .btn-secondary {
        background: #e9ecef;
        color: #495057;
    }

    .btn-secondary:hover {
        background: #dee2e6;
    }

    .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .save-message {
        font-size: 0.85rem;
    }

    .save-message.success {
        color: #4caf50;
    }

    .save-message.error {
        color: #f44336;
    }

    .alert-error {
        background: rgba(244, 67, 54, 0.15);
        border: 1px solid rgba(244, 67, 54, 0.3);
        border-radius: 6px;
        padding: 0.75rem 1rem;
        color: #f44336;
    }

    .deploy-hint {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

    .deploy-hint summary {
        cursor: pointer;
        color: #666;
        font-size: 0.85rem;
    }

    .hint-content {
        margin-top: 0.75rem;
        color: #555;
        font-size: 0.85rem;
    }

    .hint-content pre {
        background: #f1f3f5;
        border-radius: 4px;
        padding: 0.5rem 0.75rem;
        overflow-x: auto;
    }

    .hint-content code {
        color: #333;
        font-size: 0.82rem;
    }

    .port-table {
        width: 100%;
        margin-top: 0.75rem;
        border-collapse: collapse;
    }

    .port-table th, .port-table td {
        padding: 0.35rem 0.5rem;
        text-align: left;
        border-bottom: 1px solid #eee;
    }

    .port-table th {
        color: #888;
        font-weight: 500;
    }

    .loading-spinner {
        text-align: center;
        padding: 2rem;
        color: #888;
    }
</style>
