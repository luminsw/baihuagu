@code {
    private string inputMessage = "";
    private bool isThinking = false;
    private List<ChatMessage> messages = new();
    private AIStatusSummary? aiStatus;
    private CancellationTokenSource? _chatCts;
    private string chatSessionId = Guid.NewGuid().ToString("N");

    private List<AiConfigProvider> providers = new();
    private string selectedProviderId = "";
    private string selectedModel = "";

    private string chatMode = "remote";
    private string localModelPath = "";
    private List<LocalModelInfo> localModels = new();
    private bool _canShowLocalModels = true;

    private List<AiConfigModel> availableModels => providers
        .FirstOrDefault(p => p.Id == selectedProviderId)?.Models ?? new List<AiConfigModel>();

    private bool CanSend => chatMode == "remote"
        ? !isThinking && !string.IsNullOrWhiteSpace(inputMessage) && providers.Any()
        : !isThinking && !string.IsNullOrWhiteSpace(inputMessage) && !string.IsNullOrWhiteSpace(localModelPath);

    protected override void OnInitialized()
    {
        aiStatus = GlobalStateService.GetAIStatus();
        GlobalStateService.StateChanged += OnGlobalStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _canShowLocalModels = await CapabilityService.CanShowAsync("MessagesLocalModelSelector");
            await LoadProvidersAsync();
            await LoadChatHistoryAsync();
        }
        // 每次渲染后为代码块添加复制按钮
        await JSRuntime.InvokeVoidAsync("addCopyButtonsToCodeBlocks");
    }

    private async Task LoadProvidersAsync()
    {
        providers = await ApiService.GetAiConfigProvidersAsync();
        // 默认选中主提供商；无主提供商则选第一个
        var defaultProvider = providers.FirstOrDefault(p => p.IsMain) ?? providers.FirstOrDefault();
        if (defaultProvider != null)
        {
            selectedProviderId = defaultProvider.Id;
            var defaultModel = defaultProvider.Models.FirstOrDefault(m => m.IsMain)
                               ?? defaultProvider.Models.FirstOrDefault();
            selectedModel = defaultModel?.Name ?? "";
        }

        StateHasChanged();
    }

    private void OnGlobalStateChanged(object? sender, EventArgs e)
    {
        aiStatus = GlobalStateService.GetAIStatus();
        InvokeAsync(StateHasChanged);
    }

    private string RenderMarkdown(string? content)
    {
        if (string.IsNullOrWhiteSpace(content)) return "";
        var pipeline = new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .DisableHtml()
            .Build();
        return Markdown.ToHtml(content, pipeline);
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch { }
    }

    private async Task SaveChatHistoryAsync()
    {
        try
        {
            var history = messages.Select(m => new
            {
                m.IsUser,
                m.Content,
                m.Time,
                ToolCalls = m.ToolCalls.Select(t => new { t.Name, t.DisplayName }).ToList()
            }).ToList();
            var json = System.Text.Json.JsonSerializer.Serialize(new { sessionId = chatSessionId, messages = history });
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "chat_history", json);
        }
        catch { }
    }

    private async Task LoadChatHistoryAsync()
    {
        try
        {
            var json = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "chat_history");
            if (!string.IsNullOrWhiteSpace(json))
            {
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                var root = doc.RootElement;
                if (root.TryGetProperty("sessionId", out var sidProp))
                    chatSessionId = sidProp.GetString() ?? Guid.NewGuid().ToString("N");
                if (root.TryGetProperty("messages", out var msgsProp))
                {
                    var history = System.Text.Json.JsonSerializer.Deserialize<List<ChatMessage>>(msgsProp.GetRawText());
                    if (history != null && history.Count > 0)
                    {
                        messages = history;
                        StateHasChanged();
                        await Task.Yield();
                        try { await JSRuntime.InvokeVoidAsync("hljs.highlightAll"); } catch { }
                    }
                }
            }
        }
        catch { }
    }

    private async Task ClearChatHistoryAsync()
    {
        messages.Clear();
        chatSessionId = Guid.NewGuid().ToString("N");
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "chat_history");
        }
        catch { }
        StateHasChanged();
    }

    private async Task ExportChatAsync()
    {
        if (messages.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("# AI 对话记录");
        sb.AppendLine($"导出时间: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
        sb.AppendLine();
        foreach (var msg in messages)
        {
            var role = msg.IsUser ? "**用户**" : "**AI**";
            sb.AppendLine($"## {role} ({msg.Time:HH:mm:ss})");
            sb.AppendLine();
            sb.AppendLine(msg.Content);
            if (msg.ToolCalls.Any())
            {
                sb.AppendLine();
                sb.AppendLine($"> 🔧 调用了工具: {string.Join(", ", msg.ToolCalls.Select(t => t.DisplayName))}");
            }
            sb.AppendLine();
            sb.AppendLine("---");
            sb.AppendLine();
        }

        var markdown = sb.ToString();
        var bytes = System.Text.Encoding.UTF8.GetBytes(markdown);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"chat-export-{DateTime.Now:yyyyMMdd-HHmmss}.md";

        try
        {
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, $"data:text/markdown;base64,{base64}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"导出失败: {ex.Message}");
        }
    }

    private async Task RegenerateAsync(ChatMessage aiMessage)
    {
        var index = messages.IndexOf(aiMessage);
        if (index <= 0) return;

        // 找到对应的用户消息（AI 消息前一条应该是用户消息）
        var userMessage = messages[index - 1];
        if (!userMessage.IsUser) return;

        // 删除该 AI 消息及之后的所有消息
        while (messages.Count > index)
        {
            messages.RemoveAt(index);
        }

        isThinking = true;
        aiMessage.Content = "";
        aiMessage.ToolCalls.Clear();
        aiMessage.Time = DateTime.Now;
        messages.Add(aiMessage);
        StateHasChanged();

        await SendStreamCoreAsync(userMessage.Content, aiMessage);
    }

    /// <summary>
    /// 核心流式发送逻辑
    /// </summary>
    private async Task SendStreamCoreAsync(string content, ChatMessage aiMessage)
    {
        // 构建历史消息（后端 ChatMemoryService 负责截断和记忆管理）
        var history = messages.Take(messages.Count - 1)
            .Select(m => (m.IsUser, m.Content))
            .ToList();

        _chatCts = new CancellationTokenSource();
        try
        {
            if (chatMode == "remote")
            {
                if (useVaultSearch)
                {
                    await foreach (var delta in ApiService.StreamChatWithVaultAsync(content, selectedModel, history, _chatCts.Token))
                    {
                        if (_chatCts.IsCancellationRequested) break;
                        aiMessage.Content += delta;
                        StateHasChanged();
                        await Task.Yield();
                    }
                }
                else
                {
                    await foreach (var evt in ApiService.StreamChatWithEventsAsync(content, selectedProviderId, selectedModel, history, chatSessionId, _chatCts.Token))
                    {
                        if (_chatCts.IsCancellationRequested) break;
                        if (evt.Type == "delta" && !string.IsNullOrEmpty(evt.Content))
                        {
                            aiMessage.Content += evt.Content;
                        }
                        else if (evt.Type == "tool_call")
                        {
                            var displayName = evt.ToolName switch
                            {
                                "search_vault" => "🔍 搜索知识库",
                                "create_note" => "📝 创建笔记",
                                "get_system_status" => "📊 获取系统状态",
                                "get_current_date" => "📅 获取时间",
                                "list_vaults" => "📚 列出知识库",
                                _ => $"🔧 {evt.ToolName}"
                            };
                            aiMessage.ToolCalls.Add(new ToolCallInfo { Name = evt.ToolName ?? "", DisplayName = displayName });
                        }
                        StateHasChanged();
                        await Task.Yield();
                    }
                }
            }
            else
            {
                await foreach (var delta in ApiService.StreamLocalChatAsync(content, localModelPath, chatMode, history, _chatCts.Token))
                {
                    if (_chatCts.IsCancellationRequested) break;
                    aiMessage.Content += delta;
                    StateHasChanged();
                    await Task.Yield();
                }
            }

            if (_chatCts.IsCancellationRequested)
            {
                aiMessage.Content = string.IsNullOrEmpty(aiMessage.Content)
                    ? "（已停止）"
                    : aiMessage.Content + "\n\n（已停止）";
            }
        }
        catch (OperationCanceledException)
        {
            aiMessage.Content = string.IsNullOrEmpty(aiMessage.Content)
                ? "（已停止）"
                : aiMessage.Content + "\n\n（已停止）";
        }
        catch (Exception ex)
        {
            aiMessage.Content = $"请求失败：{ex.Message}";
        }
        finally
        {
            isThinking = false;
            _chatCts?.Dispose();
            _chatCts = null;
            StateHasChanged();
            await Task.Yield();
            try { await JSRuntime.InvokeVoidAsync("hljs.highlightAll"); } catch { }
            await SaveChatHistoryAsync();
        }
    }

    private string GetShortModelName(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "默认模型";
        var parts = fullName.Split('/', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 0 ? parts[^1] : fullName;
    }

    private bool IsLocalProvider(string providerId)
    {
        var provider = providers.FirstOrDefault(p => p.Id == providerId);
        if (provider == null) return false;
        var lower = provider.BaseUrl.ToLowerInvariant();
        return lower.Contains("localhost:11434") || lower.Contains("127.0.0.1:11434") ||
               lower.Contains("localhost:1234") || lower.Contains("127.0.0.1:1234");
    }

    private void OnProviderChanged(ChangeEventArgs e)
    {
        selectedProviderId = e.Value?.ToString() ?? "";
        var provider = providers.FirstOrDefault(p => p.Id == selectedProviderId);
        if (provider != null)
        {
            var defaultModel = provider.Models.FirstOrDefault(m => m.IsMain)
                               ?? provider.Models.FirstOrDefault();
            selectedModel = defaultModel?.Name ?? "";
        }
        else
        {
            selectedModel = "";
        }
    }

    private void OnChatModeChanged(ChangeEventArgs e)
    {
        chatMode = e.Value?.ToString() ?? "remote";
    }

    private void OnChatModeChangedSync(string mode)
    {
        chatMode = mode;
    }

    private async Task ScanLocalModels()
    {
        localModels = await ApiService.ScanLocalModelsAsync();
        if (!localModels.Any())
        {
            // 如果没有扫描到，尝试扫描用户输入的路径所在目录
            if (!string.IsNullOrWhiteSpace(localModelPath))
            {
                var dir = Path.GetDirectoryName(localModelPath);
                if (!string.IsNullOrWhiteSpace(dir) && Directory.Exists(dir))
                {
                    localModels = await ApiService.ScanLocalModelsAsync(dir);
                }
            }
        }
    }

    private void SelectLocalModel(LocalModelInfo model)
    {
        localModelPath = model.Path;
        chatMode = model.Type.ToLower();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes}B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1}KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1}MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1}GB";
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private bool useVaultSearch = false;

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(inputMessage))
            return;

        messages.Add(new ChatMessage { IsUser = true, Content = inputMessage, Time = DateTime.Now });
        var userMessage = inputMessage;
        inputMessage = "";
        isThinking = true;

        var aiMessage = new ChatMessage { IsUser = false, Content = "", Time = DateTime.Now };
        messages.Add(aiMessage);
        StateHasChanged();

        await SendStreamCoreAsync(userMessage, aiMessage);
    }

    private void StopChat()
    {
        try
        {
            _chatCts?.Cancel();
        }
        catch { }
    }

    public class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Content { get; set; } = "";
        public DateTime Time { get; set; }
        public List<ToolCallInfo> ToolCalls { get; set; } = new();
    }

    public class ToolCallInfo
    {
        public string Name { get; set; } = "";
        public string DisplayName { get; set; } = "";
    }

    public void Dispose()
    {
        GlobalStateService.StateChanged -= OnGlobalStateChanged;
        try
        {
            _chatCts?.Cancel();
            _chatCts?.Dispose();
        }
        catch { }
    }
}
