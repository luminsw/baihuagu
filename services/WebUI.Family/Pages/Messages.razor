@page "/messages"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using WebUI.Services
@using Markdig
@using Microsoft.JSInterop
@inject WebUI.Services.IApiService ApiService
@inject CapabilityService CapabilityService
@inject GlobalStateService GlobalStateService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>消息</PageTitle>

<h1>💬 AI 对话</h1>

<div class="ai-info-bar">
    @if (aiStatus?.IsConfigured ?? false)
    {
        <span class="ai-info-badge">
            <span class="ai-info-provider">🏢 @aiStatus?.ProviderName</span>
            <span class="ai-info-sep">·</span>
            <span class="ai-info-model">🤖 @GetShortModelName(aiStatus?.Model)</span>
        </span>
    }
    else
    {
        <span class="ai-info-badge ai-not-ready">⚠️ AI 未配置，请先设置 API Key</span>
    }
    @if (messages.Count > 0)
    {
        <div style="margin-left: auto; display: flex; gap: 0.5rem;">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ExportChatAsync">
                📥 导出对话
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearChatHistoryAsync">
                🗑️ 清空对话
            </button>
        </div>
    }
</div>

<div class="chat-container">
    <div class="chat-messages">
        @foreach (var message in messages)
        {
            <div class="message @(message.IsUser ? "user" : "ai")">
                <div class="message-avatar">
                    @(message.IsUser ? "👤" : "🤖")
                </div>
                <div class="message-content">
                    @if (message.ToolCalls.Any())
                    {
                        <div class="tool-calls">
                            @foreach (var tool in message.ToolCalls)
                            {
                                <span class="tool-call-badge">@tool.DisplayName</span>
                            }
                        </div>
                    }
                    <div class="message-text">
                        @if (message.IsUser)
                        {
                            @message.Content
                        }
                        else
                        {
                            @((MarkupString)RenderMarkdown(message.Content))
                        }
                    </div>
                    <div class="message-actions">
                        @if (!message.IsUser)
                        {
                            <button class="msg-action-btn" @onclick="() => RegenerateAsync(message)" title="重新生成">
                                🔄 重新生成
                            </button>
                        }
                        <span class="message-time">@message.Time.ToString("HH:mm")</span>
                    </div>
                </div>
            </div>
        }

        @if (isThinking)
        {
            <div class="message ai">
                <div class="message-avatar">🤖</div>
                <div class="message-content">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-controls">
        <div class="model-selector-bar">
            <div class="selector-group">
                <label>模式</label>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn @(chatMode == "remote" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => OnChatModeChangedSync("remote"))" disabled="@isThinking">🌐 远程</button>
                    <button type="button" class="btn @(chatMode == "gguf" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => OnChatModeChangedSync("gguf"))" disabled="@isThinking">🦙 GGUF</button>
                    <button type="button" class="btn @(chatMode == "onnx" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => OnChatModeChangedSync("onnx"))" disabled="@isThinking">📦 ONNX</button>
                </div>
            </div>
            @if (chatMode == "remote")
            {
                <div class="selector-group">
                    <label>提供商</label>
                    <select class="form-select" value="@selectedProviderId" @onchange="OnProviderChanged" disabled="@isThinking">
                        @foreach (var provider in providers)
                        {
                            <option value="@provider.Id">@provider.Name @(provider.IsMain ? "(主)" : "")</option>
                        }
                    </select>
                </div>
                <div class="selector-group">
                    <label>模型</label>
                    <select class="form-select" @bind="selectedModel" disabled="@isThinking">
                        @if (availableModels.Count == 0)
                        {
                            <option value="">— 无可用模型 —</option>
                        }
                        @foreach (var model in availableModels)
                        {
                            <option value="@model.Name">@GetShortModelName(model.Name) @(model.IsMain ? "(默认)" : "")</option>
                        }
                    </select>
                    @if (availableModels.Count == 0 && IsLocalProvider(selectedProviderId))
                    {
                        <a href="settings" class="link-small" style="margin-top: 0.25rem; display: inline-block;">
                            去设置页获取模型 →
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="selector-group" style="flex: 1; min-width: 12rem;">
                    <label>模型路径</label>
                    <div style="display: flex; gap: 0.5rem; flex: 1;">
                        <input type="text"
                               class="form-control"
                               @bind="localModelPath"
                               placeholder="@(chatMode == "gguf" ? "/path/to/model.gguf" : "/path/to/onnx/model")"
                               disabled="@isThinking"
                               style="flex: 1; font-size: 0.85rem;" />
                        <button @onclick="ScanLocalModels" class="btn btn-secondary" disabled="@isThinking" style="white-space: nowrap; font-size: 0.85rem;">
                            🔍 扫描
                        </button>
                    </div>
                </div>
            }
            @if (chatMode == "remote")
            {
                <div class="selector-group" style="align-items: center;">
                    <label>知识库</label>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" @bind="useVaultSearch" id="vaultSearchSwitch" disabled="@isThinking">
                        <label class="form-check-label" for="vaultSearchSwitch" style="font-size: 0.85rem;">
                            @(useVaultSearch ? "🔍 检索中" : "关闭")
                        </label>
                    </div>
                </div>
            }
        </div>
        @if (localModels.Any())
        {
            <div class="local-model-list">
                @foreach (var model in localModels)
                {
                    <div class="local-model-item @(localModelPath == model.Path ? "active" : "")" @onclick="() => SelectLocalModel(model)">
                        <span class="local-model-type">@model.Type.ToUpper()</span>
                        <span class="local-model-name">@model.Name</span>
                        <span class="local-model-size">@FormatBytes(model.Size)</span>
                    </div>
                }
            </div>
        }
        <div class="chat-input">
            <textarea @bind="inputMessage"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="输入消息...&#10;Shift+Enter 换行，Enter 发送"
                      class="form-control chat-textarea"
                      rows="1"
                      disabled="@isThinking"></textarea>
            @if (isThinking)
            {
                <button @onclick="StopChat" class="btn btn-danger">
                    ⏹ 停止
                </button>
            }
            else
            {
                <button @onclick="SendMessage" class="btn btn-primary" disabled="@(!CanSend)">
                    发送
                </button>
            }
        </div>
    </div>
</div>

<style>
