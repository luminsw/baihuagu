@page "/qr-tool"
@rendermode InteractiveServer
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject HttpClient HttpClient

<PageTitle>二维码工具</PageTitle>

<h1>📱 二维码工具</h1>
<p class="text-muted">生成二维码供移动端扫描，快速添加服务器</p>

<div class="qr-tool-container">
    <!-- 服务器配对二维码 -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">🏠 服务器配对码</h5>
            <button class="btn btn-sm btn-outline-primary" @onclick="LoadServerQRCode" disabled="@_isLoadingServerQR">
                @if (_isLoadingServerQR)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>加载中...</span>
                }
                else
                {
                    <span>🔄 刷新</span>
                }
            </button>
        </div>
        <div class="card-body text-center">
            @if (_serverQRCode != null)
            {
                <div class="qr-code-wrapper" @ref="_serverQrContainer"></div>
                <p class="qr-hint mt-2">使用手机扫描上方二维码，自动添加此服务器</p>
                <div class="server-info text-start mt-3">
                    <div class="row g-2">
                        <div class="col-6"><small class="text-muted">服务器名称</small><div class="fw-medium">@_serverQRCode.HostName</div></div>
                        <div class="col-6"><small class="text-muted">ServerId</small><div class="fw-medium text-truncate" title="@_serverQRCode.ServerId">@_serverQRCode.ServerId</div></div>
                        <div class="col-12"><small class="text-muted">地址</small><div class="fw-medium">@_serverQRCode.Url</div></div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(_serverQRError))
            {
                <div class="alert alert-warning">@_serverQRError</div>
            }
            else
            {
                <p class="text-muted">点击「刷新」加载服务器配对二维码</p>
            }
        </div>
    </div>

    <!-- 通用二维码生成 -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">📝 通用二维码</h5>
        </div>
        <div class="card-body">
            <div class="form-group">
                <label>输入内容</label>
                <textarea class="form-control" @bind="_inputText" rows="3" placeholder="粘贴要转成二维码的内容，如 API Key..."></textarea>
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" @onclick="GenerateQR">生成二维码</button>
                <button class="btn btn-secondary" @onclick="ClearAll">清空</button>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-error">@_errorMessage</div>
            }

            <div class="qr-result @(_showQR ? "" : "qr-hidden")">
                <div class="qr-code-wrapper" @ref="_qrContainer"></div>
                <p class="qr-hint">使用手机扫描上方二维码，内容将自动填入</p>
            </div>
        </div>
    </div>
</div>

@code {
    // 服务器配对二维码
    private ElementReference _serverQrContainer;
    private ServerQRResponse? _serverQRCode;
    private bool _isLoadingServerQR = false;
    private string _serverQRError = "";

    // 通用二维码
    private string _inputText = "";
    private bool _showQR = false;
    private string _errorMessage = "";
    private ElementReference _qrContainer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadServerQRCode();
        }
    }

    private async Task LoadServerQRCode()
    {
        _isLoadingServerQR = true;
        _serverQRError = "";
        try
        {
            _serverQRCode = await HttpClient.GetFromJsonAsync<ServerQRResponse>("api/pairing/qrcode");
            if (_serverQRCode != null && !string.IsNullOrEmpty(_serverQRCode.QrCodeData))
            {
                await Task.Yield();
                await JS.InvokeVoidAsync("generateQRCode", _serverQrContainer, _serverQRCode.QrCodeData);
            }
        }
        catch (Exception ex)
        {
            _serverQRError = $"加载失败: {ex.Message}";
        }
        finally
        {
            _isLoadingServerQR = false;
        }
    }

    private async Task GenerateQR()
    {
        _errorMessage = "";
        if (string.IsNullOrWhiteSpace(_inputText))
        {
            _errorMessage = "请输入内容";
            _showQR = false;
            return;
        }
        _showQR = true;
        await Task.Yield();
        await JS.InvokeVoidAsync("generateQRCode", _qrContainer, _inputText.Trim());
    }

    private void ClearAll()
    {
        _inputText = "";
        _showQR = false;
        _errorMessage = "";
    }

    private class ServerQRResponse
    {
        public string Url { get; set; } = "";
        public string HostName { get; set; } = "";
        public string ServerId { get; set; } = "";
        public string DeviceId { get; set; } = "";
        public string QrCodeData { get; set; } = "";
    }
}

<style>
    .qr-tool-container {
        max-width: 600px;
        margin-top: 1.5rem;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        margin-bottom: 0.35rem;
        font-weight: 500;
    }
    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #c8d4dc;
        border-radius: 4px;
        font-size: 0.95rem;
        font-family: monospace;
    }
    .form-actions {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .btn-primary {
        background: #2e8baf;
        color: white;
    }
    .btn-secondary {
        background: #5a6a72;
        color: white;
    }
    .qr-result {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: #f5f8fa;
        border-radius: 8px;
        text-align: center;
    }
    .qr-result.qr-hidden {
        display: none;
    }
    .qr-code-wrapper {
        display: inline-block;
        padding: 1rem;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        min-height: 200px;
        min-width: 200px;
    }
    .qr-hint {
        margin-top: 1rem;
        color: #666;
        font-size: 0.9rem;
    }
    .alert-error {
        background: #e0ecf4;
        border: 1px solid #c8dde8;
        color: #4a2a30;
        padding: 0.75rem 1rem;
        border-radius: 4px;
        margin-bottom: 1rem;
    }
    .server-info {
        background: #f5f8fa;
        padding: 0.75rem;
        border-radius: 6px;
        font-size: 0.9rem;
    }
</style>
