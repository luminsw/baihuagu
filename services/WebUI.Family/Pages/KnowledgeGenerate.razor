@page "/generate"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Navigation
@inject WebUI.Services.IApiService ApiService
@inject WebUI.Services.VaultsService VaultsService
@inject Microsoft.Extensions.Logging.ILogger<KnowledgeGenerate> Logger
@inject Microsoft.JSInterop.IJSRuntime JS
@using Microsoft.JSInterop

<PageTitle>AI 生成知识库</PageTitle>

<h1>🤖 AI 生成知识库</h1>

<p class="text-muted mb-3">输入主题或问题，AI 将自动生成结构化笔记内容和记忆卡片。</p>

@if (isInitializing)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">加载中...</span>
        </div>
        <p class="mt-3 text-muted">正在加载配置...</p>
    </div>
}
else
{
    <div class="generate-section">
        <!-- 主题/问题输入（最上方） -->
        <div class="form-group">
            <label>
                @(generationMode == "vault" ? "🎯 主题关键词" : "🎯 问题描述")
            </label>
            @if (generationMode == "vault")
            {
                <input type="text" @bind="aiQuery" class="form-control" placeholder="例如：Python编程、中医诊断学..." />
                <div class="form-text">输入一个主题，AI 将生成完整的知识库大纲和笔记内容</div>
            }
            else
            {
                <textarea @bind="aiQuery" @bind:event="oninput" class="form-control" rows="4"
                          placeholder="输入一个问题，AI 将生成结构化的原子笔记..."></textarea>
                <div class="form-text">输入一个具体问题，AI 将生成单条结构化笔记</div>
            }
        </div>

        <!-- 生成方式选择 -->
        <div class="form-group">
            <label>🎯 生成方式</label>
            <div class="btn-group" role="group">
                <button class="btn @(generationMode == "vault" ? "btn-primary" : "btn-outline-primary")"
                        @onclick='() => generationMode = "vault"'>
                    📚 生成完整知识库
                </button>
                <button class="btn @(generationMode == "note" ? "btn-primary" : "btn-outline-primary")"
                        @onclick='() => generationMode = "note"'>
                    📝 生成单条笔记
                </button>
            </div>
        </div>

        <!-- 行业选择（含 AI 自动推断 + 手动输入） -->
        <div class="form-group">
            <label>🏷️ 行业</label>
            <div class="d-flex flex-wrap gap-1 mb-2">
                <button class="btn @(string.IsNullOrEmpty(selectedIndustry) && !manualIndustryMode ? "btn-primary" : "btn-outline-primary") btn-sm"
                        @onclick="SelectAutoIndustry">
                    ✨ AI 自动推断
                </button>
                @foreach (var industry in GetIndustryOptions())
                {
                    <button class="btn @(!manualIndustryMode && selectedIndustry == industry ? "btn-primary" : "btn-outline-primary") btn-sm"
                            @onclick="() => OnIndustryChanged(industry)">
                        @industry
                    </button>
                }
                <button class="btn @(manualIndustryMode ? "btn-primary" : "btn-outline-secondary") btn-sm"
                        @onclick="EnableManualIndustry">
                    ✏️ 自定义
                </button>
            </div>
            @if (manualIndustryMode)
            {
                <input type="text" class="form-control form-control-sm" @bind="manualIndustryValue" @bind:event="oninput"
                       @bind:after="SyncManualIndustry"
                       placeholder="输入自定义行业名称..." style="max-width: 250px;" />
            }
            else if (string.IsNullOrEmpty(selectedIndustry))
            {
                <div class="form-text text-info">AI 将根据您输入的主题自动推断所属行业</div>
            }
        </div>

        <!-- AI 模型选择 -->
        @if (aiProviders.Count > 0)
        {
            <div class="form-group">
                <label>🤖 AI 模型</label>
                <div class="ai-model-selector">
                    @foreach (var provider in aiProviders)
                    {
                        <div style="font-size: 0.85rem; color: #666; margin-bottom: 0.25rem;">
                            @provider.Name @(provider.IsMain ? "(主)" : "")
                        </div>
                        <div class="model-options">
                            @foreach (var model in provider.Models)
                            {
                                var modelName = model.Name;
                                var displayName = modelName.Split('/').LastOrDefault() ?? modelName;
                                <button type="button"
                                        class="model-option @(selectedModel == modelName ? "selected" : "")"
                                        @onclick="() => SelectModel(modelName)"
                                        title="@modelName">
                                    @displayName
                                    @if (model.IsPaid)
                                    {
                                        <span class="tag tag-paid" style="margin-left: 0.3rem;">付费</span>
                                    }
                                    @if (model.IsMain)
                                    {
                                        <span class="tag tag-default" style="margin-left: 0.3rem;">默认</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- 知识库选择 -->
        <div class="form-group">
            <label>📚 目标知识库</label>
            <div class="vault-selector">
                <select class="form-select form-select-sm" @bind="selectedVaultId">
                    @foreach (var vault in GetFilteredVaults())
                    {
                        <option value="@vault.Id">@vault.Name</option>
                    }
                    @if (!string.IsNullOrEmpty(vaultRootPath))
                    {
                        <option value="__new__">✨ 新建（AI 自动命名）</option>
                    }
                </select>
                @if (!string.IsNullOrEmpty(selectedVaultId) && selectedVaultId != "__new__")
                {
                    var selectedVault = GetFilteredVaults().FirstOrDefault(v => v.Id == selectedVaultId);
                    @if (selectedVault?.Tags?.Any() == true)
                    {
                        <div class="d-flex flex-wrap gap-1 align-items-center mt-2">
                            @foreach (var tag in selectedVault.Tags)
                            {
                                <span class="badge bg-info text-dark" style="font-size: 0.7em;">@tag</span>
                            }
                        </div>
                    }
                }
                @if (!string.IsNullOrEmpty(vaultRootPath))
                {
                    <small class="text-muted mt-2 d-block">
                        📂 知识库根路径：<code>@vaultRootPath</code>
                        @if (selectedVaultId == "__new__")
                        {
                            <span class="ms-2 text-info">— 新知识库将在此路径下创建子目录</span>
                        }
                    </small>
                }
                else if (GetFilteredVaults().Count == 0)
                {
                    <div class="alert alert-warning mt-2">
                        当前行业暂无知识库，请先<a href="vaults" class="alert-link">配置知识库</a>或<a href="vaults" class="alert-link">设置知识库根路径</a>。
                    </div>
                }
            </div>
        </div>

        @if (selectedVaultId == "__new__")
        {
            <div class="new-vault-hint alert alert-info mb-3">
                <strong>✨ 新建知识库模式</strong>
                <small class="ms-2 text-muted">AI 将自动命名并创建新知识库</small>
            </div>

            <!-- 生成记忆卡片选项（仅新建模式） -->
            <div class="form-group">
                <label class="form-check-label">
                    <input type="checkbox" @bind="generateCards" class="form-check-input" />
                    🧠 生成笔记后自动生成记忆卡片
                </label>
                <div class="form-text text-muted">笔记生成完成后，自动将其转换为 Anki 记忆卡片</div>
            </div>
        }

        <!-- 提示词编辑 -->
        <div class="form-group">
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showPromptEditor = !showPromptEditor">
                @(showPromptEditor ? "🔼 收起提示词" : "✏️ 编辑提示词")
            </button>
        </div>

        @if (showPromptEditor)
        {
            <div class="form-group">
                <label>系统提示词</label>
                <textarea class="form-control" @bind="customSystemPrompt" rows="6"
                          placeholder="留空则使用默认提示词..."></textarea>
                <div class="form-text">
                    @if (string.IsNullOrWhiteSpace(customSystemPrompt))
                    {
                        <span class="text-muted">使用默认提示词</span>
                    }
                    else
                    {
                        <span class="text-info">（已自定义）</span>
                    }
                </div>
            </div>
        }

        <!-- 生成按钮 -->
        <div class="form-actions">
            <button @onclick="ExecuteGeneration"
                    class="btn btn-primary btn-lg"
                    disabled="@(isProcessing || string.IsNullOrWhiteSpace(aiQuery) || string.IsNullOrWhiteSpace(selectedVaultId))">
                @if (isProcessing)
                {
                    <span>⏳ @processingStep...</span>
                }
                else if (generationMode == "vault")
                {
                    <span>🚀 生成知识库 @(generateCards ? "并创建记忆卡片" : "")</span>
                }
                else
                {
                    <span>🤖 生成笔记 @(generateCards ? "并创建记忆卡片" : "")</span>
                }
            </button>
        </div>
    </div>

    <!-- 记忆卡片入口 -->
    <div class="mt-3">
        <a href="cards" class="btn btn-outline-info">
            <span>🧠 查看记忆卡片</span>
        </a>
    </div>
}

<style>
    .generate-section {
        background: #f5f8fa;
        border: 1px solid #e8eef2;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        max-width: 650px;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        font-weight: 600;
        color: #4a5860;
        margin-bottom: 0.5rem;
    }
    .form-actions {
        margin-top: 1.5rem;
    }
    .ai-model-selector {
        padding: 0.5rem;
        background: white;
        border-radius: 4px;
        border: 1px solid #e8eef2;
    }
    .model-options {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .model-option {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.4rem 0.75rem;
        background: white;
        border: 2px solid #d8e2e8;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }
    .model-option:hover {
        border-color: #a0aeb6;
    }
    .model-option.selected {
        border-color: #2e8baf;
        background: #e0ecf4;
        box-shadow: 0 0 0 2px rgba(0,123,255,0.2);
    }
    .tag {
        display: inline-flex;
        align-items: center;
        padding: 0.1rem 0.3rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 500;
    }
    .tag-default {
        background: #5a6a72;
        color: white;
    }
    .tag-paid {
        background: #f5eee0;
        color: #6a5a3a;
        border: 1px solid #d4a574;
    }
    .vault-selector code {
        font-size: 0.85em;
        background: #e8eef2;
        padding: 0.15rem 0.4rem;
        border-radius: 3px;
    }
    .new-vault-hint {
        padding: 0.75rem 1rem;
    }
</style>

@code {
    private List<AiProviderInfo> aiProviders = new();
    private string selectedModel = "";
    private bool isInitializing = true;
    private bool isProcessing = false;
    private string processingStep = "";

    private string generationMode = "vault";

    private string selectedIndustry = "";
    private bool manualIndustryMode = false;
    private string manualIndustryValue = "";
    private string aiQuery = "";
    private bool generateCards = true;

    private List<VaultConfig> vaults = new();
    private string selectedVaultId = "";
    private string vaultRootPath = "";
    private int aiTimeoutSeconds = 90;
    private bool saveToVault = true;
    private bool autoSplitAfterGenerate = true;
    private string customSystemPrompt = "";
    private bool showPromptEditor = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !isInitializing) return;

        try
        {
            var loadProvidersTask = LoadAiProviders();
            var loadVaultsTask = LoadVaults();
            var loadPlatformTask = LoadAiTimeoutConfig();

            await Task.WhenAll(loadProvidersTask, loadVaultsTask, loadPlatformTask);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "初始化加载失败");
        }
        finally
        {
            isInitializing = false;
            StateHasChanged();
        }
    }

    private List<string> GetIndustryOptions()
    {
        var predefined = new List<string> { "中医", "计算机", "通用" };
        var fromVaults = vaults.Select(v => v.Industry)
                               .Where(i => !string.IsNullOrWhiteSpace(i))
                               .Distinct();
        return predefined.Concat(fromVaults)
                         .Distinct()
                         .OrderBy(i => i)
                         .ToList();
    }

    private List<VaultConfig> GetFilteredVaults() =>
        string.IsNullOrWhiteSpace(selectedIndustry)
            ? vaults
            : vaults.Where(v => v.Industry == selectedIndustry).ToList();

    private async Task LoadVaults()
    {
        try
        {
            var vaultsResponse = await VaultsService.GetVaultsAsync();
            vaults = vaultsResponse.Vaults;

            vaultRootPath = await VaultsService.GetVaultRootPathPreferenceAsync();

            selectedVaultId = !string.IsNullOrEmpty(vaultRootPath) ? "__new__" : GetFilteredVaults().FirstOrDefault()?.Id ?? "";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载知识库列表失败");
            vaults = new List<VaultConfig>();
        }
    }

    private async Task LoadAiProviders()
    {
        try
        {
            aiProviders = await ApiService.GetAiProvidersAsync();
            var mainProvider = aiProviders.FirstOrDefault(p => p.IsMain) ?? aiProviders.FirstOrDefault();
            var mainModel = mainProvider?.Models.FirstOrDefault(m => m.IsMain)?.Name
                ?? mainProvider?.Models.FirstOrDefault()?.Name;
            if (!string.IsNullOrWhiteSpace(mainModel))
            {
                selectedModel = mainModel;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载 AI 提供方失败");
            aiProviders = new List<AiProviderInfo>();
        }
    }

    private void SelectModel(string modelName)
    {
        selectedModel = modelName;
    }

    private void SelectAutoIndustry()
    {
        OnIndustryChanged("");
    }

    private void OnIndustryChanged(string industry)
    {
        selectedIndustry = industry;
        manualIndustryMode = false;
        customSystemPrompt = "";
        selectedVaultId = !string.IsNullOrEmpty(vaultRootPath) ? "__new__" : GetFilteredVaults().FirstOrDefault()?.Id ?? "";
    }

    private void EnableManualIndustry()
    {
        manualIndustryMode = !manualIndustryMode;
        if (manualIndustryMode)
        {
            selectedIndustry = manualIndustryValue?.Trim() ?? "";
        }
    }

    private void SyncManualIndustry()
    {
        if (manualIndustryMode)
        {
            selectedIndustry = manualIndustryValue?.Trim() ?? "";
        }
    }

    private async Task LoadAiTimeoutConfig()
    {
        try
        {
            var platformInfo = await ApiService.GetPlatformAsync();
            if (platformInfo != null && platformInfo.AiRequestTimeoutMinutes > 0)
            {
                aiTimeoutSeconds = 30;
            }
        }
        catch { }
    }

    private async Task<string?> InferIndustryAsync(string query)
    {
        try
        {
            var options = string.Join("、", GetIndustryOptions());
            var prompt = $"根据以下内容，判断它属于哪个行业。只返回以下预定义行业之一（不要返回其他内容）：{options}\n\n内容：{query}";
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(aiTimeoutSeconds));
            var response = await ApiService.ChatAsync(prompt, cts.Token);
            if (response.Success && !string.IsNullOrWhiteSpace(response.Reply))
            {
                var inferred = response.Reply.Trim();
                var available = GetIndustryOptions();
                var matched = available.FirstOrDefault(i => inferred.Contains(i));
                if (!string.IsNullOrEmpty(matched))
                {
                    Logger.LogInformation("AI 推断行业：{Inferred}，匹配：{Matched}", inferred, matched);
                    return matched;
                }
                Logger.LogWarning("AI 推断行业结果 '{Inferred}' 未匹配预定义选项，使用通用", inferred);
            }
        }
        catch (OperationCanceledException)
        {
            Logger.LogWarning("AI 推断行业超时");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "AI 推断行业失败");
        }
        return "通用";
    }

    private async Task ExecuteGeneration()
    {
        if (string.IsNullOrWhiteSpace(aiQuery)) return;

        var industry = manualIndustryMode ? manualIndustryValue?.Trim() : selectedIndustry;
        if (string.IsNullOrWhiteSpace(industry))
        {
            isProcessing = true;
            processingStep = "AI 推断行业中...";
            StateHasChanged();

            var inferred = await InferIndustryAsync(aiQuery);
            industry = inferred ?? "通用";
            selectedIndustry = industry;

            if (selectedVaultId == "__new__" || string.IsNullOrWhiteSpace(selectedVaultId))
            {
                selectedVaultId = !string.IsNullOrEmpty(vaultRootPath) ? "__new__" : GetFilteredVaults().FirstOrDefault()?.Id ?? "";
            }

            isProcessing = false;
            StateHasChanged();
        }

        if (generationMode == "vault")
        {
            await GenerateFullVault(industry);
        }
        else
        {
            await GenerateSingleNote(industry);
        }
    }

    private async Task GenerateFullVault(string industry)
    {
        isProcessing = true;
        processingStep = "提交生成任务中...";
        try
        {
            var response = await ApiService.CreateVaultGenerationTaskAsync(industry.Trim(), aiQuery.Trim(), selectedModel, generateCards: generateCards);
            if (response.Success && !string.IsNullOrWhiteSpace(response.TaskId))
            {
                Navigation.NavigateTo("tasks");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", string.IsNullOrWhiteSpace(response.Message) ? "任务创建失败" : response.Message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "生成知识库失败");
            await JS.InvokeVoidAsync("alert", $"生成失败：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
            processingStep = "";
        }
    }


    private async Task GenerateSingleNote(string industry)
    {
        if (selectedVaultId == "__new__")
        {
            if (string.IsNullOrEmpty(vaultRootPath))
            {
                await JS.InvokeVoidAsync("alert", "请先在知识库管理页设置知识库根路径");
                return;
            }

            isProcessing = true;
            processingStep = "创建知识库中...";
            try
            {
                var vaultName = await GenerateVaultNameAsync(aiQuery, industry);
                if (string.IsNullOrWhiteSpace(vaultName))
                {
                    Logger.LogWarning("无法生成知识库名称");
                    await JS.InvokeVoidAsync("alert", "无法生成知识库名称，请检查 AI 配置或重新输入问题");
                    return;
                }

                var vaultPath = System.IO.Path.Combine(vaultRootPath, "local", industry, vaultName);
                var (success, vault, error) = await VaultsService.AddVaultAsync(vaultName, vaultPath, industry);
                if (!success || vault == null)
                {
                    await JS.InvokeVoidAsync("alert", $"创建知识库失败：{error}");
                    return;
                }

                if (string.IsNullOrWhiteSpace(vault.Id))
                {
                    Logger.LogError("AddVaultAsync 返回了无效的 vault.Id");
                    await JS.InvokeVoidAsync("alert", "创建知识库成功但返回了无效的 ID，请刷新页面重试");
                    return;
                }

                selectedVaultId = vault.Id;
                var vaultsResponse = await VaultsService.GetVaultsAsync(forceRefresh: true);
                vaults = vaultsResponse.Vaults;

                Logger.LogInformation("新建知识库完成，名称={VaultName}, Id={VaultId}", vaultName, vault.Id);

                processingStep = "生成笔记中...";
                StateHasChanged();

                var response = await ApiService.CreateAiTaskAsync(aiQuery, saveToVault, vault.Id, selectedModel, autoSplitAfterGenerate, customSystemPrompt, industry);

                if (response.Success)
                {
                    if (generateCards && !string.IsNullOrWhiteSpace(response.TaskId))
                    {
                        processingStep = "笔记生成任务已提交，等待完成后生成记忆卡片...";
                        StateHasChanged();

                        await WaitForTaskCompletion(response.TaskId);
                        await GenerateAnkiCards(vault.Id);
                    }
                    Navigation.NavigateTo("tasks");
                }
                else
                {
                    await JS.InvokeVoidAsync("alert", $"创建任务失败：{response.Message}");
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"创建失败：{ex.Message}");
            }
            finally
            {
                isProcessing = false;
                processingStep = "";
            }
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedVaultId))
        {
            await JS.InvokeVoidAsync("alert", "请先选择知识库");
            return;
        }

        isProcessing = true;
        processingStep = "生成笔记中...";
        try
        {
            var response = await ApiService.CreateAiTaskAsync(aiQuery, saveToVault, selectedVaultId, selectedModel, autoSplitAfterGenerate, customSystemPrompt, industry);

            if (response.Success)
            {
                if (generateCards && !string.IsNullOrWhiteSpace(response.TaskId))
                {
                    processingStep = "笔记生成任务已提交，等待完成后生成记忆卡片...";
                    StateHasChanged();

                    await WaitForTaskCompletion(response.TaskId);
                    await GenerateAnkiCards(selectedVaultId);
                }
                Navigation.NavigateTo("tasks");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"创建任务失败：{response.Message}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"创建任务失败：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
            processingStep = "";
        }
    }

    private async Task WaitForTaskCompletion(string taskId)
    {
        var maxAttempts = 60;
        var delayMs = 2000;

        for (var i = 0; i < maxAttempts; i++)
        {
            try
            {
                await Task.Delay(delayMs);
            }
            catch { }
        }
    }

    private async Task GenerateAnkiCards(string vaultId)
    {
        if (string.IsNullOrWhiteSpace(vaultId)) return;

        processingStep = "生成记忆卡片中...";
        StateHasChanged();

        try
        {
            var result = await ApiService.GenerateAllCardsAsync(vaultId);
            if (result != null)
            {
                Logger.LogInformation("记忆卡片生成完成，任务ID={TaskId}", result.TaskId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "生成记忆卡片失败，跳过");
        }
    }

    private async Task<string?> GenerateVaultNameAsync(string query, string industry)
    {
        try
        {
            var prompt = $"根据以下{industry}问题，生成一个简短的中文知识库名称（2-6个字，不要包含标点符号，只返回名称本身）：\n\n问题：{query}";
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(aiTimeoutSeconds));
            var response = await ApiService.ChatAsync(prompt, cts.Token);
            if (response.Success && !string.IsNullOrWhiteSpace(response.Reply))
            {
                var lines = response.Reply.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
                    .Where(l => !l.TrimStart().StartsWith(">"))
                    .ToList();

                var rawName = string.Join("", lines).Trim();

                var name = rawName
                    .Replace("\"", "").Replace("'", "").Replace("「", "").Replace("」", "")
                    .Replace("《", "").Replace("》", "")
                    .Trim();

                if (name.Length > 20)
                    name = name.Substring(0, 20);

                return name;
            }
        }
        catch (OperationCanceledException)
        {
            Logger.LogWarning("AI 生成知识库名称超时，使用降级方案");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "AI 生成知识库名称失败，使用降级方案");
        }

        return FallbackVaultName(query);
    }

    private string? FallbackVaultName(string query)
    {
        if (string.IsNullOrWhiteSpace(query)) return null;
        var cleaned = query.Trim()
            .Replace("？", "").Replace("?", "").Replace("。", "").Replace("，", "").Replace(",", "")
            .Replace("的", "").Replace("如何", "").Replace("怎么", "").Replace("什么", "");
        if (string.IsNullOrWhiteSpace(cleaned)) cleaned = query.Trim();
        return cleaned.Length > 6 ? cleaned.Substring(0, 6) : cleaned;
    }
}
