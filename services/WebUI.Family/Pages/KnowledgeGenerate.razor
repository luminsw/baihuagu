@page "/generate"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager Navigation
@inject WebUI.Services.IApiService ApiService
@inject Microsoft.Extensions.Logging.ILogger<KnowledgeGenerate> Logger
@inject Microsoft.JSInterop.IJSRuntime JS
@using Microsoft.JSInterop

<PageTitle>AI 生成知识库</PageTitle>

<h1>🤖 AI 生成知识库</h1>

<p class="text-muted mb-3">输入行业和关键词，AI 将自动生成完整的知识库（名称 → 大纲 → 笔记内容）。</p>

@if (isInitializing)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">加载中...</span>
        </div>
        <p class="mt-3 text-muted">正在加载配置...</p>
    </div>
}
else
{
    <div class="generate-section">
        <div class="form-group">
            <label for="industry">🏷️ 行业</label>
            <input type="text" id="industry" @bind="industry" class="form-control" placeholder="例如：医学、计算机、机械..." />
        </div>

        <div class="form-group">
            <label for="keyword">🎯 关键词 / 主题</label>
            <input type="text" id="keyword" @bind="keyword" class="form-control" placeholder="例如：Python编程、中医诊断学..." />
        </div>

        <div class="form-group">
            <label for="noteCount">📝 笔记数量（1-50）</label>
            <input type="number" id="noteCount" @bind="noteCount" class="form-control" min="1" max="50" />
        </div>

        @if (aiProviders.Count > 0)
        {
            <div class="form-group">
                <label>🤖 AI 模型</label>
                <div class="ai-model-selector" style="padding: 0.5rem; background: #f8f9fa; border-radius: 4px; border: 1px solid #e9ecef;">
                    @foreach (var provider in aiProviders)
                    {
                        <div style="font-size: 0.85rem; color: #666; margin-bottom: 0.25rem;">
                            @provider.Name @(provider.IsMain ? "(主)" : "")
                        </div>
                        <div class="model-options" style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
                            @foreach (var model in provider.Models)
                            {
                                var modelName = model.Name;
                                var displayName = modelName.Split('/').LastOrDefault() ?? modelName;
                                <button type="button"
                                        class="model-option @(selectedModel == modelName ? "selected" : "")"
                                        @onclick="() => SelectModel(modelName)"
                                        title="@modelName">
                                    @displayName
                                    @if (model.IsPaid)
                                    {
                                        <span class="tag tag-paid" style="margin-left: 0.3rem;">付费</span>
                                    }
                                    @if (model.IsMain)
                                    {
                                        <span class="tag tag-default" style="margin-left: 0.3rem;">默认</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="form-actions">
            <button @onclick="GenerateVault"
                    class="btn btn-primary btn-lg"
                    disabled="@isGenerating">
                @if (isGenerating)
                {
                    <span>⏳ 创建任务中...</span>
                }
                else
                {
                    <span>🚀 生成知识库</span>
                }
            </button>
        </div>
    </div>
}

<style>
    .generate-section {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        max-width: 600px;
    }
    .form-group {
        margin-bottom: 1rem;
    }
    .form-group label {
        display: block;
        font-weight: 600;
        color: #495057;
        margin-bottom: 0.5rem;
    }
    .form-actions {
        margin-top: 1.5rem;
    }
    .model-options {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .model-option {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.4rem 0.75rem;
        background: white;
        border: 2px solid #dee2e6;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }
    .model-option:hover {
        border-color: #adb5bd;
    }
    .model-option.selected {
        border-color: #007bff;
        background: #e7f3ff;
        box-shadow: 0 0 0 2px rgba(0,123,255,0.2);
    }
    .tag {
        display: inline-flex;
        align-items: center;
        padding: 0.1rem 0.3rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 500;
    }
    .tag-default {
        background: #6c757d;
        color: white;
    }
    .tag-paid {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
    }
</style>

@code {
    private List<AiProviderInfo> aiProviders = new();
    private string selectedModel = "";
    private bool isInitializing = true;
    private bool isGenerating = false;

    private string industry = "";
    private string keyword = "";
    private int noteCount = 30;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !isInitializing) return;

        try
        {
            await LoadAiProviders();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "初始化加载失败");
        }
        finally
        {
            isInitializing = false;
            StateHasChanged();
        }
    }

    private async Task LoadAiProviders()
    {
        try
        {
            aiProviders = await ApiService.GetAiProvidersAsync();
            var mainProvider = aiProviders.FirstOrDefault(p => p.IsMain) ?? aiProviders.FirstOrDefault();
            var mainModel = mainProvider?.Models.FirstOrDefault(m => m.IsMain)?.Name
                ?? mainProvider?.Models.FirstOrDefault()?.Name;
            if (!string.IsNullOrEmpty(mainModel))
            {
                selectedModel = mainModel;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "加载 AI 提供方失败");
            aiProviders = new List<AiProviderInfo>();
        }
    }

    private void SelectModel(string modelName)
    {
        selectedModel = modelName;
    }

    private async Task GenerateVault()
    {
        if (string.IsNullOrWhiteSpace(industry))
        {
            await JS.InvokeVoidAsync("alert", "请输入行业");
            return;
        }
        if (string.IsNullOrWhiteSpace(keyword))
        {
            await JS.InvokeVoidAsync("alert", "请输入关键词");
            return;
        }
        if (noteCount < 1 || noteCount > 50)
        {
            await JS.InvokeVoidAsync("alert", "笔记数量必须在 1-50 之间");
            return;
        }

        isGenerating = true;
        try
        {
            var response = await ApiService.CreateVaultGenerationTaskAsync(industry.Trim(), keyword.Trim(), selectedModel, noteCount);
            if (response.Success && !string.IsNullOrWhiteSpace(response.TaskId))
            {
                Navigation.NavigateTo("tasks");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", string.IsNullOrWhiteSpace(response.Message) ? "任务创建失败" : response.Message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "生成知识库失败");
            await JS.InvokeVoidAsync("alert", $"生成失败：{ex.Message}");
        }
        finally
        {
            isGenerating = false;
        }
    }
}
