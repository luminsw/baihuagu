                <span class="load-message @(loadModelSuccess ? "text-success" : "text-error")">@loadModelMessage</span>
            }
        </div>
        }
    </div>
    }

    @if (_activeTab == "overview")
    {
    <!-- 本地工具状态 -->
    <div class="tools-section">
        <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showLocalTools)">
            <h2>@(_showLocalTools ? "▼" : "▶") 本地工具</h2>
        </div>
        @if (_showLocalTools)
        {
        <div class="tools-list">
            @foreach (var tool in localTools)
            {
                <div class="tool-item">
                    <span class="tool-name">@tool.Name</span>
                    @if (tool.IsInstalled)
                    {
                        <span class="badge badge-success">已安装 @(tool.Version)</span>
                        @if (tool.IsRunning)
                        {
                            <span class="badge badge-info">运行中</span>
                        }
                        else
                        {
                            <span class="badge badge-warning">未运行</span>
                        }
                    }
                    else
                    {
                        <span class="badge badge-warning">未安装</span>
                        @if (!string.IsNullOrEmpty(tool.InstallGuideUrl))
                        {
                            <a href="@tool.InstallGuideUrl" target="_blank" class="link-small">安装指南</a>
                        }
                    }
                </div>
            }
        </div>
        }
    </div>

    }

    @if (_activeTab == "llamacpp")
    {
    <!-- llama.cpp 配置 -->
    @if (llamaCppTool != null)
    {
        <div class="llamacpp-section">
            <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showLlamaCpp)">
                <h2>@(_showLlamaCpp ? "▼" : "▶") 🔥 llama.cpp 配置</h2>
            </div>
            @if (_showLlamaCpp)
            {
            @if (!llamaCppTool.IsInstalled)
            {
                <div class="alert alert-warning">
                    llama.cpp 未安装或未配置二进制路径。
                    <a href="@llamaCppTool.InstallGuideUrl" target="_blank">安装指南</a>
                </div>
            }
            else
            {
                <div class="llamacpp-config-form">
                    <div class="form-row">
                        <div class="form-group" style="flex: 2;">
                            <label>模型文件路径（.gguf）</label>
                            <input type="text" class="form-control" @bind="_llamaCppModelPath"
                                   placeholder="/path/to/model.gguf" />
                            <div class="form-text">例如：/home/lumin/models/Qwen3-8B-Q4_K_M.gguf</div>
                        </div>
                        <div class="form-group">
                            <label>端口</label>
                            <input type="number" class="form-control" @bind="_llamaCppPort" />
                        </div>
                    </div>

                    <h4 class="llamacpp-section-title">⚙️ 基础配置</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>GPU 层数（-ngl）</label>
                            <input type="number" class="form-control" @bind="_llamaCppNGpuLayers" />
                            <div class="form-text">0=纯CPU，999=全部 offload 到 GPU</div>
                        </div>
                        <div class="form-group">
                            <label>上下文大小（-c）</label>
                            <input type="number" class="form-control" @bind="_llamaCppContextSize" />
                            <div class="form-text">模型能记住的 token 数，越大占显存越多</div>
                        </div>
                        <div class="form-group">
                            <label>CPU 线程数（-t）</label>
                            <input type="number" class="form-control" @bind="_llamaCppThreads" />
                            <div class="form-text">0=自动使用全部核心</div>
                        </div>
                        <div class="form-group">
                            <label>批处理大小（-b）</label>
                            <input type="number" class="form-control" @bind="_llamaCppBatchSize" />
                            <div class="form-text">越大吞吐量越高，默认 2048</div>
                        </div>
                    </div>

                    <h4 class="llamacpp-section-title">🎛️ 显存优化（长上下文必读）</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>KV Cache K 量化</label>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn @(_llamaCppCacheTypeK == "" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeK = "")">不量化</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeK == "f16" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeK = "f16")">f16</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeK == "q8_0" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeK = "q8_0")">q8_0</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeK == "q4_0" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeK = "q4_0")">q4_0</button>
                            </div>
                            <div class="form-text">显存紧张时选 q8_0，可大幅降低长上下文显存占用</div>
                        </div>
                        <div class="form-group">
                            <label>KV Cache V 量化</label>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn @(_llamaCppCacheTypeV == "" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeV = "")">不量化</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeV == "f16" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeV = "f16")">f16</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeV == "q8_0" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeV = "q8_0")">q8_0</button>
                                <button type="button" class="btn @(_llamaCppCacheTypeV == "q4_0" ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => _llamaCppCacheTypeV = "q4_0")">q4_0</button>
                            </div>
                            <div class="form-text">通常与 K 量化保持一致</div>
                        </div>
                    </div>

                    <h4 class="llamacpp-section-title">🔧 高级选项</h4>
                    <div class="form-row llamacpp-presets">
                        <label class="preset-checkbox" title="Flash Attention：显著降低显存占用，Intel Arc / 现代 GPU 强烈建议开启">
                            <input type="checkbox" @bind="_llamaCppUseFlashAttn" />
                            <span>⚡ Flash Attention (--flash-attn)</span>
                        </label>
                        <label class="preset-checkbox" title="内存锁定：防止模型被换出到 swap，提升稳定性">
                            <input type="checkbox" @bind="_llamaCppUseMlock" />
                            <span>🔒 内存锁定 (--mlock)</span>
                        </label>
                        <label class="preset-checkbox" title="禁用内存映射：某些系统环境下更稳定">
                            <input type="checkbox" @bind="_llamaCppUseNoMmap" />
                            <span>🚫 禁用 mmap (--no-mmap)</span>
                        </label>
                        <label class="preset-checkbox" title="连续批处理：提升多客户端并发请求的吞吐量">
                            <input type="checkbox" @bind="_llamaCppUseContBatching" />
                            <span>🔄 连续批处理 (--cont-batching)</span>
                        </label>
                    </div>

                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label>额外启动参数</label>
                            <input type="text" class="form-control" @bind="_llamaCppExtraArgs"
                                   placeholder="--verbose --log-disable" />
                            <div class="form-text">高级自定义参数（上方勾选的选项会自动附加）</div>
                        </div>
                    </div>

                    <div class="llamacpp-quick-presets">
                        <span class="preset-label">快速预设：</span>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyVramOptimizedPreset">
                            💾 显存优化（长上下文推荐）
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ApplySpeedPreset">
                            🚀 速度优先
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyCpuOnlyPreset">
                            🖥️ 纯 CPU 模式
                        </button>
                    </div>

                    <div class="llamacpp-actions">
                        <button class="btn btn-primary" @onclick="SaveLlamaCppConfigAsync"
                                disabled="@_isSavingLlamaCppConfig">
                            @(_isSavingLlamaCppConfig ? "保存中..." : "💾 保存配置")
                        </button>
                        @if (llamaCppTool.IsRunning)
                        {
                            <button class="btn btn-danger" @onclick="StopLlamaCppAsync"
                                    disabled="@_isLlamaCppActionRunning">
                                @(_isLlamaCppActionRunning ? "停止中..." : "⏹ 停止服务")
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success" @onclick="StartLlamaCppAsync"
                                    disabled="@_isLlamaCppActionRunning">
                                @(_isLlamaCppActionRunning ? "启动中..." : "▶️ 启动服务")
                            </button>
                        }
                        @if (!string.IsNullOrEmpty(_llamaCppStatusMessage))
                        {
                            <span class="load-message @(_llamaCppStatusSuccess ? "text-success" : "text-error")">
                                @_llamaCppStatusMessage
                            </span>
                        }
                    </div>
                </div>
                }
            }
        </div>
    }

    }

    @if (_activeTab == "overview")
    {
    <!-- 场景筛选 -->
    <div class="scenario-section">
        <div class="scenario-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showRecommendations)">
            <h2>@(_showRecommendations ? "▼" : "▶") 模型推荐</h2>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshLibrary" @onclick:stopPropagation
                    disabled="@isRefreshingLibrary" title="从 Ollama Library 拉取最新模型列表">
                @(isRefreshingLibrary ? "🔄 刷新中..." : "🔄 刷新模型库")
            </button>
        </div>
        <div class="scenario-tags">
            @foreach (var tag in scenarioTags)
            {
                <button class="scenario-tag @(currentScenario == tag.Value ? "active" : "")"
                        @onclick="() => SelectScenario(tag.Value)">
                    @tag.Label
                </button>
            }
        </div>
        <div class="scenario-tags company-tags" style="margin-top:0.5rem;">
            @foreach (var tag in companyTags)
            {
                <button class="scenario-tag company-tag @(currentCompany == tag.Value ? "active" : "")"
                        @onclick="() => SelectCompany(tag.Value)">
                    @tag.Label
                </button>
            }
        </div>
    </div>

    @if (_showRecommendations)
    {
        @if (availableVram.HasValue)
        {
            <div class="hardware-vram-bar" style="margin-bottom:1rem;">
                <span style="font-size:0.85rem;padding:0.35rem 0.75rem;background:#e0ecf4;border-radius:20px;color:#2e8baf;font-weight:500;">
                    本机显存: @(availableVram.Value.ToString("F1")) GB
                    @if (recommendedTierVramGb.HasValue)
                    {
                        <span style="color:#3d6b45;font-weight:600;"> → 推荐 @recommendedTierVramGb.Value GB 档位</span>
                    }
                </span>
            </div>
        }

        @if (FilteredModelsByTier.Count == 0)
        {
            <div class="alert alert-warning">暂无推荐模型，请检查硬件检测是否正常。</div>
        }
        else
        {
            @foreach (var tier in VramTierValues)
            {
                var models = FilteredModelsByTier.GetValueOrDefault(tier);
                if (models == null || models.Count == 0) continue;

                var isRecommended = recommendedTierVramGb.HasValue && recommendedTierVramGb.Value == tier;

                <div class="tier-group @(isRecommended ? "tier-recommended" : "")">
                    <div class="tier-group-header">
                        <div class="tier-title">
                            <span class="tier-badge">💾 @tier GB</span>
                            @if (isRecommended)
                            {
                                <span class="tier-recommended-badge">✓ 当前配置推荐</span>
                            }
                        </div>
                        <span class="tier-count">@models.Count 个模型</span>
                    </div>
                    <div class="models-grid">
                        @foreach (var model in models)
                        {
                            @RenderModelCard(model)
                        }
                    </div>
                </div>
            }
        }
    }

    }


    <!-- 删除确认对话框 -->
    @if (showDeleteConfirm && modelToDelete != null)
    {
        <div class="modal-overlay" @onclick="CancelDeleteModel">
            <div class="modal-content modal-small" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>⚠️ 确认删除</h3>
                    <button class="modal-close" @onclick="CancelDeleteModel">×</button>
                </div>
                <div class="modal-body">
                    <p>确定要删除模型 <strong>@modelToDelete.Name</strong> 吗？</p>
                    <p>大小: <strong>@modelToDelete.SizeGiB GB</strong></p>
                    <p class="text-error">此操作不可恢复，模型文件将被永久删除。</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDeleteModel">取消</button>
                    <button class="btn btn-danger" @onclick="ConfirmDeleteModel" disabled="@isLoadingModel">
                        @(isLoadingModel ? "删除中..." : "确认删除")
                    </button>
                </div>
            </div>
        </div>
    }


    <!-- 模型详情弹窗 -->
    @if (showDetailsModal && modelDetails != null)
    {
        <div class="modal-overlay" @onclick="CloseDetailsModal">
            <div class="modal-content modal-large" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>📋 模型详情: @modelDetails.Name</h3>
                    <button class="modal-close" @onclick="CloseDetailsModal">×</button>
                </div>
                <div class="modal-body">
                    @if (isLoadingDetails)
                    {
                        <div class="loading-spinner">加载详情中...</div>
                    }
                    else
                    {
                        <div class="details-sections">
                            @if (!string.IsNullOrEmpty(modelDetails.Modelfile))
                            {
                                <div class="detail-section">
                                    <h4>Modelfile</h4>
                                    <pre class="detail-code">@modelDetails.Modelfile</pre>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(modelDetails.Parameters))
                            {
                                <div class="detail-section">
                                    <h4>Parameters</h4>
                                    <pre class="detail-code">@modelDetails.Parameters</pre>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(modelDetails.Template))
                            {
                                <div class="detail-section">
                                    <h4>Template</h4>
                                    <pre class="detail-code">@modelDetails.Template</pre>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(modelDetails.License))
                            {
                                <div class="detail-section">
                                    <h4>License</h4>
                                    <pre class="detail-code">@modelDetails.License</pre>
                                </div>
                            }
                            @if (string.IsNullOrEmpty(modelDetails.Modelfile) && string.IsNullOrEmpty(modelDetails.Parameters)
                                && string.IsNullOrEmpty(modelDetails.Template) && string.IsNullOrEmpty(modelDetails.License))
                            {
                                <div class="alert alert-info">该工具暂不支持显示模型详情。</div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDetailsModal">关闭</button>
                </div>
            </div>
        </div>
    }

    @if (_activeTab == "overview")
    {
    <!-- 部署状态面板 -->
    @if (activeTasks.Count > 0)
    {
        <div class="deploy-section">
            <h2>部署状态</h2>
            @foreach (var task in activeTasks)
            {
                <div class="deploy-card">
                    <div class="deploy-header">
                        <span class="deploy-model">@task.ModelName</span>
                        <span class="deploy-status @GetTaskStatusClass(task.Status)">@GetTaskStatusLabel(task.Status)</span>
                    </div>
                    <div class="deploy-progress">
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @task.ProgressPercent%"></div>
                        </div>
                        <span class="progress-text">@task.ProgressPercent%</span>
                    </div>
                    <div class="deploy-step">@task.CurrentStep</div>
                    <div class="deploy-logs">
                        @foreach (var log in task.Logs.TakeLast(5))
                        {
                            <div class="log-line">@log</div>
                        }
                    </div>
                    @if (task.Status == "running")
                    {
                        <button class="btn btn-danger btn-sm" @onclick="() => CancelDeploy(task.TaskId)">取消</button>
                    }
                    @if (task.Status == "completed" && task.AutoConfiguredProvider)
                    {
                        <div class="deploy-success">
                            ✅ 已自动添加到 <a href="settings">AI 设置</a>
                        </div>
                    }
                </div>
            }
        </div>
    }
    }
}

<style>
    .loading-spinner {
        padding: 2rem;
        text-align: center;
        color: #666;
    }

    .hardware-section, .tools-section, .scenario-section, .deploy-section {
        margin-bottom: 2rem;
    }

    .hardware-section h2, .tools-section h2, .scenario-section h2, .deploy-section h2 {
        font-size: 1.2rem;
        margin-bottom: 1rem;
        color: #333;
    }

    .hardware-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .hw-card {
        background: #f5f8fa;
        border: 1px solid #e8eef2;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
    }

    .hw-icon {
        font-size: 1.8rem;
        margin-bottom: 0.3rem;
    }

    .hw-title {
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 0.3rem;
    }

    .hw-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 0.2rem;
        word-break: break-word;
    }

    .hw-detail {
        font-size: 0.8rem;
        color: #888;
    }

    .tools-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .tool-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: #f5f8fa;
        border: 1px solid #e8eef2;
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
    }

    .tool-name {
        font-weight: 500;
        font-size: 0.9rem;
    }

    .link-small {
        font-size: 0.8rem;
        color: #2e8baf;
        text-decoration: none;
    }

    .link-small:hover {
        text-decoration: underline;
    }

    .scenario-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }

    .scenario-header h2 {
        margin-bottom: 0;
    }

    .scenario-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .scenario-tag {
        padding: 0.4rem 1rem;
        border: 1px solid #d8e2e8;
        border-radius: 20px;
        background: white;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .scenario-tag:hover {
        background: #f5f8fa;
    }

    .scenario-tag.active {
        background: #2e8baf;
        color: white;
        border-color: #2e8baf;
    }

    .models-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .model-card {
        background: white;
        border: 1px solid #e8eef2;
        border-radius: 10px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .model-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .model-name {
        font-weight: 600;
        font-size: 1rem;
        color: #333;
    }

    .model-size {
        font-size: 0.85rem;
        color: #666;
        background: #e8eef2;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
    }

    .model-desc {
        font-size: 0.85rem;
        color: #555;
        line-height: 1.4;
    }

    .model-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .model-download-status {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .model-requirements {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: #666;
    }

    .model-suitability {
        font-size: 0.85rem;
        padding: 0.3rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
    }

    .suitability-good {
        background: #e0f0e5;
        color: #3d6b45;
    }

    .suitability-ok {
        background: #f5eee0;
        color: #6a5a3a;
    }

    .suitability-slow {
        background: #e0ecf4;
        color: #4a2a30;
    }

    .model-performance {
        font-size: 0.85rem;
    }

    .speed-badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.8rem;
    }

    .speed-fast {
        background: #e0f0e5;
        color: #3d6b45;
    }

    .speed-medium {
        background: #f5eee0;
        color: #6a5a3a;
    }

    .speed-slow {
        background: #ffe5cc;
        color: #804000;
    }

    .speed-very-slow {
        background: #e0ecf4;
        color: #4a2a30;
    }

    /* 显存档位分组 */
    .tier-group {
        margin-bottom: 1.5rem;
        border: 1px solid #e8eef2;
        border-radius: 10px;
        background: #fff;
        overflow: hidden;
    }

    .tier-group.tier-recommended {
        border-color: #6b9e75;
        box-shadow: 0 0 0 1px #6b9e7520;
    }

    .tier-group-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: #f5f8fa;
        border-bottom: 1px solid #e8eef2;
    }

    .tier-group.tier-recommended .tier-group-header {
        background: #e0f0e5;
    }

    .tier-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
