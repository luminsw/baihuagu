@page "/local-models"
@rendermode InteractiveServer
@using TaskRunner.Contracts.LocalModels
@using TaskRunner.Contracts.OpenClaw
@using TaskRunner.Contracts.Benchmark
@inject WebUI.Services.IApiService ApiService
@inject WebUI.Services.AIStatusService AIStatusService
@inject WebUI.Hubs.StatusUpdateService StatusUpdateService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Logging.ILogger<LocalModels> Logger
@implements IDisposable

<PageTitle>本地模型</PageTitle>

<h1>🖥️ 本地模型部署</h1>

<!-- Tab 导航 -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "overview" ? "active" : "")" @onclick='async () => await OnTabChanged("overview")'>📊 概览</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "ollama" ? "active" : "")" @onclick='async () => await OnTabChanged("ollama")'>🦙 Ollama</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "lmstudio" ? "active" : "")" @onclick='async () => await OnTabChanged("lmstudio")'>💜 LM Studio</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "llamacpp" ? "active" : "")" @onclick='async () => await OnTabChanged("llamacpp")'>⚡ llama.cpp</button>
    </li>
</ul>


@if (isLoading)
{
    <div class="loading-spinner">加载中...</div>
}
else
{
    <!-- 硬件概览 -->
    @if (_activeTab == "overview")
    {
    <!-- 硬件概览 -->
    <div class="hardware-section">
        <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showHardware)">
            <h2>@(_showHardware ? "▼" : "▶") 硬件环境</h2>
        </div>
        @if (_showHardware)
        {
        <div class="hardware-cards">
            <div class="hw-card">
                <div class="hw-icon">🖥️</div>
                <div class="hw-title">CPU</div>
                <div class="hw-value">@(hardwareInfo?.Cpu.Name ?? "检测中...")</div>
                <div class="hw-detail">@(hardwareInfo?.Cpu.LogicalProcessorCount ?? 0) 核 @(hardwareInfo?.Cpu.Architecture ?? "")</div>
            </div>
            <div class="hw-card">
                <div class="hw-icon">🧠</div>
                <div class="hw-title">内存</div>
                <div class="hw-value">@(hardwareInfo?.Memory.TotalGiB.ToString("F1") ?? "-") GB</div>
                <div class="hw-detail">可用: @(hardwareInfo?.Memory.AvailableGiB.ToString("F1") ?? "-") GB</div>
            </div>
            <div class="hw-card">
                <div class="hw-icon">🎮</div>
                <div class="hw-title">显卡</div>
                @if (hardwareInfo?.Gpus?.Count > 0)
                {
                    @foreach (var gpu in hardwareInfo.Gpus)
                    {
                        <div class="hw-value">@gpu.Name</div>
                        <div class="hw-detail">
                            @(gpu.VramGiB.HasValue ? $"{gpu.VramGiB:F1} GB" : "显存未知")
                            @(gpu.IsIntegrated ? "(集成)" : "")
                            @(gpu.IsAppleSilicon ? "(统一内存)" : "")
                        </div>
                    }
                }
                else
                {
                    <div class="hw-value">未检测到</div>
                    <div class="hw-detail">将使用 CPU 运行</div>
                }
            </div>
            <div class="hw-card">
                <div class="hw-icon">💾</div>
                <div class="hw-title">磁盘</div>
                <div class="hw-value">@(GetDiskGiB(hardwareInfo?.AvailableDiskSpaceBytes) ?? "-") GB</div>
                <div class="hw-detail">可用空间</div>
            </div>
        </div>
        <button class="btn btn-secondary btn-sm" @onclick="RefreshHardware">🔄 刷新硬件信息</button>
        }
    </div>

    <!-- 运行中模型 -->
    <div class="running-section">
        <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showRunningModels)">
            <h2>@(_showRunningModels ? "▼" : "▶") ▶️ 运行中模型</h2>
            <button class="btn btn-secondary btn-sm" @onclick="RefreshRunningModels" @onclick:stopPropagation>🔄 刷新</button>
        </div>
        @if (_showRunningModels)
        {
            @if (runningModels.Count == 0)
            {
                <div class="alert alert-info">暂无运行中模型。下方推荐列表可部署新模型，或使用"加载模型"加载已下载的模型。</div>
            }
            else
            {
                <div class="running-models-table">
                    <div class="running-table-header">
                        <span class="col-model">模型</span>
                        <span class="col-tool">工具</span>
                        <span class="col-mem">内存占用</span>
                        <span class="col-expires">过期时间</span>
                        <span class="col-actions">操作</span>
                    </div>
                    @foreach (var rm in runningModels)
                    {
                        <div class="running-table-row">
                            <span class="col-model">
                                <span class="model-name-text">@rm.DisplayName</span>
                                @if (!string.IsNullOrEmpty(rm.Family))
                                {
                                    <span class="badge badge-light">@rm.Family</span>
                                }
                            </span>
                            <span class="col-tool">
                                <span class="tool-badge @GetToolBadgeClass(rm.ToolId)">@rm.ToolName</span>
                            </span>
                            <span class="col-mem">
                                @if (rm.VramGiB.HasValue && rm.VramGiB.Value > 0)
                                {
                                    <span>VRAM @rm.VramGiB.Value.ToString("F1") GB</span>
                                }
                                else
                                {
                                    <span>~@rm.SizeGiB.ToString("F1") GB</span>
                                }
                                <div class="mem-bar">
                                    <div class="mem-fill" style="width: @(Math.Min(100, (int)((rm.SizeBytes / (double)(hardwareInfo?.Memory.TotalBytes ?? 1)) * 100)))%"></div>
                                </div>
                            </span>
                            <span class="col-expires">
                                @if (rm.ExpiresAt.HasValue)
                                {
                                    <span title="@rm.ExpiresAt.Value.ToString("yyyy-MM-dd HH:mm:ss")">@GetTimeRemaining(rm.ExpiresAt.Value)</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </span>
                            <span class="col-actions">
                                <button class="btn btn-danger btn-sm" @onclick='() => UnloadModel(rm)' disabled="@isLoadingModel">
                                    ⏹ 卸载
                                </button>
                            </span>
                        </div>
                    }
                </div>
                <div class="memory-summary">
                    共 @runningModels.Count 个模型在运行，总内存占用约 @(runningModels.Sum(m => m.SizeGiB).ToString("F1")) GB
                </div>
            }
        }
    </div>

    }

    @if (_activeTab == "ollama")
    {
    <!-- 已下载模型 -->
    <div class="downloaded-section">
        <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showDownloadedModels)">
            <h2>@(_showDownloadedModels ? "▼" : "▶") 🦙 Ollama 已下载模型</h2>
            @if (_showDownloadedModels)
            {
                <button class="btn btn-secondary btn-sm" @onclick="RefreshDownloadedModels" @onclick:stopPropagation disabled="@isLoadingDownloaded">
                    @(isLoadingDownloaded ? "🔄 刷新中..." : "🔄 刷新")
                </button>
            }
        </div>
        @if (_showDownloadedModels)
        {
        @if (downloadedModels.Count == 0)
        {
            <div class="alert alert-info">暂无已下载模型。上方推荐列表可部署新模型。</div>
        }
        else
        {
            <div class="downloaded-models-table">
                <div class="downloaded-table-header">
                    <span class="col-dl-name">模型</span>
                    <span class="col-dl-tool">工具</span>
                    <span class="col-dl-size">大小</span>
                    <span class="col-dl-time">修改时间</span>
                    <span class="col-dl-status">状态</span>
                    <span class="col-dl-actions">操作</span>
                </div>
                @foreach (var dm in downloadedModels.Where(m => m.ToolId == "ollama"))
                {
                    <div class="downloaded-table-row">
                        <span class="col-dl-name">
                            <span class="model-name-text">@dm.Name</span>
                            @if (!string.IsNullOrEmpty(dm.Digest))
                            {
                                <span class="digest-text" title="@dm.Digest">@dm.Digest[..Math.Min(12, dm.Digest.Length)]...</span>
                            }
                        </span>
                        <span class="col-dl-tool">
                            <span class="tool-badge @GetToolBadgeClass(dm.ToolId)">@dm.ToolName</span>
                        </span>
                        <span class="col-dl-size">@dm.SizeGiB GB</span>
                        <span class="col-dl-time">
                            @(dm.ModifiedAt.HasValue ? dm.ModifiedAt.Value.ToString("yyyy-MM-dd HH:mm") : "-")
                        </span>
                        <span class="col-dl-status">
                            @if (dm.IsRunning)
                            {
                                <span class="badge badge-info">▶ 运行中</span>
                            }
                            else
                            {
                                <span class="badge badge-light">⏹ 已停止</span>
                            }
                        </span>
                        <span class="col-dl-actions">
                            <button class="btn btn-primary btn-sm" @onclick='() => LoadDownloadedModel(dm)' disabled="@isLoadingModel">
                                加载
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick='() => ShowModelDetails(dm)' disabled="@isLoadingDetails">
                                详情
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick='() => DeleteModel(dm)' disabled="@isLoadingModel">
                                删除
                            </button>
                        </span>
                    </div>
                }
            </div>
            <div class="memory-summary">
                共 @downloadedModels.Count 个模型，总大小约 @(downloadedModels.Sum(m => m.SizeGiB).ToString("F1")) GB
            </div>
        }
        @if (!string.IsNullOrEmpty(downloadedModelMessage))
        {
            <div class="load-message @(downloadedModelSuccess ? "text-success" : "text-error")" style="margin-top:0.5rem;">
                @downloadedModelMessage
            </div>
        }
        }
    </div>
    }

