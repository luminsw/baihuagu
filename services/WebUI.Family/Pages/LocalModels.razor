    @if (_activeTab == "ollama")
    {
    <!-- 加载模型 -->
    <div class="load-model-section">
        <div class="section-header" style="cursor:pointer;" @onclick="() => ToggleSection(ref _showLoadModel)">
            <h3>@(_showLoadModel ? "▼" : "▶") 📥 加载 Ollama 模型</h3>
        </div>
        @if (_showLoadModel)
        {
        <div class="load-model-form">
            <div class="form-row">
                <div class="form-group">
                    <label>模型</label>
                    <select class="form-control" @bind="loadModelName" disabled="@string.IsNullOrEmpty(loadToolId)">
                        <option value="">-- 选择模型 --</option>
                        @foreach (var name in availableModelsForLoad)
                        {
                            <option value="@name">@name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>保持时间</label>
                    <div class="btn-group btn-group-sm" role="group">
                        <button type="button" class="btn @(loadKeepAliveMinutes == 5 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => loadKeepAliveMinutes = 5)">5分</button>
                        <button type="button" class="btn @(loadKeepAliveMinutes == 30 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => loadKeepAliveMinutes = 30)">30分</button>
                        <button type="button" class="btn @(loadKeepAliveMinutes == 60 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => loadKeepAliveMinutes = 60)">1时</button>
                        <button type="button" class="btn @(loadKeepAliveMinutes == 360 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => loadKeepAliveMinutes = 360)">6时</button>
                        <button type="button" class="btn @(loadKeepAliveMinutes == -1 ? "btn-primary" : "btn-outline-primary")" @onclick="@(() => loadKeepAliveMinutes = -1)">永久</button>
                    </div>
                </div>
            </div>
            <button class="btn btn-primary" @onclick="LoadSelectedModel" disabled="@(!CanLoadModel())">
                @(isLoadingModel ? "加载中..." : "🚀 加载模型")
            </button>
            @if (!string.IsNullOrEmpty(loadModelMessage))
            {
                <span class="load-message @(loadModelSuccess ? "text-success" : "text-error")">@loadModelMessage</span>
            }
        </div>
        }
    </div>
    }

