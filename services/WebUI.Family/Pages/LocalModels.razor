            localTools = await ApiService.GetLocalToolsAsync(forceRefresh: true);
            await LoadRecommendationsAsync(forceRefresh: true);
            await RefreshRunningModels();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "刷新硬件信息失败");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SelectScenario(string scenario)
    {
        currentScenario = scenario;
        await LoadRecommendationsAsync();
    }

    private void SelectCompany(string company)
    {
        currentCompany = company;
        StateHasChanged();
    }

    private List<RecommendedModelDto> FilteredRecommendedModels =>
        string.IsNullOrEmpty(currentCompany)
            ? recommendedModels
            : recommendedModels.Where(m => m.Company == currentCompany).ToList();

    private Dictionary<int, List<RecommendedModelDto>> FilteredModelsByTier =>
        FilteredRecommendedModels
            .GroupBy(m => GetVramTierForModel(m))
            .Where(g => g.Key > 0)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(m => m.MatchScore).ToList());

    private static int GetVramTierForModel(RecommendedModelDto model)
    {
        if (!model.MinVramGiB.HasValue) return 4;
        var vram = model.MinVramGiB.Value;
        foreach (var tier in VramTierValues)
        {
            if (vram <= tier) return tier;
        }
        return VramTierValues.Last();
    }

    private RenderFragment RenderModelCard(RecommendedModelDto model) => __builder =>
    {
        <div class="model-card">
            <div class="model-header">
                <span class="model-name">@model.Name</span>
                <span class="model-size">@model.SizeGiB GB</span>
            </div>
            <div class="model-desc">@model.Description</div>
            <div class="model-meta">
                <span class="badge badge-secondary">@model.ParameterSize</span>
                <span class="badge badge-info">@model.Quantization</span>
                @foreach (var tag in model.Tags)
                {
                    <span class="badge badge-light">@tag</span>
                }
                <span class="badge" style="background:#e8eef2;color:#4a5860;">@model.Company</span>
            </div>
            <div class="model-download-status">
                @if (model.IsDownloadedOllama)
                {
                    <span class="badge badge-success" title="已在 Ollama 中下载">📦 Ollama</span>
                }
                @if (model.IsDownloadedLmStudio)
                {
                    <span class="badge badge-info" title="已在 LM Studio 中下载">📦 LM Studio</span>
                }
                @if (model.IsDownloadedLlamaCpp)
                {
                    <span class="badge badge-warning" title="已在 llama.cpp 中可用">📦 llama.cpp</span>
                }
            </div>
            <div class="model-requirements">
                <span>@(model.MinVramGiB.HasValue ? $"显存: {model.MinVramGiB:F0}GB+" : "显存: 无要求")</span>
                <span>内存: @model.MinRamGiB.ToString("F0")GB+</span>
            </div>
            <div class="model-suitability @(GetSuitabilityClass(model.Suitability))">
                @model.Suitability
                @if (model.MatchScore >= 90)
                {
                    <span> ⭐ 推荐</span>
                }
            </div>
            @if (model.EstimatedTokensPerSecond.HasValue)
            {
                <div class="model-performance">
                    <span class="speed-badge @(GetSpeedClass(model.EstimatedTokensPerSecond.Value))"
                          title="基于当前硬件的估算速度，仅供参考">
                        @GetSpeedLabel(model.EstimatedTokensPerSecond.Value)
                    </span>
                </div>
            }
            <div class="model-actions">
                <button class="btn btn-primary btn-sm" @onclick='() => DeployModel(model, "ollama")'
                        disabled="@isDeploying">
                    部署到 Ollama
                </button>
                <button class="btn btn-secondary btn-sm" @onclick='() => DeployModel(model, "lmstudio")'
                        disabled="@isDeploying">
                    部署到 LM Studio
                </button>
            </div>
        </div>
    };

    private async Task RefreshLibrary()
    {
        isRefreshingLibrary = true;
        try
        {
            var success = await ApiService.RefreshLibraryAsync();
            if (success)
            {
                await LoadRecommendationsAsync(forceRefresh: true);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "刷新模型库失败");
        }
        finally
        {
            isRefreshingLibrary = false;
        }
    }

    private async Task DeployModel(RecommendedModelDto model, string targetTool)
    {
        isDeploying = true;
        try
        {
            var result = await ApiService.DeployLocalModelAsync(new DeployLocalModelRequest
            {
                ModelId = model.Id,
                TargetTool = targetTool
            });

            if (result.Success)
            {
                // 开始轮询任务状态
                _ = StartTaskPolling(result.TaskId);
            }
            else
            {
                Logger.LogWarning("部署启动失败: {Message}", result.Message);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "部署异常");
        }
        finally
        {
            isDeploying = false;
        }
    }

    private async Task StartTaskPolling(string taskId)
    {
        // 立即刷新一次
        await RefreshTaskStatus(taskId);

        // 轮询 30 秒或直到完成
        for (int i = 0; i < 120; i++)
        {
            await Task.Delay(3000);
            var done = await RefreshTaskStatus(taskId);
            if (done) break;
        }
    }

    private async Task<bool> RefreshTaskStatus(string taskId)
    {
        var status = await ApiService.GetDeployTaskStatusAsync(taskId);
        if (status == null) return true;

        var existing = activeTasks.FirstOrDefault(t => t.TaskId == taskId);
        if (existing != null)
        {
            var idx = activeTasks.IndexOf(existing);
            activeTasks[idx] = status;
        }
        else
        {
            activeTasks.Add(status);
        }

        await InvokeAsync(StateHasChanged);
        return status.Status is "completed" or "failed";
    }

    private async Task CancelDeploy(string taskId)
    {
        var success = await ApiService.CancelDeployTaskAsync(taskId);
        if (success)
        {
            activeTasks.RemoveAll(t => t.TaskId == taskId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartStatusPolling()
    {
        _statusTimer = new System.Timers.Timer(5000);
        _statusTimer.Elapsed += async (_, _) =>
        {
            if (activeTasks.Any(t => t.Status == "running"))
            {
                foreach (var task in activeTasks.Where(t => t.Status == "running").ToList())
                {
                    await RefreshTaskStatus(task.TaskId);
                }
            }
        };
        _statusTimer.AutoReset = true;
        _statusTimer.Start();
    }

    private static string? GetDiskGiB(long? bytes)
    {
        if (!bytes.HasValue || bytes.Value <= 0) return null;
        return (bytes.Value / (1024.0 * 1024 * 1024)).ToString("F1");
    }

    private static string GetToolBadgeClass(string toolId)
    {
        return toolId switch
        {
            "ollama" => "tool-ollama",
            "lmstudio" => "tool-lmstudio",
            "llamacpp" => "tool-llamacpp",
            _ => ""
        };
    }

    private static string GetSuitabilityClass(string suitability)
    {
        if (suitability.Contains("加速") || suitability.Contains("推荐") || suitability.Contains("可直接"))
            return "suitability-good";
        if (suitability.Contains("混合") || suitability.Contains("较慢"))
            return "suitability-ok";
        return "suitability-slow";
    }

    private static string GetSpeedClass(double tps)
    {
        return tps switch
        {
            >= 30 => "speed-fast",
            >= 10 => "speed-medium",
            >= 3 => "speed-slow",
            _ => "speed-very-slow"
        };
    }

    private static string GetSpeedLabel(double tps)
    {
        return tps switch
        {
            >= 30 => $"🚀 约 {tps:F0} tok/s",
            >= 10 => $"⚡ 约 {tps:F0} tok/s",
            >= 3 => $"🐢 约 {tps:F0} tok/s",
            _ => $"🐌 约 {tps:F0} tok/s"
        };
    }

    private static string GetTaskStatusClass(string status)
    {
        return status switch
        {
            "running" => "status-running",
            "completed" => "status-completed",
            "failed" => "status-failed",
            _ => ""
        };
    }

    private static string GetTaskStatusLabel(string status)
    {
        return status switch
        {
            "pending" => "等待中",
            "running" => "进行中",
            "completed" => "已完成",
            "failed" => "失败",
            _ => status
        };
    }

    #region 运行中模型管理

    private List<RunningModelDto> runningModels = new();
    private string loadToolId = "";
    private string loadModelName = "";
    private int loadKeepAliveMinutes = 5;
    private List<string> availableModelsForLoad = new();
    private bool isLoadingModel = false;
    private string loadModelMessage = "";
    private bool loadModelSuccess = false;

    // 已下载模型管理
    private List<DownloadedModelDto> downloadedModels = new();
    private bool isLoadingDownloaded = false;
    private string downloadedModelMessage = "";
    private bool downloadedModelSuccess = false;

    // 删除确认
    private bool showDeleteConfirm = false;
    private DownloadedModelDto? modelToDelete = null;

    // 详情弹窗
    private bool showDetailsModal = false;
    private ModelDetailsDto? modelDetails = null;
    private bool isLoadingDetails = false;

    private async Task RefreshRunningModels()
    {
        runningModels = await ApiService.GetRunningModelsAsync(forceRefresh: true);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshDownloadedModels()
    {
        isLoadingDownloaded = true;
        downloadedModelMessage = "";
        try
        {
            downloadedModels = await ApiService.GetDownloadedModelsAsync();
        }
        catch (Exception ex)
        {
            downloadedModelMessage = $"刷新已下载模型失败: {ex.Message}";
            downloadedModelSuccess = false;
        }
        finally
        {
            isLoadingDownloaded = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDownloadedModel(DownloadedModelDto model)
    {
        loadToolId = model.ToolId;
        loadModelName = model.Name;
        loadKeepAliveMinutes = 5;
        await LoadSelectedModel();
    }

    private void DeleteModel(DownloadedModelDto model)
    {
        modelToDelete = model;
        showDeleteConfirm = true;
        downloadedModelMessage = "";
    }

    private void CancelDeleteModel()
    {
        showDeleteConfirm = false;
        modelToDelete = null;
    }

    private async Task ConfirmDeleteModel()
    {
        if (modelToDelete == null) return;
        isLoadingModel = true;
        downloadedModelMessage = "";
        try
        {
            var success = await ApiService.DeleteModelAsync(new DeleteModelRequest
            {
                ToolId = modelToDelete.ToolId,
                ModelName = modelToDelete.Name
            });

            if (success)
            {
                downloadedModelMessage = $"✅ {modelToDelete.Name} 已删除";
                downloadedModelSuccess = true;
                showDeleteConfirm = false;
                modelToDelete = null;
                await RefreshDownloadedModels();
                await RefreshRunningModels();
            }
            else
            {
                downloadedModelMessage = $"❌ 删除失败，请检查工具是否运行";
                downloadedModelSuccess = false;
            }
        }
        catch (Exception ex)
        {
            downloadedModelMessage = $"删除异常: {ex.Message}";
            downloadedModelSuccess = false;
        }
        finally
        {
            isLoadingModel = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowModelDetails(DownloadedModelDto model)
    {
        showDetailsModal = true;
        isLoadingDetails = true;
        modelDetails = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            modelDetails = await ApiService.GetModelDetailsAsync(new ModelDetailsRequest
            {
                ToolId = model.ToolId,
                ModelName = model.Name
            });
        }
        catch
        {
            modelDetails = new ModelDetailsDto
            {
                Name = model.Name,
                ToolId = model.ToolId,
            };
        }
        finally
        {
            isLoadingDetails = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        modelDetails = null;
    }

    private async Task UnloadModel(RunningModelDto model)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"确定要卸载模型 {model.DisplayName} 吗？正在使用该模型的任务将被中断。"))
            return;
        isLoadingModel = true;
        loadModelMessage = "";
        try
        {
            var success = await ApiService.UnloadModelAsync(new UnloadModelRequest
            {
                ToolId = model.ToolId,
                ModelName = model.ModelName
            });

            if (success)
            {
                loadModelMessage = $"✅ {model.DisplayName} 已卸载";
                loadModelSuccess = true;
                await Task.Delay(500);
                await RefreshRunningModels();
            }
            else
            {
                loadModelMessage = $"❌ 卸载 {model.DisplayName} 失败";
                loadModelSuccess = false;
            }
        }
        catch (Exception ex)
        {
            loadModelMessage = $"卸载异常: {ex.Message}";
            loadModelSuccess = false;
        }
        finally
        {
            isLoadingModel = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnLoadToolChanged()
    {
        loadModelName = "";
        availableModelsForLoad.Clear();
        if (!string.IsNullOrEmpty(loadToolId))
        {
            availableModelsForLoad = await ApiService.GetAvailableModelsAsync(loadToolId);
        }
        await InvokeAsync(StateHasChanged);
    }

    private bool CanLoadModel()
    {
        return !string.IsNullOrEmpty(loadToolId) && !string.IsNullOrEmpty(loadModelName) && !isLoadingModel;
    }

    private async Task LoadSelectedModel()
    {
        isLoadingModel = true;
        loadModelMessage = "";
        try
        {
            var success = await ApiService.LoadModelAsync(new LoadModelRequest
            {
                ToolId = loadToolId,
                ModelName = loadModelName,
                KeepAliveMinutes = loadKeepAliveMinutes
            });

            if (success)
            {
                loadModelMessage = $"✅ {loadModelName} 已加载";
                loadModelSuccess = true;
                await Task.Delay(500);
                await RefreshRunningModels();
            }
            else
            {
                loadModelMessage = $"❌ 加载 {loadModelName} 失败，请检查工具是否运行";
                loadModelSuccess = false;
            }
        }
        catch (Exception ex)
        {
            loadModelMessage = $"加载异常: {ex.Message}";
            loadModelSuccess = false;
        }
        finally
        {
            isLoadingModel = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetTimeRemaining(DateTime expiresAt)
    {
        var remaining = expiresAt - DateTime.Now;
        if (remaining.TotalSeconds <= 0) return "即将过期";
        if (remaining.TotalHours >= 1) return $"{remaining.TotalHours:F0}小时后过期";
        if (remaining.TotalMinutes >= 1) return $"{remaining.TotalMinutes:F0}分钟后过期";
        return "即将过期";
    }

    #endregion

    public void Dispose()
    {
        _statusTimer?.Stop();
        _statusTimer?.Dispose();
    }

    private async Task OnTabChanged(string tab)
    {
        _activeTab = tab;
        if (tab == "ollama" || tab == "lmstudio" || tab == "llamacpp")
        {
            loadToolId = tab;
            await OnLoadToolChanged();
        }
        await InvokeAsync(StateHasChanged);
    }
