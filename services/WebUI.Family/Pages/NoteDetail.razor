@page "/note"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Logging.ILogger<NoteDetail> Logger
@inject WebUI.Services.IRecentNotesService RecentNotesService
@inject WebUI.Services.IFavoritesService FavoritesService
@inject WebUI.Services.IUserPreferencesService UserPreferencesService
@inject WebUI.Services.SearchStateService SearchStateService
@using WebUI.Services
@inject IApiService ApiService
@inject WebUI.Services.VaultsService VaultsService
@inject Microsoft.JSInterop.IJSRuntime JS
@using Markdig
@using Microsoft.JSInterop

<PageTitle>笔记详情</PageTitle>

@if (isLoading)
{
    <div class="loading">
        <div class="spinner"></div>
        <span>加载中...</span>
    </div>
}
else if (note == null && !string.IsNullOrEmpty(noteId))
{
    <div class="error-message">
        <h1>❌ 笔记未找到</h1>
        <p>无法找到路径为 "@noteId" 的笔记</p>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
            <button @onclick="GoBack" class="btn btn-secondary">返回搜索</button>
            @if (isGeneratingMissingNote)
            {
                <button disabled class="btn btn-primary">
                    <span class="spinner" style="display:inline-block; width:16px; height:16px; border-width:2px; vertical-align:middle;"></span>
                    AI 生成中...
                </button>
                <p style="color: #888; font-size: 0.85rem; margin-top: 0.5rem; width: 100%;">
                    AI 正在生成笔记，预计需要 10-30 秒，请稍候...
                </p>
            }
            else
            {
                <button @onclick="GenerateMissingNote" class="btn btn-primary">✨ AI 生成此笔记</button>
            }
        </div>
        @if (!string.IsNullOrEmpty(generateMessage))
        {
            <div class="alert @(generateSuccess ? "alert-success" : "alert-danger")" style="margin-top: 1rem; padding: 0.75rem; border-radius: 4px;">
                @generateMessage
            </div>
        }
    </div>
}
else if (note != null)
{
    <div class="note-detail">
        @* 面包屑导航 *@
        <div class="breadcrumb">
            <a href="" @onclick:preventDefault @onclick="GoHome" class="breadcrumb-item">🏠 首页</a>
            <span class="breadcrumb-separator">/</span>
            <a href="search" class="breadcrumb-item">🔍 搜索</a>
            <span class="breadcrumb-separator">/</span>
            @if (!string.IsNullOrEmpty(note?.Path))
            {
                var pathParts = note.Path.Split('/');
                for (var i = 0; i < pathParts.Length - 1; i++)
                {
                    var category = string.Join("/", pathParts.Take(i + 1));
                    <a href="search?q=@category" class="breadcrumb-item">@pathParts[i]</a>
                    <span class="breadcrumb-separator">/</span>
                }
            }
            <span class="breadcrumb-current">@note?.Title</span>
        </div>

            <div class="note-header">
                <button @onclick="GoBack" class="btn btn-link">← 返回</button>
                <div class="note-actions">
                <button @onclick="ToggleFavorite" class="btn @(isFavorite ? "btn-warning" : "btn-outline-warning")">
                    <span>@(isFavorite ? "⭐" : "☆")</span> @(isFavorite ? "已收藏" : "收藏")
                </button>
                <button @onclick="EditNote" class="btn btn-secondary">
                    <span>✏️</span> @(isEditing ? "取消编辑" : "编辑")
                </button>
            </div>
        </div>

        <div class="note-content-card">
            <h1 class="note-title">@note?.Title</h1>
            
            @if (note == null || string.IsNullOrEmpty(note.Content))
            {
                <div class="alert alert-warning" style="background: #f5eee0; border: 1px solid #d4a574; padding: 1rem; border-radius: 4px; margin: 1rem 0;">
                    <strong>⚠️ 注意：</strong> 笔记内容为空或笔记不存在
                    <br/>
                    <small>路径：@noteId</small>
                </div>
            }
            
            <div class="note-meta">
                <span class="meta-item">📁 @note?.Path</span>
                <span class="meta-item">📅 @note?.Modified.ToString("yyyy-MM-dd HH:mm")</span>
            </div>

            @if (isEditing)
            {
                <div class="note-edit-form">
                    <div class="form-group">
                        <label for="editContent">笔记内容</label>
                        <textarea id="editContent" 
                                  @bind="editContent"
                                  class="form-control" 
                                  rows="15"
                                  style="font-size: @(fontSize)px; line-height: 1.8; font-family: monospace;">
                        </textarea>
                    </div>
                    <div class="edit-actions">
                        <button @onclick="SaveNote" class="btn btn-primary" disabled="@string.IsNullOrWhiteSpace(editContent)">
                            💾 保存
                        </button>
                        <button @onclick="CancelEdit" class="btn btn-secondary">
                            ❌ 取消
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="note-body" style="font-size: @(fontSize)px; line-height: 1.8;">
                    @if (!string.IsNullOrEmpty(note?.Content))
                    {
                        var htmlContent = RenderMarkdownWithWikiLinks(note.Content);
                        @((MarkupString)htmlContent)
                    }
                    else
                    {
                        <p><em>（无内容）</em></p>
                    }
                </div>
            }

            @if (note?.Tags != null && note.Tags.Any())
            {
                <div class="note-tags">
                    @foreach (var tag in note.Tags)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <h1>📝 笔记详情</h1>
        <p>请从搜索结果中选择一个笔记</p>
        <button @onclick="GoToSearch" class="btn btn-primary">去搜索</button>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "id")]
    public string? id { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "vaultId")]
    public string? vaultId { get; set; }

    private string noteId = "";
    private string selectedVaultId = "";
    private string noteVaultId = "";
    private NoteInfo? note;
    private bool isLoading = false;
    private bool isFavorite = false;
    private double fontSize = 16.0;
    private bool isEditing = false;
    private string editContent = "";
    private bool isGeneratingMissingNote = false;
    private string generateMessage = "";
    private bool generateSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        // 加载字体大小偏好
        fontSize = await UserPreferencesService.GetFontSize();

        // 从查询参数获取路径，如：/note?id=方剂/桂枝汤
        if (!string.IsNullOrEmpty(id))
        {
            noteId = Uri.UnescapeDataString(id).Trim('/');
            Logger.LogInformation("加载笔记：{NoteId}", noteId);

            // 优先使用 URL 中指定的知识库
            if (!string.IsNullOrEmpty(vaultId))
            {
                selectedVaultId = vaultId;
                noteVaultId = vaultId;
                await LoadNote();
            }
            else
            {
                // 未指定知识库时，遍历所有知识库查找笔记
                await LoadNoteFromAnyVault();
            }
        }
        else
        {
            Logger.LogWarning("未提供笔记 ID");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && note != null)
        {
            // 检查是否已收藏
            isFavorite = await FavoritesService.IsFavorite(note.Path);
            StateHasChanged();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task LoadNote()
    {
        isLoading = true;
        try
        {
            note = await LoadNoteFromPath(selectedVaultId);

            if (note == null)
            {
                Logger.LogWarning("笔记未找到：{NoteId}", noteId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "加载失败：{NoteId}", noteId);
            note = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadNoteFromAnyVault()
    {
        isLoading = true;
        try
        {
            var vaultsResponse = await VaultsService.GetVaultsAsync();
            foreach (var vault in vaultsResponse.Vaults)
            {
                var found = await LoadNoteFromPath(vault.Id);
                if (found != null)
                {
                    selectedVaultId = vault.Id;
                    noteVaultId = vault.Id;
                    note = found;
                    Logger.LogInformation("笔记在知识库 {VaultName}({VaultId}) 中找到", vault.Name, vault.Id);
                    return;
                }
            }
            Logger.LogWarning("笔记在所有知识库中均未找到：{NoteId}", noteId);
            note = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "遍历知识库加载失败：{NoteId}", noteId);
            note = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<NoteInfo?> LoadNoteFromPath(string vaultIdToUse)
    {
        if (string.IsNullOrWhiteSpace(vaultIdToUse))
        {
            Logger.LogWarning("未选择知识库，无法加载笔记：{NoteId}", noteId);
            return null;
        }

        try
        {
            var vaultNote = await ApiService.ReadVaultNoteAsync(noteId, vaultIdToUse);
            if (vaultNote == null)
            {
                Logger.LogWarning("笔记未找到：{NoteId}", noteId);
                return null;
            }

            var title = vaultNote.Title;
            var noteInfo = new NoteInfo
            {
                Id = vaultNote.Path,
                Title = title,
                Path = vaultNote.Path,
                Content = vaultNote.Content,
                Modified = vaultNote.Modified,
                Tags = vaultNote.Tags?.ToArray() ?? Array.Empty<string>()
            };

            // 记录到最近浏览
            _ = RecentNotesService.AddRecentNote(noteInfo.Path, title);
            return noteInfo;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "读取失败：{NoteId}", noteId);
            return null;
        }
    }

    private async Task<NoteInfo> CreateNoteInfo(string filePath, string path)
    {
        var content = await System.IO.File.ReadAllTextAsync(filePath);
        var title = System.IO.Path.GetFileNameWithoutExtension(path);
        
        var noteInfo = new NoteInfo
        {
            Id = path,
            Title = title,
            Path = path,
            Content = content,
            Modified = System.IO.File.GetLastWriteTime(filePath),
            Tags = Array.Empty<string>()
        };

        // 记录到最近浏览
        _ = RecentNotesService.AddRecentNote(path, title);

        return noteInfo;
    }

    private async Task GoBack()
    {
        // 使用浏览器历史返回，保持用户的导航预期
        await JS.InvokeVoidAsync("history.back");
    }

    private void GoHome()
    {
        Navigation.NavigateTo("");
    }

    private async Task GoToSearch()
    {
        // 如果有搜索状态，使用浏览器返回；否则直接跳转搜索页
        if (SearchStateService.HasState)
        {
            await JS.InvokeVoidAsync("history.back");
        }
        else
        {
            Navigation.NavigateTo("search");
        }
    }

    private void EditNote()
    {
        if (note == null) return;
        
        if (!isEditing)
        {
            // 进入编辑模式
            isEditing = true;
            editContent = note.Content;
        }
        else
        {
            // 退出编辑模式
            isEditing = false;
            editContent = "";
        }
    }

    private async Task SaveNote()
    {
        if (note == null || string.IsNullOrWhiteSpace(editContent)) return;

        if (string.IsNullOrWhiteSpace(selectedVaultId))
        {
            Logger.LogWarning("未选择知识库，无法保存笔记：{Path}", note?.Path);
            return;
        }

        try
        {
            var ok = await ApiService.WriteVaultNoteAsync(note.Path, editContent, selectedVaultId);
            if (!ok)
            {
                Logger.LogWarning("写入笔记失败：{Path}", note.Path);
                return;
            }

            note.Content = editContent;
            note.Modified = DateTime.Now;
            
            // 退出编辑模式
            isEditing = false;
            editContent = "";
            
            Logger.LogInformation("笔记已保存：{NoteId}", note.Path);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "保存笔记失败");
        }
    }

    private void CancelEdit()
    {
        isEditing = false;
        editContent = "";
    }

    private async Task GenerateMissingNote()
    {
        if (string.IsNullOrWhiteSpace(noteId) || string.IsNullOrWhiteSpace(selectedVaultId))
            return;

        isGeneratingMissingNote = true;
        generateMessage = "";
        generateSuccess = false;
        StateHasChanged();

        try
        {
            var result = await ApiService.GenerateMissingNoteAsync(noteId, selectedVaultId);
            if (result != null && result.Success)
            {
                generateSuccess = true;
                var msg = $"笔记已生成：{result.NotePath}";
                if (result.FixedLinks > 0)
                    msg += $"，同时纠正了 {result.FixedLinks} 条链接";
                generateMessage = msg;

                // 重新加载笔记（现在应该能找到了）
                await LoadNote();
            }
            else
            {
                generateSuccess = false;
                generateMessage = result?.Message ?? "生成失败";
            }
        }
        catch (Exception ex)
        {
            generateSuccess = false;
            generateMessage = $"生成失败：{ex.Message}";
            Logger.LogError(ex, "AI 生成缺失笔记失败");
        }
        finally
        {
            isGeneratingMissingNote = false;
            StateHasChanged();
        }
    }

    private async Task ToggleFavorite()
    {
        if (note == null) return;

        var isFav = await FavoritesService.IsFavorite(note.Path);
        if (isFav)
        {
            await FavoritesService.RemoveFavorite(note.Path);
            isFavorite = false;
        }
        else
        {
            await FavoritesService.AddFavorite(note.Path, note.Title);
            isFavorite = true;
        }
    }

    /// <summary>
    /// 渲染 Markdown 并处理双向链接 [[path]]
    /// </summary>
    private string RenderMarkdownWithWikiLinks(string content)
    {
        // 先将 Markdown 转换为 HTML
        var html = Markdown.ToHtml(content);
        
        // 处理 [[双向链接]] 格式
        // 匹配 [[path]] 或 [[path|text]]
        html = System.Text.RegularExpressions.Regex.Replace(html,
            @"\[\[([^\]|]+)(?:\|([^\]]+))?\]\]",
            match =>
            {
                var path = match.Groups[1].Value.Trim();
                
                // 提取纯文本作为显示文本（去掉路径中的目录）
                var displayText = System.IO.Path.GetFileName(path);
                if (!string.IsNullOrEmpty(match.Groups[2].Value))
                {
                    displayText = match.Groups[2].Value;
                }
                
                // 生成带 onclick 的链接，使用 Blazor 导航
                var encodedPath = Uri.EscapeDataString(path);
                return $"<a href=\"note?id={encodedPath}\" class=\"wiki-link\" onclick=\"window.location.href='note?id={encodedPath}'; return false;\">{displayText}</a>";
            });
        
        return html;
    }

    public class NoteInfo
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Path { get; set; } = "";
        public string Content { get; set; } = "";
        public string RenderedContent => Content.Replace("\n", "<br/>");
        public DateTime Modified { get; set; }
        public string[] Tags { get; set; } = Array.Empty<string>();
    }

}

