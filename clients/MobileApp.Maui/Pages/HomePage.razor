@page "/"
@inject BaihuaSdk.Storage.IServerConfigStore ServerStore
@inject BaihuaSdk.Storage.ISecureStore SecureStore
@inject BaihuaSdk.Signing.IRequestSigner Signer
@inject NavigationManager Nav

<PageTitle>百花</PageTitle>

<h1>百花</h1>
<p>个人知识库集散地 · 移动端</p>

<h2>已配对服务器</h2>

@if (_servers.Count == 0)
{
    <p class="empty-hint">还没有配对的服务器</p>
    <button class="btn primary" @onclick="GoPairing">添加服务器</button>
}
else
{
    <div class="server-list">
        @foreach (var s in _servers)
        {
            <div class="server-card @(s.IsOnline ? "online" : "offline")">
                <div class="server-main" @onclick="() => SelectServer(s)">
                    <div class="server-name">@s.Name @(Signer.HasServerSecret(s.HttpUrl) ? "🔑" : "")</div>
                    <div class="server-url">@s.HttpUrl</div>
                    <div class="server-status">@(s.IsOnline ? "● 在线" : "○ 离线")</div>
                    <div class="server-time">最后使用: @(s.LastUsedAt?.ToString("MM-dd HH:mm") ?? "从未")</div>
                </div>
                <button class="btn small danger" @onclick="() => DeleteServer(s)">🗑️</button>
            </div>
        }
    </div>

    <button class="btn" style="margin-top:12px" @onclick="GoPairing">+ 添加服务器</button>
}

@if (_selectedServer != null)
{
    <div class="quick-actions">
        <h3>@_selectedServer.Name</h3>
        <button class="btn primary" @onclick="GoSync">📥 同步知识库</button>
        <button class="btn" @onclick="GoVaults">📁 浏览已同步</button>
        <button class="btn" @onclick="GoPairing">🔗 重新配对</button>
    </div>
}

@if (_confirmDelete != null)
{
    <div class="confirm-dialog">
        <p>确认删除服务器 "@_confirmDelete.Name"？</p>
        <button class="btn danger" @onclick="ConfirmDelete">确认删除</button>
        <button class="btn" @onclick="() => _confirmDelete = null">取消</button>
    </div>
}

@code {
    private IReadOnlyList<BaihuaSdk.Models.ServerConfig> _servers = Array.Empty<BaihuaSdk.Models.ServerConfig>();
    private BaihuaSdk.Models.ServerConfig? _selectedServer;
    private BaihuaSdk.Models.ServerConfig? _confirmDelete;

    protected override async Task OnInitializedAsync()
    {
        _servers = await ServerStore.GetServersAsync();
        foreach (var s in _servers)
        {
            if (!Signer.HasServerSecret(s.HttpUrl))
            {
                var secret = await SecureStore.GetAsync($"secret_{s.HttpUrl}");
                if (!string.IsNullOrEmpty(secret))
                    Signer.SetServerSecret(s.HttpUrl, secret);
            }
        }
        var current = await ServerStore.GetCurrentServerAsync();
        if (current != null) _selectedServer = current;
    }

    private async Task SelectServer(BaihuaSdk.Models.ServerConfig server)
    {
        _selectedServer = server;
        await ServerStore.SetCurrentServerAsync(server.Id);
        StateHasChanged();
    }

    private void DeleteServer(BaihuaSdk.Models.ServerConfig server)
    {
        _confirmDelete = server;
    }

    private async Task ConfirmDelete()
    {
        if (_confirmDelete == null) return;

        await ServerStore.DeleteServerAsync(_confirmDelete.Id);
        Signer.ClearSecrets();

        _servers = await ServerStore.GetServersAsync();
        if (_selectedServer?.Id == _confirmDelete.Id)
            _selectedServer = null;
        _confirmDelete = null;
        StateHasChanged();
    }

    private void GoSync() { Nav.NavigateTo("/sync"); StateHasChanged(); }
    private void GoVaults() { Nav.NavigateTo("/vaults"); StateHasChanged(); }
    private void GoPairing() { Nav.NavigateTo("/pairing"); StateHasChanged(); }
}
