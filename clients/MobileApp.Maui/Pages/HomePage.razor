@page "/"
@inject BaihuaguSdk.Storage.IServerConfigStore ServerStore
@inject NavigationManager Nav

<PageTitle>百花谷</PageTitle>

<h1>百花谷</h1>
<p>个人知识库集散地 · SDK 试验版</p>

<h2>已配对服务器</h2>

@if (_servers.Count == 0)
{
    <p class="empty-hint">还没有配对的服务器</p>
    <a href="/pairing" class="btn primary">添加服务器</a>
}
else
{
    <div class="server-list">
        @foreach (var s in _servers)
        {
            <div class="server-card @(s.IsOnline ? "online" : "offline")" @onclick="() => SelectServer(s)">
                <div class="server-name">@s.Name</div>
                <div class="server-url">@s.HttpUrl</div>
                <div class="server-status">@(s.IsOnline ? "● 在线" : "○ 离线")</div>
                <div class="server-time">最后使用: @(s.LastUsedAt?.ToString("MM-dd HH:mm") ?? "从未")</div>
            </div>
        }
    </div>

    <a href="/pairing" class="btn" style="margin-top:12px">+ 添加服务器</a>
}

@if (_selectedServer != null)
{
    <div class="quick-actions">
        <h3>@_selectedServer.Name</h3>
        <button class="btn primary" @onclick="GoSync">📥 同步知识库</button>
        <button class="btn" @onclick="GoPairing">📋 查看详情</button>
    </div>
}

@code {
    private IReadOnlyList<BaihuaguSdk.Models.ServerConfig> _servers = Array.Empty<BaihuaguSdk.Models.ServerConfig>();
    private BaihuaguSdk.Models.ServerConfig? _selectedServer;

    protected override async Task OnInitializedAsync()
    {
        _servers = await ServerStore.GetServersAsync();
        var current = await ServerStore.GetCurrentServerAsync();
        if (current != null) _selectedServer = current;
    }

    private async Task SelectServer(BaihuaguSdk.Models.ServerConfig server)
    {
        _selectedServer = server;
        await ServerStore.SetCurrentServerAsync(server.Id);
    }

    private void GoSync() => Nav.NavigateTo("/sync");
    private void GoPairing() => Nav.NavigateTo("/pairing");
}
