@page "/vaults"
@inject BaihuaSdk.Storage.IServerConfigStore ServerStore
@inject BaihuaSdk.Signing.RequestSigner Signer
@inject BaihuaSdk.Services.SyncServiceImpl SyncService
@inject MobileApp.Maui.Services.IVaultStorageFactory VaultStorageFactory
@inject NavigationManager Nav

<PageTitle>百花 - 已同步</PageTitle>

<h1>已同步的知识库</h1>

@if (_syncing)
{
    <p class="sync-status">🔄 正在同步...</p>
}

@if (_viewContent != null)
{
    <!-- 文件内容预览页 -->
    <div class="view-header">
        <button class="btn small" @onclick="BackToFileList">← 返回列表</button>
        <span class="view-path">@_viewFilePath</span>
    </div>
    <div class="markdown-content">@((MarkupString)_viewContent)</div>
}
else if (_selectedVault != null)
{
    <!-- 文件列表页 -->
    <div class="vault-header">
        <button class="btn small" @onclick="BackToVaultList">← 返回知识库</button>
        <h2>@_selectedVault.DisplayName <span class="file-count">@_selectedVault.Files.Count 个文件</span></h2>
    </div>
    
    @if (_selectedVault.Files.Count == 0)
    {
        <p class="empty-hint">该知识库没有文件。</p>
    }
    else
    {
        <div class="folder-list">
            @foreach (var folder in _selectedFolders)
            {
                <div class="folder-group">
                    <div class="folder-header" @onclick="() => ToggleFolder(folder.Name)">
                        <span class="folder-icon">@(folder.IsExpanded ? "📂" : "📁")</span>
                        <span class="folder-name">@folder.Name</span>
                        <span class="file-count">@folder.Files.Count 个文件</span>
                    </div>
                    @if (folder.IsExpanded)
                    {
                        <div class="file-list">
                            @foreach (var file in folder.Files)
                            {
                                <div class="file-item" @onclick="() => ViewFile(file)">
                                    <span class="file-icon">📄</span>
                                    <span class="file-path">@file.RelPath</span>
                                    <span class="file-size">@file.SizeDisplay</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}
else
{
    <!-- 知识库列表页 -->
    @if (_vaults.Count == 0)
    {
        <p class="empty-hint">还没有同步过知识库。</p>
        <button class="btn small primary" @onclick="GoSync">去同步</button>
    }
    else
    {
        <div class="toolbar">
            <button class="btn small" @onclick="RefreshVaultsAsync">🔄 刷新</button>
            @if (_currentServer != null)
            {
                <button class="btn small primary" @onclick="SyncAll">📥 同步全部</button>
            }
        </div>

        @foreach (var vault in _vaults)
        {
            <div class="vault-card">
                <div class="vault-main" @onclick="() => OpenVault(vault)">
                    <strong>@vault.DisplayName</strong>
                    <span class="file-count">@vault.Files.Count 个文件</span>
                </div>
                <button class="btn small danger" @onclick="() => ConfirmDeleteVault(vault)">🗑️</button>
            </div>
        }
    }
}

@if (_confirmDelete != null)
{
    <div class="confirm-dialog">
        <p>确认删除知识库 "@_confirmDelete.DisplayName"？</p>
        <p class="hint">这将删除本地所有已同步的文件 (@_confirmDelete.Files.Count 个)，不会影响服务器上的数据。</p>
        <button class="btn danger" @onclick="DeleteVaultConfirmed">确认删除</button>
        <button class="btn" @onclick="() => _confirmDelete = null">取消</button>
    </div>
}

@if (_error != null)
{
    <p class="error-message">❌ @_error</p>
}

@code {
    private List<VaultEntry> _vaults = new();
    private VaultEntry? _selectedVault;
    private List<FolderEntry> _selectedFolders = new();
    private string? _viewContent;
    private string? _viewFilePath;
    private bool _syncing = false;
    private string? _error;
    private BaihuaSdk.Models.ServerConfig? _currentServer;
    private VaultEntry? _confirmDelete;

    private record VaultEntry(string Id, string DisplayName, List<FileEntry> Files);
    private record FileEntry(string RelPath, long Size, string FullPath)
    {
        public string SizeDisplay => Size < 1024 ? $"{Size} B" :
            Size < 1024 * 1024 ? $"{Size / 1024.0:F1} KB" : $"{Size / (1024.0 * 1024):F1} MB";
    }
    private class FolderEntry
    {
        public string Name { get; init; } = "";
        public List<FileEntry> Files { get; } = new();
        public bool IsExpanded { get; set; } = false;
    }

    private record VaultInfoFile(string Id, string Name, string Industry, string Source);

    protected override async Task OnInitializedAsync()
    {
        _currentServer = await ServerStore.GetCurrentServerAsync();
        await RefreshVaultsAsync();
    }

    private async Task RefreshVaultsAsync()
    {
        _vaults.Clear();
        var baseDir = System.IO.Path.Combine(FileSystem.AppDataDirectory, "vaults");
        if (!Directory.Exists(baseDir)) return;

        var nameMap = await FetchServerVaultNameMapAsync();

        foreach (var vaultDir in Directory.GetDirectories(baseDir))
        {
            var id = System.IO.Path.GetFileName(vaultDir);
            var displayName = ReadVaultDisplayName(vaultDir, id);
            if (displayName == id && nameMap.TryGetValue(id, out var serverName))
                displayName = serverName;

            var files = Directory.GetFiles(vaultDir, "*.*", SearchOption.AllDirectories)
                .Where(f => !System.IO.Path.GetFileName(f).Equals(".vault-info.json", StringComparison.OrdinalIgnoreCase))
                .Select(f => new FileEntry(
                    System.IO.Path.GetRelativePath(vaultDir, f),
                    new System.IO.FileInfo(f).Length, f))
                .OrderBy(f => f.RelPath)
                .ToList();
            _vaults.Add(new VaultEntry(id, displayName, files));
        }
        StateHasChanged();
    }

    private async Task<Dictionary<string, string>> FetchServerVaultNameMapAsync()
    {
        if (_currentServer == null) return new();
        if (!Signer.HasServerSecret(_currentServer.HttpUrl)) return new();

        try
        {
            var vaults = await SyncService.FetchVaultListAsync(_currentServer.HttpUrl);
            return vaults.ToDictionary(v => v.Id, v => v.Name);
        }
        catch { return new(); }
    }

    private string ReadVaultDisplayName(string vaultDir, string fallbackId)
    {
        try
        {
            var infoPath = System.IO.Path.Combine(vaultDir, ".vault-info.json");
            if (System.IO.File.Exists(infoPath))
            {
                var json = System.IO.File.ReadAllText(infoPath);
                var info = System.Text.Json.JsonSerializer.Deserialize<VaultInfoFile>(json);
                if (!string.IsNullOrWhiteSpace(info?.Name))
                    return info.Name;
            }
        }
        catch { /* 忽略元数据读取失败 */ }
        return fallbackId;
    }

    private void OpenVault(VaultEntry vault)
    {
        _selectedVault = vault;
        _selectedFolders = BuildFolderTree(vault.Files);
        _viewContent = null;
    }

    /// <summary>按顶层目录分组文件</summary>
    private List<FolderEntry> BuildFolderTree(List<FileEntry> files)
    {
        var folders = new Dictionary<string, FolderEntry>();

        foreach (var file in files)
        {
            var parts = file.RelPath.Split('/');
            var folderName = parts.Length > 1 ? parts[0] : "根目录";

            if (!folders.TryGetValue(folderName, out var folder))
            {
                folder = new FolderEntry { Name = folderName, IsExpanded = true };
                folders[folderName] = folder;
            }
            folder.Files.Add(file);
        }

        return folders.Values.OrderBy(f => f.Name == "根目录" ? "" : f.Name).ToList();
    }

    private void ToggleFolder(string folderName)
    {
        var folder = _selectedFolders.FirstOrDefault(f => f.Name == folderName);
        if (folder != null)
            folder.IsExpanded = !folder.IsExpanded;
    }

    private void BackToVaultList()
    {
        _selectedVault = null;
        _selectedFolders.Clear();
    }

    private void BackToFileList()
    {
        _viewContent = null;
    }

    private void GoSync() => Nav.NavigateTo("/sync");

    private async Task SyncAll()
    {
        if (_currentServer == null || _syncing) return;

        _syncing = true;
        _error = null;
        StateHasChanged();

        try
        {
            var vaults = await SyncService.FetchVaultListAsync(_currentServer.HttpUrl);
            foreach (var vault in vaults)
            {
                var storage = VaultStorageFactory.CreateForVault(vault.Id);
                await SyncService.SyncVaultAsync(
                    _currentServer.HttpUrl,
                    vault.Id,
                    Signer.DeviceId,
                    storage);
                await WriteVaultMetadataAsync(storage, vault);
            }
            await RefreshVaultsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _syncing = false;
            StateHasChanged();
        }
    }

    private async Task WriteVaultMetadataAsync(MobileContract.Services.IVaultStorageAdapter storage, MobileContract.VaultSync.VaultInfo vault)
    {
        try
        {
            var metadataPath = System.IO.Path.Combine(storage.RootPath, ".vault-info.json");
            var json = System.Text.Json.JsonSerializer.Serialize(new
            {
                vault.Id,
                vault.Name,
                vault.Industry,
                vault.Source,
                SyncedAt = DateTimeOffset.UtcNow
            });
            await System.IO.File.WriteAllTextAsync(metadataPath, json, System.Text.Encoding.UTF8);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"保存知识库元数据失败: {ex.Message}");
        }
    }

    private void ViewFile(FileEntry file)
    {
        _viewFilePath = file.RelPath;
        try
        {
            var markdown = File.ReadAllText(file.FullPath);
            _viewContent = Markdig.Markdown.ToHtml(markdown);
        }
        catch { _viewContent = "<p>[无法预览]</p>"; }
    }

    private void ConfirmDeleteVault(VaultEntry vault)
    {
        _confirmDelete = vault;
    }

    private async Task DeleteVaultConfirmed()
    {
        if (_confirmDelete == null) return;

        try
        {
            var vaultDir = System.IO.Path.Combine(FileSystem.AppDataDirectory, "vaults", _confirmDelete.Id);
            if (Directory.Exists(vaultDir))
            {
                Directory.Delete(vaultDir, recursive: true);
            }
            _vaults.RemoveAll(v => v.Id == _confirmDelete.Id);
            if (_selectedVault?.Id == _confirmDelete.Id)
            {
                _selectedVault = null;
                _selectedFolders.Clear();
            }
        }
        catch (Exception ex)
        {
            _error = $"删除失败: {ex.Message}";
        }
        finally
        {
            _confirmDelete = null;
            StateHasChanged();
        }
    }
}
