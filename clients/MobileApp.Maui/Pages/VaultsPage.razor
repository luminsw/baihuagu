@page "/vaults"
@inject BaihuaguSdk.Storage.IServerConfigStore ServerStore
@inject BaihuaguSdk.Signing.RequestSigner Signer
@inject BaihuaguSdk.Services.SyncServiceImpl SyncService
@inject MobileApp.Maui.Services.IVaultStorageFactory VaultStorageFactory
@inject NavigationManager Nav

<PageTitle>百花谷 - 已同步</PageTitle>

<h1>已同步的知识库</h1>

@if (_syncing)
{
    <p class="sync-status">🔄 正在同步...</p>
}

@if (_vaults.Count == 0)
{
    <p class="empty-hint">还没有同步过知识库。</p>
    <button class="btn small primary" @onclick="GoSync">去同步</button>
}
else
{
    <div class="toolbar">
        <button class="btn small" @onclick="RefreshVaultsAsync">🔄 刷新</button>
        @if (_currentServer != null)
        {
            <button class="btn small primary" @onclick="SyncAll">📥 同步全部</button>
        }
    </div>

    @foreach (var vault in _vaults)
    {
        <div class="vault-card" @onclick="() => OpenVault(vault.DisplayName)">
            <strong>@vault.DisplayName</strong>
            <span class="file-count">@vault.Files.Count 个文件</span>
        </div>
    }
}

@if (_selectedName != null)
{
    <h2 style="margin-top:20px">
        <button class="btn small" @onclick="() => _selectedName = null">← 返回</button>
        @_selectedName
    </h2>

    @foreach (var file in _selectedFiles)
    {
        <div class="file-item" @onclick="() => ViewFile(file)">
            <span class="file-icon">📄</span>
            <span class="file-path">@file.RelPath</span>
            <span class="file-size">@file.SizeDisplay</span>
        </div>
    }

    @if (_viewContent != null)
    {
        <h3 style="margin-top:16px">
            <button class="btn small" @onclick="() => _viewContent = null">← 返回</button>
            @_viewFilePath
        </h3>
        <pre class="file-content">@_viewContent</pre>
    }
}

@if (_error != null)
{
    <p class="error-message">❌ @_error</p>
}

@code {
    private List<VaultEntry> _vaults = new();
    private string? _selectedName;
    private List<FileEntry> _selectedFiles = new();
    private string? _viewContent;
    private string? _viewFilePath;
    private bool _syncing = false;
    private string? _error;
    private BaihuaguSdk.Models.ServerConfig? _currentServer;

    private record VaultEntry(string Id, string DisplayName, List<FileEntry> Files);
    private record FileEntry(string RelPath, long Size, string FullPath)
    {
        public string SizeDisplay => Size < 1024 ? $"{Size} B" :
            Size < 1024 * 1024 ? $"{Size / 1024.0:F1} KB" : $"{Size / (1024.0 * 1024):F1} MB";
    }

    private record VaultInfoFile(string Id, string Name, string Industry, string Source);

    protected override async Task OnInitializedAsync()
    {
        _currentServer = await ServerStore.GetCurrentServerAsync();
        await RefreshVaultsAsync();
    }

    private async Task RefreshVaultsAsync()
    {
        _vaults.Clear();
        var baseDir = System.IO.Path.Combine(FileSystem.AppDataDirectory, "vaults");
        if (!Directory.Exists(baseDir)) return;

        // 尝试从服务器获取名称映射（兼容已同步但未生成 .vault-info.json 的历史数据）
        var nameMap = await FetchServerVaultNameMapAsync();

        foreach (var vaultDir in Directory.GetDirectories(baseDir))
        {
            var id = System.IO.Path.GetFileName(vaultDir);
            var displayName = ReadVaultDisplayName(vaultDir, id);
            if (displayName == id && nameMap.TryGetValue(id, out var serverName))
                displayName = serverName;

            var files = Directory.GetFiles(vaultDir, "*.*", SearchOption.AllDirectories)
                .Where(f => !System.IO.Path.GetFileName(f).Equals(".vault-info.json", StringComparison.OrdinalIgnoreCase))
                .Select(f => new FileEntry(
                    System.IO.Path.GetRelativePath(vaultDir, f),
                    new System.IO.FileInfo(f).Length, f))
                .OrderBy(f => f.RelPath)
                .ToList();
            _vaults.Add(new VaultEntry(id, displayName, files));
        }
        StateHasChanged();
    }

    private async Task<Dictionary<string, string>> FetchServerVaultNameMapAsync()
    {
        if (_currentServer == null) return new();
        if (!Signer.HasServerSecret(_currentServer.HttpUrl)) return new();

        try
        {
            var vaults = await SyncService.FetchVaultListAsync(_currentServer.HttpUrl);
            return vaults.ToDictionary(v => v.Id, v => v.Name);
        }
        catch { return new(); }
    }

    private string ReadVaultDisplayName(string vaultDir, string fallbackId)
    {
        try
        {
            var infoPath = System.IO.Path.Combine(vaultDir, ".vault-info.json");
            if (System.IO.File.Exists(infoPath))
            {
                var json = System.IO.File.ReadAllText(infoPath);
                var info = System.Text.Json.JsonSerializer.Deserialize<VaultInfoFile>(json);
                if (!string.IsNullOrWhiteSpace(info?.Name))
                    return info.Name;
            }
        }
        catch { /* 忽略元数据读取失败，回退到目录名 */ }
        return fallbackId;
    }

    private void OpenVault(string name)
    {
        _selectedName = name;
        _selectedFiles = _vaults.First(v => v.DisplayName == name).Files;
        _viewContent = null;
    }

    private void GoSync() => Nav.NavigateTo("/sync");

    private async Task SyncAll()
    {
        if (_currentServer == null || _syncing) return;

        _syncing = true;
        _error = null;
        StateHasChanged();

        try
        {
            var vaults = await SyncService.FetchVaultListAsync(_currentServer.HttpUrl);
            foreach (var vault in vaults)
            {
                var storage = VaultStorageFactory.CreateForVault(vault.Id);
                await SyncService.SyncVaultAsync(
                    _currentServer.HttpUrl,
                    vault.Id,
                    Signer.DeviceId,
                    storage);
                await WriteVaultMetadataAsync(storage, vault);
            }
            await RefreshVaultsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _syncing = false;
            StateHasChanged();
        }
    }

    private async Task WriteVaultMetadataAsync(MobileContract.Services.IVaultStorageAdapter storage, MobileContract.VaultSync.VaultInfo vault)
    {
        try
        {
            var metadataPath = System.IO.Path.Combine(storage.RootPath, ".vault-info.json");
            var json = System.Text.Json.JsonSerializer.Serialize(new
            {
                vault.Id,
                vault.Name,
                vault.Industry,
                vault.Source,
                SyncedAt = DateTimeOffset.UtcNow
            });
            await System.IO.File.WriteAllTextAsync(metadataPath, json, System.Text.Encoding.UTF8);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"保存知识库元数据失败: {ex.Message}");
        }
    }

    private void ViewFile(FileEntry file)
    {
        _viewFilePath = file.RelPath;
        try { _viewContent = File.ReadAllText(file.FullPath); }
        catch { _viewContent = "[无法预览]"; }
    }
}
