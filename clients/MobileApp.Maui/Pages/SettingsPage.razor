@page "/settings"
@inject BaihuaguSdk.Signing.RequestSigner Signer

<PageTitle>百花谷 - 设置</PageTitle>

<h1>设置</h1>

<div class="settings-section">
    <h3>设备信息</h3>
    <p>设备 ID: <code>@Signer.DeviceId</code></p>
    <p>设备名称: <code>@Signer.DeviceName</code></p>
</div>

<div class="settings-section">
    <h3>关于</h3>
    <p>百花谷 iOS SDK 试验项目</p>
    <p>版本: 1.0.0-preview</p>
    <p>技术栈: .NET MAUI Blazor Hybrid + BaihuaguSdk</p>
</div>
