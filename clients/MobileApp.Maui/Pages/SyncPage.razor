@page "/sync"
@inject MobileContract.Services.ISyncService SyncService
@inject BaihuaguSdk.Services.AuthorizationWatcher Watcher
@inject BaihuaguSdk.Signing.RequestSigner Signer
@inject BaihuaguSdk.Storage.IServerConfigStore ServerStore
@inject BaihuaguSdk.Storage.ISecureStore SecureStore
@inject MobileApp.Maui.Services.IVaultStorageFactory VaultStorageFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject MobileContract.Services.IRemoteLogService Logger
@implements IDisposable

<PageTitle>百花谷 - 同步</PageTitle>

<h1>知识库同步</h1>

@if (_servers.Count == 0)
{
    <p class="empty-hint">还没有配对的服务器。<button class="btn small primary" @onclick="GoPairing">去添加</button></p>
}
else
{
    <select @bind="_selectedServerId" @bind:after="OnServerChanged" class="server-select">
        <option value="">-- 选择服务器 --</option>
        @foreach (var s in _servers)
        {
            <option value="@s.Id">@s.Name (@s.HttpUrl)</option>
        }
    </select>

    @if (_selectedServer != null && !string.IsNullOrEmpty(_selectedServer.HttpUrl))
    {
        @if (!_hasSecret)
        {
            <div class="warning-banner">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <p class="mb-0">⚠️ 尚未配对认证。</p>
                    <span class="ws-badge @(_pushConnected ? "ws-on" : "ws-off")">
                        @(_pushConnected ? "🟢 WebSocket 已连接" : "🔴 WebSocket 未连接")
                    </span>
                </div>
                <button class="btn primary" @onclick="CheckAuthorizationStatus" disabled="@_isLoading">
                    @(_isLoading ? "检查中..." : "🔍 检查授权状态")
                </button>
                @if (_regResult != null)
                {
                    <p class="@(_regResult.Success ? "success" : "error") mt-2">
                        @(_regResult.Success
                            ? (_regResult.Authorized ? "✅ 已授权! 密钥已保存" : "已注册，等待 WebUI 授权；授权成功后会自动刷新")
                            : $"注册失败: {_regResult.ErrorMessage ?? "请检查网络"}")
                    </p>
                }
            </div>
        }
        else
        {
            <button class="btn primary" @onclick="FetchVaults" disabled="@_isLoading">
                @(_isLoading ? "加载中..." : "📋 获取知识库列表")
            </button>

            @if (_syncResult != null)
            {
                <div class="status-banner success" @ref="_resultRef">
                    <strong>✅ 同步完成</strong>
                    <p>共 @_syncResult.TotalFiles 文件，下载 @_syncResult.Downloaded，删除 @_syncResult.Deleted，失败 @_syncResult.Failed</p>
                    @if (_syncResult.Errors != null && _syncResult.Errors.Count > 0)
                    {
                        <div class="error-details">
                            <p><strong>失败详情：</strong></p>
                            <ul>
                                @foreach (var err in _syncResult.Errors.Take(10))
                                {
                                    <li>@err</li>
                                }
                                @if (_syncResult.Errors.Count > 10)
                                {
                                    <li>... 还有 @(_syncResult.Errors.Count - 10) 个错误</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="status-banner error" @ref="_resultRef">
                    <strong>❌ 出错了</strong>
                    <p>@_error</p>
                </div>
            }

            @if (_vaults.Count > 0)
            {
                <h3>知识库 (@_vaults.Count)</h3>
                <div class="vault-list">
                    @foreach (var v in _vaults)
                    {
                        var syncStatus = GetSyncStatus(v.Id);
                        <div class="vault-card @(syncStatus.IsSynced ? "synced" : "")">
                            <div>
                                <strong>@v.Name</strong>
                                <span class="industry">@v.Industry</span>
                                <span class="sync-status-tag @(syncStatus.IsSynced ? "synced" : "not-synced")">
                                    @(syncStatus.IsSynced ? $"✅ 已同步 ({syncStatus.FileCount} 个文件)" : "🔄 未同步")
                                </span>
                            </div>
                            <button class="btn small @(syncStatus.IsSynced ? "secondary" : "primary")"
                                    @onclick="() => SyncVault(v)" disabled="@(_syncingVault == v.Id)">
                                @(_syncingVault == v.Id ? "⏳ 同步中..." : "🔄 同步")
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }
}

@code {
    private IReadOnlyList<BaihuaguSdk.Models.ServerConfig> _servers = Array.Empty<BaihuaguSdk.Models.ServerConfig>();
    private string _selectedServerId = "";
    private BaihuaguSdk.Models.ServerConfig? _selectedServer;
    private IReadOnlyList<MobileContract.VaultSync.VaultInfo> _vaults = Array.Empty<MobileContract.VaultSync.VaultInfo>();
    private bool _isLoading;
    private string? _syncingVault;
    private MobileContract.VaultSync.SyncResult? _syncResult;
    private MobileContract.Pairing.RegisterDeviceResult? _regResult;
    private bool _hasSecret;
    private string? _error;
    private ElementReference _resultRef;
    private CancellationTokenSource? _watchCts;
    private bool _pushConnected;

    private record SyncStatus(bool IsSynced, int FileCount);

    private SyncStatus GetSyncStatus(string vaultId)
    {
        var vaultDir = System.IO.Path.Combine(FileSystem.AppDataDirectory, "vaults", vaultId);
        if (!Directory.Exists(vaultDir))
            return new SyncStatus(false, 0);

        var fileCount = Directory.GetFiles(vaultDir, "*.*", SearchOption.AllDirectories)
            .Where(f => !System.IO.Path.GetFileName(f).Equals(".vault-info.json", StringComparison.OrdinalIgnoreCase))
            .Count();
        return new SyncStatus(fileCount > 0, fileCount);
    }

    protected override async Task OnInitializedAsync()
    {
        Watcher.WebSocketConnectionStateChanged += OnWebSocketConnectionStateChange;
        _servers = await ServerStore.GetServersAsync();
        var current = await ServerStore.GetCurrentServerAsync();
        if (current != null)
        {
            _selectedServerId = current.Id;
            _selectedServer = current;
            // 从 SecureStore 恢复密钥到内存（避免 app 重启后内存丢失），并同步 _hasSecret 状态
            if (!Signer.HasServerSecret(current.HttpUrl))
            {
                var secret = await SecureStore.GetAsync($"secret_{current.HttpUrl}");
                if (!string.IsNullOrEmpty(secret))
                    Signer.SetServerSecret(current.HttpUrl, secret);
            }
            _hasSecret = Signer.HasServerSecret(current.HttpUrl);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_selectedServer != null && !_hasSecret)
        {
            await WatchAuthorizationAsync("自动检查");
        }
    }

    private void GoPairing() { Nav.NavigateTo("/pairing"); StateHasChanged(); }

    private async Task OnServerChanged()
    {
        StopWatching();
        _selectedServer = _servers.FirstOrDefault(s => s.Id == _selectedServerId);
        if (_selectedServer != null)
        {
            await ServerStore.SetCurrentServerAsync(_selectedServer.Id);
            _hasSecret = Signer.HasServerSecret(_selectedServer.HttpUrl);
            _syncResult = null; _error = null; _regResult = null;
            if (!_hasSecret)
            {
                await WatchAuthorizationAsync("切换服务器");
            }
        }
        else
        {
            _syncResult = null; _error = null; _regResult = null;
        }
        StateHasChanged();
    }

    private async Task CheckAuthorizationStatus()
    {
        if (_selectedServer == null) return;
        await WatchAuthorizationAsync("按钮");
    }

    private async Task WatchAuthorizationAsync(string source)
    {
        if (_selectedServer == null || _hasSecret) return;

        StopWatching();
        _watchCts = new CancellationTokenSource();
        _isLoading = true; _error = null;
        StateHasChanged();

        try
        {
            Logger.Info($"[{source}] 开始查询注册/授权状态", "SyncPage");
            var result = await Watcher.WaitForAuthorizationAsync(
                _selectedServer.HttpUrl,
                MobileApp.Maui.Services.DeviceInfoHelper.GetDeviceName(),
                ct: _watchCts.Token);

            if (result.IsAuthorized && !string.IsNullOrEmpty(result.SharedSecret))
            {
                Logger.Info($"[{source}] 已授权，准备保存密钥并加载知识库", "SyncPage");
                await ApplyAuthorizedSecretAsync(result.SharedSecret, source);
            }
            else if (_watchCts.IsCancellationRequested)
            {
                Logger.Info($"[{source}] 授权等待已取消", "SyncPage");
            }
            else if (!string.IsNullOrEmpty(result.ErrorMessage))
            {
                _error = result.ErrorMessage;
            }
            else
            {
                // 未授权但也没有异常：说明还在等待，给 UI 一个明确状态
                _regResult = new MobileContract.Pairing.RegisterDeviceResult
                {
                    Success = true,
                    Authorized = false,
                    RequestId = result.RequestId
                };
            }
        }
        catch (OperationCanceledException)
        {
            Logger.Info($"[{source}] 授权等待已取消", "SyncPage");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.Info($"[{source}] 等待授权异常: {ex.Message}", "SyncPage");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void StopWatching()
    {
        if (_watchCts != null)
        {
            _watchCts.Cancel();
            _watchCts.Dispose();
            _watchCts = null;
        }
    }

    private async Task ApplyAuthorizedSecretAsync(string secret, string source)
    {
        if (_selectedServer == null) return;
        Signer.SetServerSecret(_selectedServer.HttpUrl, secret);
        await SecureStore.SetAsync($"secret_{_selectedServer.HttpUrl}", secret);
        _hasSecret = true;
        _regResult = null;
        Logger.Info($"[{source}] 授权完成，密钥已保存，准备加载知识库列表", "SyncPage");
        StateHasChanged();
        await FetchVaults();
        Logger.Info($"[{source}] 知识库列表加载完成: {_vaults.Count} 个", "SyncPage");
    }

    private void OnWebSocketConnectionStateChange(bool connected)
    {
        _pushConnected = connected;
        Logger.Info($"[WebSocket] 连接状态变化: {(connected ? "已连接" : "已断开")}", "SyncPage");
        InvokeAsync(StateHasChanged);
    }

    private async Task FetchVaults()
    {
        if (_selectedServer == null) return;
        _error = null; _isLoading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            _vaults = await SyncService.FetchVaultListAsync(_selectedServer.HttpUrl);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; await InvokeAsync(StateHasChanged); }
    }

    public void Dispose()
    {
        StopWatching();
        Watcher.WebSocketConnectionStateChanged -= OnWebSocketConnectionStateChange;
        Watcher.Dispose();
    }

    private async Task SyncVault(MobileContract.VaultSync.VaultInfo vault)
    {
        if (_selectedServer == null || vault == null) return;
        _syncingVault = vault.Id; _error = null;
        StateHasChanged();
        try
        {
            var storage = VaultStorageFactory.CreateForVault(vault.Id);
            var deviceId = Signer.DeviceId;

            _syncResult = await SyncService.SyncVaultAsync(
                _selectedServer.HttpUrl, vault.Id, deviceId, storage);

            // 保存知识库元数据到本地，便于「已同步」页显示名称而非 ID
            await WriteVaultMetadataAsync(storage, vault);

            await ServerStore.AddOrUpdateServerAsync(_selectedServer with
            {
                IsOnline = true, LastUsedAt = DateTimeOffset.UtcNow
            });
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            _syncingVault = null;
            StateHasChanged();
            if (_syncResult != null || !string.IsNullOrEmpty(_error))
            {
                try { await JS.InvokeVoidAsync("scrollIntoView", _resultRef); } catch { }
            }
        }
    }

    private async Task WriteVaultMetadataAsync(MobileContract.Services.IVaultStorageAdapter storage, MobileContract.VaultSync.VaultInfo vault)
    {
        try
        {
            var metadataPath = System.IO.Path.Combine(storage.RootPath, ".vault-info.json");
            var json = System.Text.Json.JsonSerializer.Serialize(new
            {
                vault.Id,
                vault.Name,
                vault.Industry,
                vault.Source,
                SyncedAt = DateTimeOffset.UtcNow
            });
            await System.IO.File.WriteAllTextAsync(metadataPath, json, System.Text.Encoding.UTF8);
        }
        catch (Exception ex)
        {
            Logger.Info($"保存知识库元数据失败: {ex.Message}", "SyncPage");
        }
    }
}
