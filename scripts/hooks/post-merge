#!/bin/bash
# Git post-merge hook: pull/merge 后自动触发部署
# 由 scripts/install-hooks.sh 安装到 .git/hooks/post-merge

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

(
    cd "$PROJECT_ROOT"
    exec >> /tmp/yj-auto-deploy.log 2>&1
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] 🔗 post-merge hook triggered"
    ./scripts/auto-deploy.sh
) &
