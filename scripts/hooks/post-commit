#!/bin/bash
# Git post-commit hook: 提交后自动触发部署
# 由 scripts/install-hooks.sh 安装到 .git/hooks/post-commit

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# 非交互式后台执行部署，避免阻塞 git commit 命令
(
    cd "$PROJECT_ROOT"
    # 抑制输出，避免污染 git 命令行输出
    exec >> /tmp/yj-auto-deploy.log 2>&1
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] 🔗 post-commit hook triggered"
    ./scripts/auto-deploy.sh
) &
