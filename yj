# 确保加密密钥文件存在（自动管理，对非专业人员零配置）
ensure_encryption_key() {
    local key_file="/opt/yj-family/data/.yj-key"
    if [ -f "$key_file" ]; then
        return 0
    fi

    echo "[ℹ] 首次运行，自动生成加密密钥…"
    mkdir -p /opt/yj-family/data
    # 生成 256-bit 随机密钥（64 个 hex 字符）
    if command -v openssl &> /dev/null; then
        openssl rand -hex 32 > "$key_file"
    else
        # 回退：使用 /dev/urandom
        head -c 32 /dev/urandom | xxd -p -c 64 > "$key_file"
    fi
    chmod 600 "$key_file" 2>/dev/null || true
    echo "[✓] 加密密钥已生成并保存到 $key_file"
    echo "    此密钥用于保护 API Key，请勿删除。"
}

# 检测 Docker 镜像是否需要重新构建
# 原理：比较镜像中的 git.commit label 与当前源码 HEAD，同时检查工作区是否有未 commit 的变更
# 返回 0 表示需要重建，1 表示不需要
_needs_rebuild() {
    local image="$1"

    # 镜像不存在 → 需要构建
    if ! docker images "$image" --format '{{.ID}}' | grep -q .; then
        return 0
    fi

    local git_head
    git_head=$(cd "$YJ_ROOT" && git rev-parse HEAD 2>/dev/null || echo "unknown")

    local image_commit
    image_commit=$(docker inspect "$image" --format='{{index .Config.Labels "git.commit"}}' 2>/dev/null || echo "")

    # 旧镜像没有 label → 需要重建
    if [ -z "$image_commit" ]; then
        return 0
    fi

    # commit 不匹配 → 需要重建
    if [ "$image_commit" != "$git_head" ]; then
        return 0
    fi

    # commit 匹配，但检查工作区是否有未 commit 的变更（包括新增、修改、删除的文件）
    # 这能捕获开发中新增文件但未 commit 的情况
    if [ -d "$YJ_ROOT/.git" ]; then
        local dirty
        dirty=$(cd "$YJ_ROOT" && git status --short 2>/dev/null)
        if [ -n "$dirty" ]; then
            return 0
        fi
    fi

    return 1
}

