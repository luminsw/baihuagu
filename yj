            echo "路径不能为空，请重新输入。"
            continue
        fi
        
        if [ ! -d "$VAULT_PATH" ]; then
            read -rp "文件夹不存在，是否创建？ [y/N] " CREATE
            if [[ "$CREATE" =~ ^[Yy]$ ]]; then
                mkdir -p "$VAULT_PATH"
                echo "[✓] 已创建文件夹: $VAULT_PATH"
            else
                continue
            fi
        fi
        break
    done

    # 创建 notes 子目录
    mkdir -p "$VAULT_PATH/notes"

    # 确保加密密钥文件存在
    ensure_encryption_key

    # 保存配置
    echo ""
    echo "【2/2】保存配置..."

    if [ "$IS_SELF_CONTAINED" -eq 1 ]; then
        SETTINGS_FILE="$YJ_ROOT/appsettings.json"
    else
        SETTINGS_FILE="$TASK_RUNNER_DIR/appsettings.json"
    fi

    cat > "$SETTINGS_FILE" << EOF
{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8788"
      }
    }
  },
  "VaultPath": "$VAULT_PATH"
}
EOF
    echo "[✓] 配置已保存"

    cat << 'EOF'

╔══════════════════════════════════════╗
║     配置完成！                       ║
╚══════════════════════════════════════╝

┌──────────────────────────────────────────────────────────────┐
│  AI 功能配置：                                              │
│  启动服务后，在 Web 界面「设置 → AI 配置」中添加 API Key    │
│  支持阿里云百炼、硅基流动、DeepSeek、火山引擎等             │
├──────────────────────────────────────────────────────────────┤
│  基础功能（无需 API Key）：                                 │
│  ✅ 笔记管理、全文搜索、手机同步                            │
└──────────────────────────────────────────────────────────────┘

现在可以启动服务了：
  ./yj start

EOF
}

cmd_start() {
    echo "正在启动百花谷服务..."

    # 检查 Docker 容器是否已在运行（避免裸机与 Docker 共存）
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qE "yj-family-(webui|taskrunner|taskrunner-ai|taskrunner-vault|nginx)"; then
        echo "[!] 检测到 Docker 容器正在运行"
        echo "    Family 版不支持同时运行 Docker 和裸机进程"
        echo "    请先停止 Docker 容器: ./yj stop"
        echo "    或直接使用 Docker 模式: ./yj dashboard"
        return 1
    fi

    # 检查是否已运行
    if lsof -ti:8788 -sTCP:LISTEN &> /dev/null 2>&1; then
        echo "[提示] 服务已经在运行中（端口 8788）"
        return
    fi

    # 检查运行环境
    if [ "$IS_SELF_CONTAINED" -eq 0 ]; then
        if ! command -v dotnet &> /dev/null; then
            echo "[错误] 未检测到 .NET SDK"
            echo ""
            echo "解决方案："
            echo "  1. 安装 .NET SDK：https://dotnet.microsoft.com/download"
            echo "  2. 或下载自包含版本（无需 .NET SDK）"
            return
        fi
    fi

    # 检查配置
    if [ "$IS_SELF_CONTAINED" -eq 1 ]; then
        SETTINGS_FILE="$YJ_ROOT/appsettings.json"
    else
        SETTINGS_FILE="$TASK_RUNNER_DIR/appsettings.json"
    fi

    if [ ! -f "$SETTINGS_FILE" ]; then
        echo "[提示] 检测到首次使用，请先运行配置向导："
        echo "  ./yj setup"
        return
    fi

    # 检查是否有 AI 配置（通过 API 查询）
    HAS_API_KEY=0
    if curl -s http://localhost:8788/api/ai-config/providers 2>/dev/null | grep -q "id"; then
        HAS_API_KEY=1
    fi

    # 启动服务
    if [ "$IS_SELF_CONTAINED" -eq 1 ]; then
        nohup "$SERVICE_EXE" > /tmp/yj-service.log 2>&1 &
    else
        cd "$TASK_RUNNER_DIR"
        nohup dotnet run --configuration Release > /tmp/yj-service.log 2>&1 &
    fi
    echo $! > "$PID_FILE"

    # 等待服务启动
    echo "等待服务启动..."
    sleep 3

    # 检查是否成功
    if lsof -ti:8788 -sTCP:LISTEN &> /dev/null 2>&1; then
        echo "[✓] 服务已启动！"
        echo ""
        echo "访问地址："
        echo "  - Web 界面: http://localhost:8788"
        echo "  - 状态检查: http://localhost:8788/health"
        echo ""
        
        if [ "$HAS_API_KEY" -eq 0 ]; then
            cat << 'EOF'
┌────────────────────────────────────────────────────────┐
│  ⚠️  未配置 API Key，以下功能不可用：                  │
│     AI 辅助查询、AI 生成笔记                           │
├────────────────────────────────────────────────────────┤
│  如需启用 AI 功能，请运行: ./yj setup                  │
└────────────────────────────────────────────────────────┘

EOF
        fi
        
        echo "提示：运行 './yj' 或 './yj dashboard' 打开管理面板"
    else
        echo "[✗] 服务启动失败，请检查日志: /tmp/yj-service.log"
    fi
}

cmd_status() {
    echo "检查服务状态..."
    local mode
    mode=$(_detect_mode)

    if [ "$mode" = "docker" ]; then
        echo "[模式] Docker 容器"
        echo ""
        local tr_status webui_status nginx_status
        tr_status=$(docker ps --filter "name=yj-family-taskrunner" --format "{{.Status}}" 2>/dev/null || echo "未运行")
        webui_status=$(docker ps --filter "name=yj-family-webui" --format "{{.Status}}" 2>/dev/null || echo "未运行")
        nginx_status=$(docker ps --filter "name=yj-family-nginx" --format "{{.Status}}" 2>/dev/null || echo "未运行")

        printf "  %-20s %s\n" "TaskRunner (8788)" "$tr_status"
        printf "  %-20s %s\n" "WebUI (5177)" "$webui_status"
        printf "  %-20s %s\n" "nginx (80)" "$nginx_status"

        # 检查健康状态
        echo ""
        if curl -s --max-time 2 http://localhost:8788/health > /dev/null 2>&1; then
            echo "[✓] TaskRunner 健康检查通过"
        else
            echo "[✗] TaskRunner 健康检查失败"
        fi
        if curl -s --max-time 2 http://localhost:8789/health > /dev/null 2>&1; then
            echo "[✓] TaskRunner.AI 健康检查通过"
        else
            echo "[✗] TaskRunner.AI 健康检查失败"
        fi
        if curl -s --max-time 2 http://localhost:8790/health > /dev/null 2>&1; then
            echo "[✓] TaskRunner.Vault 健康检查通过"
        else
            echo "[✗] TaskRunner.Vault 健康检查失败"
        fi
        if curl -s --max-time 2 http://localhost:5177/health > /dev/null 2>&1; then
            echo "[✓] WebUI 健康检查通过"
        else
            echo "[✗] WebUI 健康检查失败"
        fi
    elif [ "$mode" = "native" ]; then
        echo "[模式] 裸机进程"
        echo ""
        local tr_pid webui_pid
        tr_pid=$(lsof -ti:8788 -sTCP:LISTEN 2>/dev/null || echo "")
        webui_pid=$(lsof -ti:5177 -sTCP:LISTEN 2>/dev/null || echo "")

        if [ -n "$tr_pid" ]; then
            printf "  %-20s PID %s\n" "TaskRunner (8788)" "$tr_pid"
        else
            printf "  %-20s %s\n" "TaskRunner (8788)" "未运行"
        fi

        if [ -n "$webui_pid" ]; then
            printf "  %-20s PID %s\n" "WebUI (5177)" "$webui_pid"
        else
            printf "  %-20s %s\n" "WebUI (5177)" "未运行"
        fi
    else
        echo "[已停止] 所有服务未运行"
    fi
}

cmd_stop() {
    echo "正在停止服务..."
    local stopped=0
    local modes
    modes=$(_detect_all_modes)

    # 总是尝试停止 Docker（即使检测到的模式不是 docker，防止残留）
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qE "yj-family-(webui|taskrunner|taskrunner-ai|taskrunner-vault|nginx)"; then
        echo "[模式] Docker 容器"
        cd "$YJ_ROOT/docker"
        if docker compose down --remove-orphans >/dev/null 2>&1; then
            echo "[✓] 已停止 Docker 容器"
            stopped=1
        else
            echo "[✗] Docker 停止失败，尝试强制清理..."
            docker compose kill 2>/dev/null || true
            docker compose down --remove-orphans 2>/dev/null || true
            stopped=1
        fi
    fi

    # 总是尝试停止裸机进程（即使检测到的模式不是 native，防止残留）
    PID=$(lsof -ti:8788 -sTCP:LISTEN 2>/dev/null || true)
    if [ -n "$PID" ]; then
        echo "[模式] 裸机进程 (TaskRunner PID: $PID)"
        kill "$PID" 2>/dev/null && sleep 1
        kill -9 "$PID" 2>/dev/null || true
        echo "[✓] 已停止 TaskRunner（PID: $PID）"
        stopped=1
    fi

    PID_WUF=$(lsof -ti:5177 -sTCP:LISTEN 2>/dev/null || true)
    if [ -n "$PID_WUF" ]; then
        echo "[模式] 裸机进程 (WebUI PID: $PID_WUF)"
        kill "$PID_WUF" 2>/dev/null && sleep 1
        kill -9 "$PID_WUF" 2>/dev/null || true
        echo "[✓] 已停止 WebUI（PID: $PID_WUF）"
        stopped=1
    fi

    if [ "$stopped" -eq 0 ]; then
        echo "[提示] 服务未运行"
    fi
    rm -f "$PID_FILE"
}

cmd_restart() {
    echo "═══════════════════════════════════════"
    echo "  正在重启百花谷服务"
    echo "═══════════════════════════════════════"
    echo ""
    local mode
    mode=$(_detect_mode)

    if [ "$mode" = "docker" ]; then
        echo "[模式] Docker 容器"
        cd "$YJ_ROOT/docker"
        local services="taskrunner taskrunner-ai taskrunner-vault webui nginx"
        # 检测是否需要重建（代码有变更才 --build）
        local build_flag=""
        if _needs_rebuild "yj-family/taskrunner:latest" || _needs_rebuild "yj-family/taskrunner-ai:latest" || _needs_rebuild "yj-family/taskrunner-vault:latest" || _needs_rebuild "yj-family/webui:latest"; then
            echo "[…] 检测到源码更新，重新构建…"
            build_flag="--build"
        fi
        docker compose -p yj-family up -d $build_flag --force-recreate $services
        echo "[✓] 服务已重启"
    else
        cmd_stop
        sleep 1
        cmd_start
    fi
}

cmd_logs() {
    local service="${1:-all}"
    local mode
    mode=$(_detect_mode)

    if [ "$mode" = "docker" ]; then
        case "$service" in
            taskrunner|tr)
                docker logs -f --tail 100 yj-family-taskrunner 2>&1
                ;;
            webui|wuf)
                docker logs -f --tail 100 yj-family-webui 2>&1
                ;;
            nginx)
                docker logs -f --tail 100 yj-family-nginx 2>&1
                ;;
            ai|taskrunner-ai)
                docker logs -f --tail 100 yj-family-taskrunner-ai 2>&1
                ;;
            vault|taskrunner-vault)
                docker logs -f --tail 100 yj-family-taskrunner-vault 2>&1
                ;;
            all|*)
                echo "=== TaskRunner ==="
                docker logs --tail 50 yj-family-taskrunner 2>&1
                echo ""
                echo "=== TaskRunner.AI ==="
                docker logs --tail 50 yj-family-taskrunner-ai 2>&1
                echo ""
                echo "=== TaskRunner.Vault ==="
                docker logs --tail 50 yj-family-taskrunner-vault 2>&1
                echo ""
                echo "=== WebUI ==="
                docker logs --tail 50 yj-family-webui 2>&1
                ;;
        esac
    else
        case "$service" in
            taskrunner|tr)
                tail -f /tmp/yj-taskrunner-family.log 2>/dev/null || tail -f /tmp/yj-service.log 2>/dev/null
                ;;
            webui|wuf)
                tail -f /tmp/yj-webui-family.log 2>/dev/null
                ;;
            all|*)
                echo "=== TaskRunner ==="
                tail -n 50 /tmp/yj-taskrunner-family.log 2>/dev/null || tail -n 50 /tmp/yj-service.log 2>/dev/null
                echo ""
                echo "=== WebUI ==="
                tail -n 50 /tmp/yj-webui-family.log 2>/dev/null
                ;;
        esac
    fi
}

cmd_open() {
    if command -v xdg-open &> /dev/null; then
        xdg-open http://localhost:5177
    elif command -v open &> /dev/null; then
        open http://localhost:5177
    else
        echo "请手动打开浏览器访问: http://localhost:5177"
    fi
}

cmd_dashboard() {
    local edition="family"
    local edition_cap="Family"
    local port=5177
    local base_url="http://localhost:$port"
    local health_url="$base_url/health"
    local taskrunner_port=8788
    local taskrunner_url="http://localhost:$taskrunner_port/health"
    local force_build=0

    # 解析参数
    while [ $# -gt 0 ]; do
        case "$1" in
            --force-build|-f)
                force_build=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    echo "正在检测 WebUI (family) 服务状态..."

    # 检查 Docker 是否可用
    if command -v docker &> /dev/null && docker info &> /dev/null 2>&1; then
        # 使用 Docker 启动服务
        echo "[ℹ] 检测到 Docker，使用容器化部署"

        # 检查容器是否已运行（若已运行，跳过裸机检测，避免误判容器内进程为裸机）
        local webui_running=0
        if docker ps --format '{{.Names}}' | grep -q "yj-family-webui"; then
            webui_running=1
            echo "[✓] WebUI 容器正在运行"
        fi

        # 仅在容器未运行时，检查裸机进程（避免 Docker 与裸机共存）
        if [ $webui_running -eq 0 ] && (lsof -ti:8788 -sTCP:LISTEN &>/dev/null || lsof -ti:5177 -sTCP:LISTEN &>/dev/null); then
            echo "[!] 检测到裸机进程正在运行（端口 8788/5177）"
            echo "    Family 版不支持同时运行 Docker 和裸机进程"
            echo "    请先停止裸机进程: ./yj stop"
            echo "    或直接使用裸机模式: ./yj start"
            exit 1
        fi

        # 检测镜像是否需要更新（即使容器已在运行）
        local need_build=0
        if [ "$force_build" -eq 1 ]; then
            need_build=1
            echo "[ℹ] 强制重建模式"
        elif ! docker images yj-family/webui:latest --format '{{.ID}}' | grep -q .; then
            need_build=1
        elif _needs_rebuild "yj-family/webui:latest" || _needs_rebuild "yj-family/taskrunner:latest"; then
            need_build=1
        fi

        if [ $webui_running -eq 0 ] || [ $need_build -eq 1 ]; then
            if [ $webui_running -eq 1 ] && [ $need_build -eq 1 ]; then
                echo "[…] 检测到源码有更新，正在重建并重启容器…"
            elif [ $webui_running -eq 0 ]; then
                echo "[…] 正在启动 Docker 容器…"
            fi

            # 确保数据目录存在
            mkdir -p /opt/yj-family/data /opt/yj-family/logs /opt/yj-family/config/nginx

            # 确保加密密钥文件存在（自动管理，容器重建后仍然可用）
            ensure_encryption_key

            # 复制 nginx 配置（如果不存在）
            if [ ! -f /opt/yj-family/config/nginx/nginx.conf ]; then
                cp "$YJ_ROOT/docker/nginx/nginx.conf" /opt/yj-family/config/nginx/nginx.conf 2>/dev/null || true
            fi

            # 进入 docker 目录并启动
            cd "$YJ_ROOT/docker"

            # 确定 build 标志
            local build_flag=""
            if [ $need_build -eq 1 ]; then
                if ! docker images yj-family/webui:latest --format '{{.ID}}' | grep -q .; then
                    echo "  → 首次运行，构建 Docker 镜像（可能需要几分钟）…"
                else
                    echo "  → 重新构建 Docker 镜像…"
                fi
                build_flag="--build"
            fi

            # 导出构建参数，确保镜像携带版本信息用于下次比对
            export GIT_COMMIT=$(cd "$YJ_ROOT" && git rev-parse HEAD 2>/dev/null || echo "unknown")
            export GIT_BRANCH=$(cd "$YJ_ROOT" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")

            # 智能清理：只删除异常状态的 yj-family 容器，保留正常运行的
            # 避免手动操作单个容器后导致的 compose 状态不一致
            local abnormal_containers
            abnormal_containers=$(docker ps -a --filter "name=yj-family-" --format "{{.Names}}|{{.State}}" 2>/dev/null | grep -v "|running" | cut -d'|' -f1 || true)
            if [ -n "$abnormal_containers" ]; then
                echo "  → 清理异常容器: $(echo $abnormal_containers | tr '\n' ' ')"
                echo "$abnormal_containers" | while read -r c; do
                    [ -n "$c" ] && docker rm -f "$c" > /dev/null 2>&1 || true
                done
            fi

            # 导出当前用户 UID/GID，使容器以当前用户运行（避免文件 owner 为 root）
            export USER_UID=$(id -u)
            export USER_GID=$(id -g)

            # 启动/重建容器；如果因名称冲突失败，自动 down 后重试一次
            local up_output
            up_output=$(docker compose up -d $build_flag --remove-orphans 2>&1) || true
            if echo "$up_output" | grep -qiE "conflict|already in use"; then
                echo "  → 检测到容器冲突，执行完整清理后重试…"
                docker compose down --remove-orphans > /dev/null 2>&1 || true
                docker rm -f yj-family-taskrunner yj-family-taskrunner-ai yj-family-taskrunner-vault yj-family-webui yj-family-nginx 2>/dev/null || true
                docker compose up -d $build_flag --remove-orphans 2>&1 | grep -v "^$" || true
            else
                echo "$up_output" | grep -v "^$" || true
            fi

            # 等待服务就绪（最多 60 秒）
            echo "  → 等待服务就绪…"
            local wait_count=0
            while [ $wait_count -lt 60 ]; do
                sleep 1
                if curl -s --max-time 2 "$health_url" > /dev/null 2>&1; then
                    echo "[✓] 服务已就绪"
                    break
                fi
                wait_count=$((wait_count + 1))
                if [ $((wait_count % 10)) -eq 0 ]; then
                    echo "     已等待 ${wait_count}s…"
                fi
            done

            if ! curl -s --max-time 2 "$health_url" > /dev/null 2>&1; then
                echo "[✗] 服务启动超时（60秒）"
                echo "请查看容器日志："
                echo "  docker logs yj-family-webui"
                echo "  docker logs yj-family-taskrunner"
                echo "  docker logs yj-family-taskrunner-ai"
                echo "  docker logs yj-family-taskrunner-vault"
                exit 1
            fi
        fi
    else
        # 回退到直接运行 dotnet（无 Docker）
        echo "[ℹ] Docker 不可用，使用直接运行模式"

        # 如果服务未运行，自动启动
        if ! curl -s --max-time 2 "$health_url" > /dev/null 2>&1; then
            echo "[…] WebUI 未运行，正在自动启动 family 版服务…"

            if ! command -v dotnet &> /dev/null; then
                echo "[✗] 未检测到 .NET SDK，无法自动启动"
                echo "请先安装 .NET SDK：https://dotnet.microsoft.com/download"
                echo "或安装 Docker 以使用容器化部署"
                exit 1
            fi

            # 启动 TaskRunner（如果未运行）
            if ! curl -s --max-time 2 "$taskrunner_url" > /dev/null 2>&1; then
                echo "  → 启动 TaskRunner.Family (端口 $taskrunner_port)…"
                nohup dotnet run --project "$YJ_ROOT/services/TaskRunner.Family" --no-launch-profile > /tmp/yj-taskrunner-family.log 2>&1 &
            fi

            # 启动 WebUI
            echo "  → 启动 WebUI.Family (端口 $port)…"
            nohup dotnet run --project "$YJ_ROOT/services/WebUI.Family" --no-launch-profile > /tmp/yj-webui-family.log 2>&1 &

            # 等待服务就绪（最多 30 秒）
            echo "  → 等待服务就绪…"
            local wait_count=0
            while [ $wait_count -lt 30 ]; do
                sleep 1
                if curl -s --max-time 2 "$health_url" > /dev/null 2>&1; then
                    echo "[✓] 服务已就绪"
                    break
                fi
                wait_count=$((wait_count + 1))
                if [ $((wait_count % 5)) -eq 0 ]; then
                    echo "     已等待 ${wait_count}s…"
                fi
            done

            if ! curl -s --max-time 2 "$health_url" > /dev/null 2>&1; then
                echo "[✗] 服务启动超时（30秒）"
                echo "请查看日志："
                echo "  cat /tmp/yj-taskrunner-family.log"
                echo "  cat /tmp/yj-webui-family.log"
                exit 1
            fi
        else
            echo "[✓] WebUI 正在运行（端口 $port）"
        fi
    fi

    # 请求 CLI token
    local response
    response=$(curl -s --max-time 5 -X POST "$base_url/api/auth/cli-token" 2>/dev/null)
    local token
    token=$(echo "$response" | grep -o '"token":"[^"]*"' | cut -d'"' -f4)

    if [ -z "$token" ]; then
        echo "[✗] 无法获取访问令牌"
        echo "响应: $response"
        exit 1
    fi

    local dashboard_url="$base_url/?cli-token=$token"

    echo ""
    echo "╔══════════════════════════════════════╗"
    echo "║     正在打开 family 版管理面板       ║"
    echo "╚══════════════════════════════════════╝"
    echo ""

    # 复制到剪贴板（尽可能）
    local copied=0
    if command -v xclip &> /dev/null; then
        echo -n "$dashboard_url" | xclip -selection clipboard 2>/dev/null && copied=1
    elif command -v wl-copy &> /dev/null; then
        echo -n "$dashboard_url" | wl-copy 2>/dev/null && copied=1
    elif command -v pbcopy &> /dev/null; then
        echo -n "$dashboard_url" | pbcopy 2>/dev/null && copied=1
    fi

    if [ "$copied" -eq 1 ]; then
        echo "[✓] 授权 URL 已复制到剪贴板"
    fi

    # 打开浏览器
    local opened=0
    if command -v xdg-open &> /dev/null; then
        xdg-open "$dashboard_url" && opened=1
    elif command -v open &> /dev/null; then
        open "$dashboard_url" && opened=1
    fi

    if [ "$opened" -eq 1 ]; then
        echo "[✓] 浏览器已打开"
    else
        echo ""
        echo "请手动打开浏览器访问："
        echo "  $dashboard_url"
    fi

    echo ""
    echo "提示："
    echo "  • 此链接一次性有效，5 分钟内过期"
    echo "  • 仅允许本机（127.0.0.1）生成授权链接"
    if command -v docker &> /dev/null && docker ps --format '{{.Names}}' | grep -q "yj-family-webui"; then
        echo "  • Docker 容器已在运行，关闭终端不会停止服务"
        echo "  • 查看日志：docker logs yj-family-webui"
        echo "  • 停止服务：cd $YJ_ROOT/docker && docker compose down"
    else
        echo "  • 后台进程已在运行，关闭终端不会停止服务"
        echo "  • 查看日志：cat /tmp/yj-webui-family.log"
        echo "  • 停止服务：lsof -ti:$port | xargs kill -9"
    fi
}

# 主入口
case "${1:-}" in
    help|--help|-h)
        show_help
        ;;
    setup)
        cmd_setup
        ;;
    start)
        cmd_start
        ;;
    status)
        cmd_status
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    logs)
        cmd_logs "${2:-all}"
        ;;
    open)
        cmd_open
        ;;
    dashboard)
        cmd_dashboard
        ;;
    *)
        if [ -z "$1" ]; then
            cmd_dashboard
        else
            echo "未知命令: $1"
            show_help
        fi
        ;;
esac
