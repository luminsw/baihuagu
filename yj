#!/bin/bash
#
# 原记 Family 版 - 本地管理 CLI (Linux/Mac)
# 用法: ./yj [command]
#   yj                  默认打开 dashboard（管理面板）
#   yj setup            - 首次配置（设置 API Key、知识库路径）
#   yj start            - 启动服务
#   yj status           - 查看服务状态
#   yj stop             - 停止服务
#   yj open             - 打开 Web 管理界面
#   yj dashboard        - 一键打开管理面板（自动授权）

set -e

YJ_ROOT="$(cd "$(dirname "$0")" && pwd)"
TASK_RUNNER_DIR="$YJ_ROOT/services/TaskRunner.Family"
PID_FILE="/tmp/yj-service.pid"

# 检测是自包含版本还是源码版本
if [ -f "$YJ_ROOT/yj-service" ]; then
    IS_SELF_CONTAINED=1
    SERVICE_EXE="$YJ_ROOT/yj-service"
else
    IS_SELF_CONTAINED=0
fi

# 检测当前运行模式：docker 或 native（可同时存在）
_detect_mode() {
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qE "yj-family-(webui|taskrunner|taskrunner-ai|taskrunner-vault|nginx)"; then
        echo "docker"
    elif lsof -ti:8788 -sTCP:LISTEN &>/dev/null || lsof -ti:5177 -sTCP:LISTEN &>/dev/null; then
        echo "native"
    else
        echo "none"
    fi
}

# 检测所有活跃的运行模式（返回逗号分隔列表，如 "docker,native"）
_detect_all_modes() {
    local modes=""
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qE "yj-family-(webui|taskrunner|taskrunner-ai|taskrunner-vault|nginx)"; then
        modes="docker"
    fi
    if lsof -ti:8788 -sTCP:LISTEN &>/dev/null || lsof -ti:5177 -sTCP:LISTEN &>/dev/null; then
        [ -n "$modes" ] && modes="$modes,native" || modes="native"
    fi
    echo "$modes"
}

