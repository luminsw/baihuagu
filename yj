cmd_setup() {
    cat << 'EOF'

╔══════════════════════════════════════╗
║     百花谷 - 首次配置向导          ║
╚══════════════════════════════════════╝

本向导将帮助您完成基本配置。

EOF

    # 检查运行环境
    if [ "$IS_SELF_CONTAINED" -eq 1 ]; then
        echo "[✓] 自包含版本，无需 .NET SDK"
    else
        if ! command -v dotnet &> /dev/null; then
            echo "[错误] 未检测到 .NET SDK"
            echo ""
            echo "解决方案："
            echo "  1. 安装 .NET SDK：https://dotnet.microsoft.com/download"
            echo "  2. 或下载自包含版本（无需 .NET SDK）"
            exit 1
        fi
        echo "[✓] .NET SDK 已安装"
    fi

    # 配置知识库路径
    while true; do
        echo ""
        echo "【1/2】设置知识库路径"
        echo "知识库是您存放笔记的文件夹。可以先用 Obsidian 创建，"
        echo "也可以选择一个空文件夹，我们会帮您创建。"
        echo ""
        read -rp "请输入知识库路径（例如 ~/MyNotes）: " VAULT_PATH
        
        # 展开 ~
        VAULT_PATH="${VAULT_PATH/#\~/$HOME}"
        
