[Unit]
Description=WebUI Family
After=network.target taskrunner.service taskrunner-ai.service taskrunner-vault.service

[Service]
Type=simple
WorkingDirectory=/opt/yj-family/webui
EnvironmentFile=/etc/systemd/system/webui.env
Environment=WEBUI_CONFIG_DIR=/opt/yj/data
Environment=ASPNETCORE_URLS=http://0.0.0.0:5177
ExecStart=/usr/bin/dotnet WebUI.Family.dll --urls http://0.0.0.0:5177
Restart=always
RestartSec=5
StandardOutput=append:/opt/yj-family/logs/webui.log
StandardError=append:/opt/yj-family/logs/webui.log

[Install]
WantedBy=multi-user.target
