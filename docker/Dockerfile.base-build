# 基础镜像 - Build 阶段（包含 .NET SDK）
# 用于加速 TaskRunner 和 WebUI 的编译
#
# 构建命令：
#   docker build -f Dockerfile.base-build -t yj-family/base-build:latest ..
#
# 更新频率：
#   - 仅当 .NET SDK 版本更新时需要重建
#   - 应用代码变更无需重建此镜像

FROM mcr.microsoft.com/dotnet/sdk:10.0
WORKDIR /src

# 预安装常用工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*
