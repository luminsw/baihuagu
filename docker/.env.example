# ============================================
# Family Docker 部署环境变量模板
# 复制为 .env 后按需填写：cp .env.example .env
# ============================================

# ---------- OpenObserve 配置 ----------

# OpenObserve 管理员邮箱
OPENOBSERVE_ROOT_EMAIL=root@localhost.com

# OpenObserve 初始密码
OPENOBSERVE_ROOT_PASSWORD=Complexpass#123

# ---------- 数据持久化路径（宿主机）----------

# 数据目录（SQLite 数据库、运行时配置）
DATA_DIR=/opt/yj-family/data

# 日志目录
LOGS_DIR=/opt/yj-family/logs

# 应用配置目录（覆盖容器内默认配置）
CONFIG_DIR=/opt/yj-family/config

# 知识库根路径（宿主机实际路径，最终用户需改为自己的路径）
VAULTS_DIR=/home/lumin/Vaults
